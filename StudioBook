.dropdown-item:hover{background:var(–surface);color:var(–text);}
.dropdown-item.danger{color:var(–red);}
.dropdown-item.danger:hover{background:rgba(224,82,82,0.1);}

/* PARTNERS */
.partner-section{background:var(–bg2);border-top:1px solid var(–border);border-bottom:1px solid var(–border);padding:40px;}
.partner-head{text-align:center;margin-bottom:32px;}
