/* REVENUE */
.revenue-section{background:var(–bg2);padding:72px 40px;}
.revenue-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;}
.rev-card{background:var(–surface);border:1px solid var(–border);border-radius:14px;padding:20px;}
