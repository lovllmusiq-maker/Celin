<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StudioBook — Trouvez & Réservez Votre Studio</title>
<meta name="description" content="La première marketplace française dédiée aux studios d'enregistrement professionnels. Trouvez, comparez, réservez.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
:root {
  --bg:#0a0a0f; --bg2:#111118; --bg3:#16161f;
  --surface:#1c1c28; --surface2:#232333; --border:#2a2a3d;
  --gold:#c9a84c; --gold2:#e8c96a; --gold-dim:rgba(201,168,76,0.15);
  --text:#f0f0f8; --text2:#9898b8; --text3:#5a5a7a;
  --red:#e05252; --green:#52c093; --blue:#5b8dee;
  --radius:12px; --font-head:'Syne',sans-serif; --font-body:'DM Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;} html{scroll-behavior:smooth;}
body{font-family:var(--font-body);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
::-webkit-scrollbar{width:6px;} ::-webkit-scrollbar-track{background:var(--bg2);} ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}

/* HEADER */
header{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:68px;background:rgba(10,10,15,0.92);backdrop-filter:blur(20px);border-bottom:1px solid var(–border);}
.logo{font-family:var(–font-head);font-size:22px;font-weight:800;letter-spacing:-0.5px;color:var(–text);display:flex;align-items:center;gap:8px;cursor:pointer;}
.logo span{color:var(–gold);}
nav{display:flex;align-items:center;gap:8px;}
nav a{font-size:13.5px;font-weight:500;color:var(–text2);padding:6px 14px;border-radius:8px;cursor:pointer;transition:all .2s;text-decoration:none;}
nav a:hover,nav a.active{color:var(–text);background:var(–surface);}
.header-actions{display:flex;align-items:center;gap:10px;}
.btn-ghost{font-family:var(–font-body);font-size:13.5px;font-weight:500;padding:8px 18px;border-radius:8px;cursor:pointer;background:transparent;border:1px solid var(–border);color:var(–text2);transition:all .2s;}
.btn-ghost:hover{border-color:var(–gold);color:var(–gold);}
.btn-gold{font-family:var(–font-body);font-size:13.5px;font-weight:600;padding:8px 20px;border-radius:8px;cursor:pointer;background:var(–gold);border:none;color:#0a0a0f;transition:all .2s;}
.btn-gold:hover{background:var(–gold2);transform:translateY(-1px);}

/* HAMBURGER MOBILE */
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px;border:1px solid var(–border);border-radius:8px;background:var(–surface);}
.hamburger span{width:20px;height:2px;background:var(–text2);border-radius:2px;transition:all .3s;}
.hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px);}
.mobile-nav{display:none;position:fixed;top:68px;left:0;right:0;z-index:99;background:rgba(10,10,15,0.98);backdrop-filter:blur(20px);border-bottom:1px solid var(–border);padding:16px 20px;flex-direction:column;gap:4px;}
.mobile-nav.open{display:flex;}
.mobile-nav a{font-size:15px;font-weight:500;color:var(–text2);padding:10px 14px;border-radius:8px;cursor:pointer;transition:all .2s;}
.mobile-nav a:hover{color:var(–text);background:var(–surface);}

/* HERO */
.hero{padding:140px 40px 80px;display:flex;flex-direction:column;align-items:center;text-align:center;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse 60% 50% at 20% 60%,rgba(201,168,76,0.07) 0%,transparent 70%),radial-gradient(ellipse 50% 60% at 80% 30%,rgba(91,141,238,0.06) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 50% 10%,rgba(201,168,76,0.04) 0%,transparent 60%);}
.hero-badge{position:relative;z-index:1;display:inline-flex;align-items:center;gap:6px;background:var(–gold-dim);border:1px solid rgba(201,168,76,0.3);border-radius:100px;padding:5px 14px;font-size:12px;color:var(–gold2);font-weight:600;letter-spacing:0.5px;margin-bottom:28px;animation:fadeUp .6s ease both;}
.hero-badge::before{content:‘●’;font-size:8px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
h1{position:relative;z-index:1;font-family:var(–font-head);font-size:clamp(38px,6vw,76px);font-weight:800;line-height:1.05;letter-spacing:-2px;color:var(–text);max-width:900px;animation:fadeUp .6s .1s ease both;}
h1 em{font-style:normal;color:var(–gold);}
.hero-sub{position:relative;z-index:1;font-size:18px;color:var(–text2);max-width:540px;line-height:1.7;margin-top:20px;font-weight:300;animation:fadeUp .6s .2s ease both;}
.search-wrap{position:relative;z-index:1;margin-top:40px;width:100%;max-width:760px;animation:fadeUp .6s .3s ease both;}
.search-bar{display:flex;align-items:center;background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:6px 6px 6px 20px;gap:12px;transition:border-color .2s;}
.search-bar:focus-within{border-color:var(–gold);}
.search-divider{width:1px;height:32px;background:var(–border);flex-shrink:0;}
.search-field{display:flex;flex-direction:column;flex:1;min-width:0;}
.search-field label{font-size:10px;font-weight:600;color:var(–text3);letter-spacing:.5px;text-transform:uppercase;}
.search-field input,.search-field select{background:transparent;border:none;outline:none;font-family:var(–font-body);font-size:14px;font-weight:500;color:var(–text);padding:2px 0;width:100%;}
.search-field select option{background:var(–bg2);}
.btn-search{background:var(–gold);border:none;border-radius:12px;padding:14px 28px;font-family:var(–font-head);font-size:15px;font-weight:700;color:#0a0a0f;cursor:pointer;white-space:nowrap;transition:all .2s;flex-shrink:0;}
.btn-search:hover{background:var(–gold2);transform:scale(1.02);}
.hero-stats{position:relative;z-index:1;display:flex;align-items:center;gap:40px;margin-top:36px;animation:fadeUp .6s .4s ease both;flex-wrap:wrap;justify-content:center;}
.stat{text-align:center;}
.stat strong{font-family:var(–font-head);font-size:26px;font-weight:800;color:var(–text);display:block;}
.stat span{font-size:12px;color:var(–text3);font-weight:400;}
.stat-sep{width:1px;height:36px;background:var(–border);}

/* AD BANNER */
.ad-banner{margin:0 40px;padding:14px 24px;background:linear-gradient(135deg,rgba(91,141,238,0.1),rgba(82,192,147,0.08));border:1px solid rgba(91,141,238,0.25);border-radius:12px;display:flex;align-items:center;justify-content:space-between;gap:20px;font-size:13px;color:var(–text2);}
.ad-banner strong{color:var(–blue);}
.ad-tag{font-size:10px;font-weight:700;letter-spacing:1px;color:var(–text3);background:var(–surface);border:1px solid var(–border);padding:2px 8px;border-radius:4px;text-transform:uppercase;flex-shrink:0;}
.ad-cta{padding:7px 16px;background:var(–blue);border:none;border-radius:8px;font-family:var(–font-body);font-size:12px;font-weight:600;color:#fff;cursor:pointer;transition:opacity .2s;white-space:nowrap;}
.ad-cta:hover{opacity:.85;}

/* SECTION */
section{padding:72px 40px;}
.section-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:36px;}
.section-head h2{font-family:var(–font-head);font-size:30px;font-weight:800;letter-spacing:-1px;color:var(–text);}
.section-head p{font-size:14px;color:var(–text2);margin-top:4px;}
.see-all{font-size:13px;font-weight:600;color:var(–gold);cursor:pointer;border:1px solid rgba(201,168,76,0.3);padding:7px 16px;border-radius:8px;transition:all .2s;background:transparent;font-family:var(–font-body);}
.see-all:hover{background:var(–gold-dim);}

/* FILTERS */
.filters{display:flex;align-items:center;gap:8px;margin-bottom:28px;flex-wrap:wrap;}
.filter-chip{padding:7px 16px;border-radius:100px;font-size:13px;font-weight:500;border:1px solid var(–border);background:var(–surface);color:var(–text2);cursor:pointer;transition:all .2s;}
.filter-chip:hover,.filter-chip.active{border-color:var(–gold);color:var(–gold);background:var(–gold-dim);}

/* SEARCH BAR studios */
.studio-search-bar{display:flex;align-items:center;gap:10px;margin-bottom:20px;}
.studio-search-input{flex:1;padding:10px 16px;background:var(–surface);border:1px solid var(–border);border-radius:10px;font-family:var(–font-body);font-size:14px;color:var(–text);outline:none;transition:border-color .2s;}
.studio-search-input:focus{border-color:var(–gold);}
.sort-select{padding:10px 14px;background:var(–surface);border:1px solid var(–border);border-radius:10px;font-family:var(–font-body);font-size:13px;color:var(–text2);outline:none;cursor:pointer;}
.sort-select option{background:var(–bg2);}
.results-count{font-size:13px;color:var(–text3);margin-bottom:16px;}
.results-count span{color:var(–gold);font-weight:700;}

/* STUDIO GRID */
.studio-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;}
.studio-card{background:var(–surface);border:1px solid var(–border);border-radius:16px;overflow:hidden;transition:all .25s;cursor:pointer;}
.studio-card:hover{border-color:rgba(201,168,76,0.4);transform:translateY(-4px);box-shadow:0 20px 60px rgba(0,0,0,0.5);}
.card-img{position:relative;height:200px;overflow:hidden;background:var(–surface2);display:flex;align-items:center;justify-content:center;font-size:80px;}
.card-badge{position:absolute;top:12px;left:12px;background:rgba(10,10,15,0.85);backdrop-filter:blur(8px);border:1px solid var(–border);border-radius:8px;padding:4px 10px;font-size:11px;font-weight:700;color:var(–gold);letter-spacing:.3px;}
.card-fav{position:absolute;top:12px;right:12px;width:34px;height:34px;background:rgba(10,10,15,0.75);backdrop-filter:blur(8px);border:1px solid var(–border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;transition:all .2s;}
.card-fav:hover{background:var(–surface2);transform:scale(1.1);}
.card-avail{position:absolute;bottom:12px;right:12px;background:rgba(82,192,147,0.9);border-radius:6px;padding:3px 10px;font-size:11px;font-weight:700;color:#0a2918;}
.card-body{padding:18px;}
.card-location{font-size:11.5px;color:var(–text3);display:flex;align-items:center;gap:4px;margin-bottom:6px;font-weight:500;}
.card-name{font-family:var(–font-head);font-size:18px;font-weight:700;color:var(–text);letter-spacing:-.3px;margin-bottom:6px;}
.card-desc{font-size:13px;color:var(–text2);line-height:1.6;margin-bottom:12px;}
.card-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;}
.tag{padding:3px 10px;border-radius:6px;font-size:11.5px;font-weight:600;background:var(–surface2);color:var(–text3);border:1px solid var(–border);}
.card-footer{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid var(–border);}
.card-rating{display:flex;align-items:center;gap:5px;font-size:13px;}
.stars{color:var(–gold);font-size:12px;}
.rating-count{color:var(–text3);font-size:12px;}
.card-price{text-align:right;}
.price-from{font-size:10px;color:var(–text3);text-transform:uppercase;letter-spacing:.5px;}
.price-val{font-family:var(–font-head);font-size:20px;font-weight:800;color:var(–text);}
.price-unit{font-size:12px;color:var(–text3);}
.no-results{text-align:center;padding:60px 20px;color:var(–text3);}
.no-results h3{font-family:var(–font-head);font-size:22px;color:var(–text2);margin-bottom:8px;}

/* MAP */
.map-section{padding:0 40px 72px;}
.map-wrap{border-radius:20px;overflow:hidden;border:1px solid var(–border);position:relative;height:480px;}
#leaflet-map{width:100%;height:100%;}
.leaflet-container{background:var(–bg3);}

/* ENGINEERS */
.engineer-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:20px;}
.eng-card{background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:22px;transition:all .25s;cursor:pointer;display:flex;flex-direction:column;gap:14px;}
.eng-card:hover{border-color:rgba(201,168,76,0.35);transform:translateY(-3px);box-shadow:0 16px 50px rgba(0,0,0,.4);}
.eng-top{display:flex;align-items:center;gap:14px;}
.eng-avatar{width:56px;height:56px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:26px;border:2px solid var(–border);}
.eng-name{font-family:var(–font-head);font-size:16px;font-weight:700;color:var(–text);}
.eng-title{font-size:12px;color:var(–text3);margin-top:2px;}
.eng-studio-link{font-size:12px;color:var(–gold);font-weight:500;}
.eng-bio{font-size:13px;color:var(–text2);line-height:1.6;}
.eng-skills{display:flex;gap:6px;flex-wrap:wrap;}
.eng-skill{padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;border:1px solid rgba(201,168,76,0.3);color:var(–gold);background:var(–gold-dim);}
.eng-footer{display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid var(–border);}
.eng-xp{font-size:12px;color:var(–text3);}
.eng-xp strong{color:var(–text);font-weight:600;}
.eng-rate{font-family:var(–font-head);font-size:15px;font-weight:700;color:var(–text);}

/* PRICING */
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:8px;}
.price-card{background:var(–surface);border:1px solid var(–border);border-radius:20px;padding:32px 28px;position:relative;transition:all .25s;}
.price-card:hover{transform:translateY(-4px);}
.price-card.featured{border-color:var(–gold);background:linear-gradient(145deg,var(–surface),rgba(201,168,76,0.07));}
.price-pop{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(–gold);color:#0a0a0f;font-size:11px;font-weight:800;padding:4px 16px;border-radius:100px;letter-spacing:.5px;white-space:nowrap;}
.price-name{font-family:var(–font-head);font-size:14px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.price-amount{font-family:var(–font-head);font-size:42px;font-weight:800;color:var(–text);letter-spacing:-2px;line-height:1;}
.price-amount sup{font-size:20px;vertical-align:top;margin-top:8px;display:inline-block;color:var(–text2);}
.price-per{font-size:13px;color:var(–text3);margin-top:4px;margin-bottom:24px;}
.price-features{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:28px;}
.price-features li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(–text2);}
.price-features li::before{content:‘✓’;color:var(–green);font-weight:700;font-size:13px;}
.price-features li.no::before{content:‘✕’;color:var(–text3);}
.price-features li.no{color:var(–text3);}
.btn-price{width:100%;padding:13px;border-radius:12px;font-family:var(–font-head);font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;border:1px solid var(–border);background:var(–surface2);color:var(–text);}
.btn-price:hover{border-color:var(–gold);color:var(–gold);}
.price-card.featured .btn-price{background:var(–gold);color:#0a0a0f;border-color:var(–gold);}
.price-card.featured .btn-price:hover{background:var(–gold2);}

/* MODAL */
.modal-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.85);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(–bg2);border:1px solid var(–border);border-radius:20px;width:100%;max-width:920px;max-height:90vh;overflow-y:auto;transform:translateY(30px) scale(.97);transition:transform .3s;position:relative;}
.modal-overlay.open .modal{transform:none;}
.modal-close{position:absolute;top:16px;right:16px;z-index:2;width:36px;height:36px;border-radius:50%;background:var(–surface);border:1px solid var(–border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:var(–text2);transition:all .2s;}
.modal-close:hover{border-color:var(–gold);color:var(–gold);}
.modal-hero{height:280px;background:var(–surface2);position:relative;border-radius:20px 20px 0 0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:80px;}
.modal-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,var(–bg2) 0%,transparent 60%);}
.modal-hero-content{position:absolute;bottom:20px;left:28px;right:28px;}
.modal-hero-content h2{font-family:var(–font-head);font-size:28px;font-weight:800;letter-spacing:-1px;color:var(–text);}
.modal-hero-content p{font-size:14px;color:var(–text2);margin-top:4px;}
.modal-body{padding:28px;display:grid;grid-template-columns:1fr 320px;gap:28px;}
.modal-info-section{display:flex;flex-direction:column;gap:24px;}
.info-block h4{font-family:var(–font-head);font-size:14px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
.equip-list{display:flex;gap:8px;flex-wrap:wrap;}
.equip-item{padding:6px 12px;background:var(–surface);border:1px solid var(–border);border-radius:8px;font-size:12.5px;color:var(–text2);}

/* BOOKING PANEL */
.booking-panel{background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:22px;height:fit-content;position:sticky;top:20px;}
.booking-panel h3{font-family:var(–font-head);font-size:18px;font-weight:800;color:var(–text);margin-bottom:4px;}
.booking-price-line{font-size:13px;color:var(–text2);margin-bottom:20px;}
.booking-price-line strong{font-size:22px;color:var(–text);font-family:var(–font-head);}
.form-group{margin-bottom:14px;}
.form-group label{font-size:11.5px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:6px;}
.form-group input,.form-group select{width:100%;padding:10px 14px;background:var(–bg);border:1px solid var(–border);border-radius:10px;font-family:var(–font-body);font-size:14px;color:var(–text);outline:none;transition:border-color .2s;}
.form-group input:focus,.form-group select:focus{border-color:var(–gold);}
.form-group select option{background:var(–bg2);}
.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:14px;}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:8px;font-size:12px;cursor:pointer;transition:all .15s;font-weight:500;}
.cal-day.header{color:var(–text3);font-size:10px;font-weight:700;letter-spacing:.5px;cursor:default;}
.cal-day.empty{pointer-events:none;}
.cal-day.available{color:var(–text2);}
.cal-day.available:hover{background:var(–surface2);color:var(–text);}
.cal-day.selected{background:var(–gold);color:#0a0a0f;font-weight:700;}
.cal-day.booked{color:var(–text3);text-decoration:line-through;cursor:not-allowed;}
.cal-day.today{border:1px solid var(–gold);color:var(–gold);}
.time-slots{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:16px;}
.time-slot{padding:7px 4px;border-radius:8px;border:1px solid var(–border);background:var(–surface2);text-align:center;font-size:11.5px;color:var(–text2);cursor:pointer;transition:all .15s;}
.time-slot:hover{border-color:var(–gold);color:var(–gold);}
.time-slot.selected{background:var(–gold-dim);border-color:var(–gold);color:var(–gold);font-weight:600;}
.time-slot.taken{color:var(–text3);cursor:not-allowed;opacity:.5;text-decoration:line-through;}
.booking-summary{background:var(–bg);border-radius:10px;padding:14px;margin-bottom:16px;}
.summary-row{display:flex;justify-content:space-between;align-items:center;font-size:13px;margin-bottom:8px;color:var(–text2);}
.summary-row:last-child{margin:0;padding-top:10px;border-top:1px solid var(–border);font-weight:700;color:var(–text);font-size:14px;}
.btn-reserve{width:100%;padding:14px;background:var(–gold);border:none;border-radius:12px;font-family:var(–font-head);font-size:15px;font-weight:700;color:#0a0a0f;cursor:pointer;transition:all .2s;}
.btn-reserve:hover{background:var(–gold2);transform:translateY(-1px);}
.btn-reserve:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.secure-note{text-align:center;font-size:11px;color:var(–text3);margin-top:10px;display:flex;align-items:center;justify-content:center;gap:5px;}

/* STRIPE MODAL */
.stripe-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.9);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;}
.stripe-overlay.open{opacity:1;pointer-events:all;}
.stripe-modal{background:var(–bg2);border:1px solid var(–border);border-radius:20px;width:100%;max-width:480px;padding:32px;position:relative;transform:translateY(30px);transition:transform .3s;}
.stripe-overlay.open .stripe-modal{transform:none;}
.stripe-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;}
.stripe-header h3{font-family:var(–font-head);font-size:20px;font-weight:800;color:var(–text);}
.stripe-close{width:32px;height:32px;border-radius:50%;background:var(–surface);border:1px solid var(–border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(–text2);transition:all .2s;}
.stripe-close:hover{border-color:var(–red);color:var(–red);}
.stripe-amount-block{background:var(–surface);border-radius:12px;padding:16px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;}
.stripe-amount-label{font-size:13px;color:var(–text2);}
.stripe-amount-val{font-family:var(–font-head);font-size:24px;font-weight:800;color:var(–gold);}
.stripe-form-group{margin-bottom:16px;}
.stripe-form-group label{font-size:11px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:6px;}
.stripe-input{width:100%;padding:12px 14px;background:var(–bg);border:1px solid var(–border);border-radius:10px;font-family:var(–font-body);font-size:14px;color:var(–text);outline:none;transition:border-color .2s;}
.stripe-input:focus{border-color:var(–gold);}
.stripe-input::placeholder{color:var(–text3);}
.stripe-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.stripe-card-icons{display:flex;gap:6px;margin-bottom:16px;}
.stripe-card-icon{padding:4px 10px;background:var(–surface);border:1px solid var(–border);border-radius:6px;font-size:11px;font-weight:700;color:var(–text3);}
.btn-pay{width:100%;padding:16px;background:linear-gradient(135deg,#635BFF,#8B5CF6);border:none;border-radius:12px;font-family:var(–font-head);font-size:16px;font-weight:700;color:#fff;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px;}
.btn-pay:hover{transform:translateY(-1px);box-shadow:0 8px 30px rgba(99,91,255,0.4);}
.btn-pay:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.stripe-secure{text-align:center;font-size:11px;color:var(–text3);margin-top:12px;display:flex;align-items:center;justify-content:center;gap:6px;}
.stripe-powered{font-size:10px;color:var(–text3);text-align:center;margin-top:8px;}
.stripe-powered span{color:#635BFF;font-weight:700;}
.stripe-spinner{width:18px;height:18px;border:2px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

/* AUTH MODAL */
.auth-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.9);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s;}
.auth-overlay.open{opacity:1;pointer-events:all;}
.auth-modal{background:var(–bg2);border:1px solid var(–border);border-radius:20px;width:100%;max-width:420px;padding:32px;position:relative;transform:translateY(30px);transition:transform .3s;}
.auth-overlay.open .auth-modal{transform:none;}
.auth-tabs{display:flex;gap:4px;margin-bottom:28px;background:var(–surface);border-radius:10px;padding:4px;}
.auth-tab{flex:1;padding:8px;text-align:center;border-radius:8px;font-size:13px;font-weight:600;color:var(–text3);cursor:pointer;transition:all .2s;}
.auth-tab.active{background:var(–bg2);color:var(–text);border:1px solid var(–border);}
.auth-header{margin-bottom:24px;}
.auth-header h3{font-family:var(–font-head);font-size:22px;font-weight:800;color:var(–text);}
.auth-header p{font-size:13px;color:var(–text2);margin-top:4px;}
.auth-form-group{margin-bottom:14px;}
.auth-form-group label{font-size:11px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:6px;}
.auth-input{width:100%;padding:12px 14px;background:var(–bg);border:1px solid var(–border);border-radius:10px;font-family:var(–font-body);font-size:14px;color:var(–text);outline:none;transition:border-color .2s;}
.auth-input:focus{border-color:var(–gold);}
.auth-input::placeholder{color:var(–text3);}
.auth-role-select{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.role-card{padding:12px;border:1px solid var(–border);border-radius:10px;text-align:center;cursor:pointer;transition:all .2s;background:var(–bg);}
.role-card:hover,.role-card.selected{border-color:var(–gold);background:var(–gold-dim);}
.role-card span{font-size:22px;display:block;margin-bottom:4px;}
.role-card p{font-size:12px;font-weight:600;color:var(–text2);}
.role-card.selected p{color:var(–gold);}
.btn-auth{width:100%;padding:14px;background:var(–gold);border:none;border-radius:12px;font-family:var(–font-head);font-size:15px;font-weight:700;color:#0a0a0f;cursor:pointer;transition:all .2s;margin-top:6px;}
.btn-auth:hover{background:var(–gold2);transform:translateY(-1px);}
.auth-divider{display:flex;align-items:center;gap:12px;margin:18px 0;color:var(–text3);font-size:12px;}
.auth-divider::before,.auth-divider::after{content:’’;flex:1;height:1px;background:var(–border);}
.btn-social{width:100%;padding:12px;background:var(–surface);border:1px solid var(–border);border-radius:10px;font-family:var(–font-body);font-size:13px;font-weight:600;color:var(–text2);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:8px;}
.btn-social:hover{border-color:var(–text2);color:var(–text);}
.auth-close{position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:50%;background:var(–surface);border:1px solid var(–border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(–text2);transition:all .2s;}
.auth-close:hover{border-color:var(–red);color:var(–red);}
.auth-error{background:rgba(224,82,82,0.1);border:1px solid rgba(224,82,82,0.3);border-radius:8px;padding:10px 14px;font-size:13px;color:var(–red);margin-bottom:14px;display:none;}
.auth-error.show{display:block;}

/* USER MENU */
.user-menu{position:relative;}
.user-avatar{width:36px;height:36px;border-radius:50%;background:var(–gold-dim);border:2px solid var(–gold);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;font-weight:700;color:var(–gold);font-family:var(–font-head);}
.user-dropdown{position:absolute;top:calc(100% + 10px);right:0;background:var(–bg2);border:1px solid var(–border);border-radius:12px;min-width:200px;padding:8px;opacity:0;pointer-events:none;transform:translateY(-8px);transition:all .2s;z-index:50;}
