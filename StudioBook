// ═══════════════════════════════════════════════════════
// FILTRES FONCTIONNELS
// ═══════════════════════════════════════════════════════
function applyFilter(el) {
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  currentFilter = el.dataset.filter;
  applyAllFilters();
}

function applyAllFilters() {
  currentSearch = document.getElementById('studioSearchInput').value.toLowerCase().trim();
  currentSort = document.getElementById('sortSelect').value;

  let filtered = studios.filter((s, i) => {
    // filtre chip
    if (currentFilter === 'all') {}
    else if (currentFilter === 'top') { if (s.rating < 4.8) return false; }
    else if (currentFilter === 'budget') { if (s.price >= 50) return false; }
    else if (currentFilter === 'dispo') { if (!s.avail) return false; }
    else { if (!s.tags.some(t => t.toLowerCase().includes(currentFilter.toLowerCase()))) return false; }

    // filtre hero city
    if (currentHeroCity && !s.city.toLowerCase().includes(currentHeroCity.toLowerCase()) && !s.location.toLowerCase().includes(currentHeroCity.toLowerCase())) return false;

    // filtre hero type
    if (currentHeroType && !s.tags.some(t => t.toLowerCase().includes(currentHeroType.toLowerCase()))) return false;

    // filtre hero budget
    if (currentHeroBudget) {
      const b = parseInt(currentHeroBudget);
      if (b === 30 && s.price >= 30) return false;
      if (b === 80 && (s.price < 30 || s.price > 80)) return false;
      if (b === 150 && (s.price < 80 || s.price > 150)) return false;
      if (b === 999 && s.price <= 150) return false;
    }

    // filtre texte
    if (currentSearch) {
      const hay = (s.name + s.location + s.desc + s.tags.join(' ') + s.equip.join(' ')).toLowerCase();
      if (!hay.includes(currentSearch)) return false;
    }

    return true;
  }).map((s, _, arr) => ({ ...s, origIdx: studios.indexOf(s) }));

  // TRI
  if (currentSort === 'price_asc') filtered.sort((a, b) => a.price - b.price);
  else if (currentSort === 'price_desc') filtered.sort((a, b) => b.price - a.price);
  else if (currentSort === 'rating') filtered.sort((a, b) => b.rating - a.rating);

  renderFilteredStudios(filtered);
  updateMapMarkers(filtered);

  // update count
  const c = document.getElementById('resultsCount');
  if(c) c.innerHTML = `Affichage de <span>${filtered.length}</span> studio${filtered.length !== 1 ? 's' : ''}`;
}

function renderFilteredStudios(list) {
  const grid = document.getElementById('studioGrid');
  const noRes = document.getElementById('noResults');
  if (!list.length) {
    grid.innerHTML = '';
    noRes.style.display = 'block';
    return;
  }
  noRes.style.display = 'none';
  grid.innerHTML = list.map(s => `
    <div class="studio-card" onclick="openStudio(${s.origIdx})">
      <div class="card-img">${s.emoji}
        ${s.badge ? `<div class="card-badge">${s.badge}</div>` : ''}
        <div class="card-fav" onclick="event.stopPropagation();toggleFav(this)">🤍</div>
        <div class="card-avail" style="${s.avail ? '' : 'background:rgba(224,82,82,.85);color:#2a0a0a;'}">${s.avail ? 'Disponible' : 'Complet'}</div>
      </div>
      <div class="card-body">
        <div class="card-location">📍 ${s.location}</div>
        <div class="card-name">${s.name}</div>
        <div class="card-desc">${s.desc.substring(0,90)}...</div>
        <div class="card-tags">${s.tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>
        <div class="card-footer">
          <div class="card-rating"><span class="stars">★★★★★</span><strong>${s.rating}</strong><span class="rating-count">(${s.reviews})</span></div>
          <div class="card-price"><div class="price-from">À partir de</div><div><span class="price-val">${s.price}€</span><span class="price-unit">/h</span></div></div>
        </div>
      </div>
    </div>`).join('');
}

