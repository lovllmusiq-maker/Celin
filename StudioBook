// ═══════════════════════════════════════════════════════
// CARTE LEAFLET
// ═══════════════════════════════════════════════════════
function initMap() {
  if (leafletMap) return;
  if (typeof L === 'undefined') {
    setTimeout(initMap, 200);
    return;
  }
  leafletMap = L.map('leaflet-map').setView([46.8, 2.3], 5);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap · © CARTO',
    maxZoom: 18
  }).addTo(leafletMap);
  addAllMarkers(studios.map((s,i) => ({...s, origIdx:i})));
}

function addAllMarkers(list) {
  leafletMarkers.forEach(m => m.remove());
  leafletMarkers = [];
  list.forEach(s => {
    const icon = L.divIcon({
      html: `<div style="background:var(--gold,#c9a84c);border-radius:50% 50% 50% 0;transform:rotate(-45deg);width:36px;height:36px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(201,168,76,0.5);border:2px solid #0a0a0f;"><span style="transform:rotate(45deg);font-size:16px;">${s.emoji}</span></div>`,
      className: '',
      iconSize: [36, 36],
      iconAnchor: [18, 36],
      popupAnchor: [0, -38]
    });
    const marker = L.marker([s.lat, s.lng], { icon })
      .addTo(leafletMap)
      .bindPopup(`
        <div style="font-family:'DM Sans',sans-serif;min-width:200px;padding:4px;">
          <div style="font-size:18px;margin-bottom:6px;">${s.emoji}</div>
          <strong style="font-size:14px;color:#f0f0f8;">${s.name}</strong>
          <div style="font-size:12px;color:#9898b8;margin:4px 0;">📍 ${s.location}</div>
          <div style="font-size:13px;color:#c9a84c;font-weight:700;">${s.price}€/h</div>
          <div style="margin-top:6px;font-size:11px;color:${s.avail ? '#52c093' : '#e05252'}">${s.avail ? '✅ Disponible' : '❌ Complet'}</div>
          <button onclick="openStudio(${s.origIdx})" style="margin-top:10px;width:100%;padding:7px;background:#c9a84c;border:none;border-radius:8px;font-weight:700;font-size:12px;cursor:pointer;">Voir & Réserver</button>
        </div>
      `, { maxWidth: 260 });
    leafletMarkers.push(marker);
  });
}

function updateMapMarkers(filtered) {
  if (!leafletMap) return;
  addAllMarkers(filtered);
}

