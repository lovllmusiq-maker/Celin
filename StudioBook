.stream-name{font-size:13px;font-weight:600;color:var(–text);}
.stream-desc{font-size:11.5px;color:var(–text3);}
.stream-pct{font-family:var(–font-head);font-size:15px;font-weight:700;color:var(–gold);}
.stream-bar-wrap{background:var(–surface2);border-radius:4px;height:4px;margin-top:4px;}
.stream-bar{height:4px;border-radius:4px;background:var(–gold);transition:width 1s ease;}

/* NAV TABS */
.nav-tabs{display:flex;gap:4px;margin-bottom:32px;border-bottom:1px solid var(–border);}
.nav-tab{padding:10px 18px;font-size:14px;font-weight:600;color:var(–text3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .2s;}
.nav-tab.active{color:var(–gold);border-bottom-color:var(–gold);}
.nav-tab:hover{color:var(–text2);}

/* TOAST */
.toast{position:fixed;bottom:24px;right:24px;z-index:400;background:var(–surface);border:1px solid var(–border);border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:12px;font-size:14px;color:var(–text);box-shadow:0 8px 40px rgba(0,0,0,.5);transform:translateY(100px);opacity:0;transition:all .3s;max-width:340px;}
.toast.show{transform:none;opacity:1;}
.toast-icon{font-size:20px;}

/* FOOTER */
footer{background:var(–bg2);border-top:1px solid var(–border);padding:60px 40px 30px;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px;}
