.rev-change{font-size:12px;margin-top:4px;}
.rev-change.up{color:var(–green);}
.revenue-streams{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.stream-card{background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:24px;}
