function showSection(name) {
  ['home','studios','engineers','pricing','monetization'].forEach(s => {
    const el = document.getElementById('section-'+s);
    if(el) el.style.display = s===name ? '' : 'none';
  });
  document.querySelectorAll('nav a').forEach(a => {
    a.classList.toggle('active', a.dataset.section === name);
  });
  window.scrollTo({top:0, behavior:'smooth'});

  if(name === 'studios') {
    applyAllFilters();
    setTimeout(() => { initMap(); }, 300);
  }
  if(name === 'engineers') renderEngineers();
  if(name === 'pricing') {
    renderPricing(pricingPlans, 'pricingGrid');
    renderPricing(artistPricing, 'artistPricingGrid');
    renderPricing(partnerPricing, 'partnerPricingGrid');
