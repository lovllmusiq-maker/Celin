// ═══════════════════════════════════════════════════════
// CALENDRIER & CRÉNEAUX
// ═══════════════════════════════════════════════════════
function buildCalendar() {
  const grid = document.getElementById('calendarGrid');
  const today = new Date();
  const days = ['L','M','M','J','V','S','D'];
  const bookedDays = [3,7,14,19,22];
  let html = days.map(d => `<div class="cal-day header">${d}</div>`).join('');
  const firstDay = new Date(today.getFullYear(), today.getMonth(), 1).getDay();
  const offset = firstDay === 0 ? 6 : firstDay - 1;
  for(let i=0;i<offset;i++) html += `<div class="cal-day empty"></div>`;
  const daysInMonth = new Date(today.getFullYear(), today.getMonth()+1, 0).getDate();
  for(let d=1;d<=daysInMonth;d++){
    const isPast = d < today.getDate();
    const isBooked = bookedDays.includes(d);
    const isToday = d === today.getDate();
    let cls = 'cal-day ';
    cls += (isPast || isBooked) ? 'booked' : 'available';
    if(isToday) cls += ' today';
    html += `<div class="${cls}" onclick="selectDay(this,${d})">${d}</div>`;
  }
  grid.innerHTML = html;
}

function selectDay(el, day) {
  document.querySelectorAll('.cal-day.selected').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected');
  selectedDay = day;
  updateSummary();
}

function buildTimeSlots() {
  const slots = ['8h00','9h00','10h00','11h00','14h00','15h00','16h00','17h00','18h00','19h00','20h00','21h00'];
  const taken = ['9h00','14h00','15h00'];
  document.getElementById('timeSlots').innerHTML = slots.map(s =>
    `<div class="time-slot ${taken.includes(s)?'taken':''}" onclick="selectTime(this,'${s}')">${s}</div>`
  ).join('');
}

function selectTime(el, time) {
  document.querySelectorAll('.time-slot.selected').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected');
  selectedTime = time;
  updateSummary();
}

function updateSummary() {
  const dur = parseInt(document.getElementById('sessionDuration')?.value || 1);
  const engRate = parseInt(document.getElementById('engineerSelect')?.value || 0);
  const studio = currentStudioPrice * dur;
  const eng = engRate * dur;
  const sub = studio + eng;
  const fee = Math.round(sub * 0.08 * 100) / 100;
  totalAmount = parseFloat((sub + fee).toFixed(2));
  let rows = `<div class="summary-row"><span>Studio × ${dur}h</span><span>${studio}€</span></div>`;
  if (eng > 0) rows += `<div class="summary-row"><span>Ingénieur × ${dur}h</span><span>${eng}€</span></div>`;
  rows += `<div class="summary-row"><span>Frais de service (8%)</span><span>${fee}€</span></div>`;
  rows += `<div class="summary-row"><span>Total à payer</span><span>${totalAmount}€</span></div>`;
  document.getElementById('bookingSummary').innerHTML = rows;
}

