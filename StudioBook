// AUTH
// ═══════════════════════════════════════════════════════
function openAuth(tab='login') {
  switchAuthTab(tab);
  document.getElementById('authOverlay').classList.add('open');
}
function closeAuth() { document.getElementById('authOverlay').classList.remove('open'); }

function switchAuthTab(tab) {
  document.getElementById('loginForm').style.display = tab==='login' ? '' : 'none';
  document.getElementById('registerForm').style.display = tab==='register' ? '' : 'none';
  document.getElementById('tabLogin').classList.toggle('active', tab==='login');
  document.getElementById('tabRegister').classList.toggle('active', tab==='register');
}

function selectRole(r) {
  selectedRole = r;
  document.getElementById('roleArtist').classList.toggle('selected', r==='artist');
  document.getElementById('roleStudio').classList.toggle('selected', r==='studio');
}

function showAuthError(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 3500);
}

function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass = document.getElementById('loginPassword').value;
  if(!email || !pass) { showAuthError('loginError','Remplissez tous les champs.'); return; }
  if(!email.includes('@')) { showAuthError('loginError','Email invalide.'); return; }
  if(pass.length < 6) { showAuthError('loginError','Mot de passe trop court.'); return; }

  // Simulation auth (remplacer par Firebase/Supabase)
  const users = JSON.parse(localStorage.getItem('sb_users') || '[]');
  const found = users.find(u => u.email === email && u.password === pass);
  if(!found) { showAuthError('loginError','Email ou mot de passe incorrect.'); return; }

  setUser(found);
  closeAuth();
  showToast('👋', `Bon retour, ${found.name} !`);
}

function doRegister() {
  const name = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pass = document.getElementById('regPassword').value;
  if(!name||!email||!pass) { showAuthError('registerError','Remplissez tous les champs.'); return; }
  if(!email.includes('@')) { showAuthError('registerError','Email invalide.'); return; }
  if(pass.length < 8) { showAuthError('registerError','Mot de passe minimum 8 caractères.'); return; }

  const users = JSON.parse(localStorage.getItem('sb_users') || '[]');
  if(users.find(u => u.email === email)) { showAuthError('registerError','Cet email est déjà utilisé.'); return; }

  const newUser = { name, email, password: pass, role: selectedRole, createdAt: new Date().toISOString() };
  users.push(newUser);
  localStorage.setItem('sb_users', JSON.stringify(users));

  setUser(newUser);
  closeAuth();
  showToast('🎉', `Bienvenue, ${name} ! Compte créé avec succès.`);
}

function socialLogin(provider) {
  // Simulation sociale (remplacer par OAuth réel)
  const fakeUser = { name: `Utilisateur ${provider}`, email: `user@${provider.toLowerCase()}.com`, role: 'artist' };
  setUser(fakeUser);
  closeAuth();
  showToast('✅', `Connecté via ${provider}`);
}

function setUser(user) {
  currentUser = user;
  localStorage.setItem('sb_user', JSON.stringify(user));
  document.getElementById('authButtons').style.display = 'none';
  document.getElementById('userMenuWrap').style.display = '';
  const initials = user.name.split(' ').map(n=>n[0]).join('').toUpperCase().substring(0,2);
  document.getElementById('userAvatar').textContent = initials;
  document.getElementById('dropdownName').textContent = user.name;
  document.getElementById('dropdownRole').textContent = user.role === 'studio' ? '🎙 Studio' : '🎤 Artiste';
}

function logout() {
  currentUser = null;
  localStorage.removeItem('sb_user');
  document.getElementById('authButtons').style.display = '';
  document.getElementById('userMenuWrap').style.display = 'none';
  toggleDropdown(true);
  showToast('👋','Déconnecté avec succès');
}

function toggleDropdown(forceClose=false) {
  const dd = document.getElementById('userDropdown');
  if(forceClose) dd.classList.remove('open');
  else dd.classList.toggle('open');
}

