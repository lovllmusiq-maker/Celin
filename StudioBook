.sponsored-label{font-size:10px;font-weight:700;letter-spacing:1px;color:var(–text3);text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.sponsored-label::after{content:’’;flex:1;height:1px;background:var(–border);}
.sponsored-card{background:linear-gradient(135deg,var(–surface),rgba(91,141,238,0.05));border:1px solid rgba(91,141,238,0.2);border-radius:14px;padding:18px;display:flex;align-items:center;gap:16px;cursor:pointer;transition:all .2s;margin-bottom:12px;}
