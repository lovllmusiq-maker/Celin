// STRIPE PAYMENT
// ═══════════════════════════════════════════════════════
function proceedToPayment() {
  if (!selectedDay) { showToast('⚠️','Veuillez sélectionner une date'); return; }
  if (!selectedTime) { showToast('⚠️','Veuillez sélectionner un créneau'); return; }
  if (!currentUser) { showToast('🔐','Connectez-vous pour réserver'); openAuth('login'); return; }

  const dur = parseInt(document.getElementById('sessionDuration').value);
  document.getElementById('stripeLabel').textContent = `Réservation · ${currentStudioName}`;
  document.getElementById('stripeDetails').textContent = `${dur}h · ${selectedTime} le ${selectedDay} — Ingénieur: ${document.getElementById('engineerSelect').options[document.getElementById('engineerSelect').selectedIndex].text.split(' —')[0]}`;
  document.getElementById('stripeAmount').textContent = totalAmount + '€';
  document.getElementById('payAmount').textContent = totalAmount + '€';
  document.getElementById('paymentEmail').value = currentUser.email || '';
  document.getElementById('stripeOverlay').classList.add('open');
}

function closeStripe() { document.getElementById('stripeOverlay').classList.remove('open'); }

function formatCard(el) {
  let v = el.value.replace(/\D/g,'').substring(0,16);
  el.value = v.replace(/(.{4})/g,'$1 ').trim();
}
function formatExpiry(el) {
  let v = el.value.replace(/\D/g,'').substring(0,4);
  if(v.length>=2) v = v.substring(0,2)+'/'+v.substring(2);
  el.value = v;
}

function processPayment() {
  const name = document.getElementById('cardName').value.trim();
  const num = document.getElementById('cardNumber').value.replace(/\s/g,'');
  const exp = document.getElementById('cardExpiry').value;
  const cvv = document.getElementById('cardCvv').value;
  const email = document.getElementById('paymentEmail').value.trim();

  if(!name||!num||!exp||!cvv||!email){ showToast('⚠️','Remplissez tous les champs'); return; }
  if(num.length < 16){ showToast('⚠️','Numéro de carte invalide'); return; }
  if(exp.length < 5){ showToast('⚠️','Date d\'expiration invalide'); return; }
  if(cvv.length < 3){ showToast('⚠️','CVV invalide'); return; }
  if(!email.includes('@')){ showToast('⚠️','Email invalide'); return; }

  const btn = document.getElementById('btnPay');
  btn.disabled = true;
  btn.innerHTML = '<div class="stripe-spinner"></div>';

  setTimeout(() => {
    btn.disabled = false;
    btn.innerHTML = `<span id="payBtnText">🔒 Payer <span id="payAmount">${totalAmount}€</span></span>`;
    closeStripe();
    closeModal();
    showToast('🎉', `Réservation confirmée ! ${selectedTime} le ${selectedDay} — Confirmation envoyée à ${email}`);
  }, 2200);
}

