    lastPlayed: new Date().toISOString().split('T')[0],
  };
  try { await window.storage.set('lb:'+G.playerId, JSON.stringify(entry), true); } catch(e) {}
}

async function loadLb() {
  try {
    const res = await window.storage.list('lb:', true);
    if (!res || !res.keys || res.keys.length === 0) return [];
    const entries = [];
    for (const key of res.keys) {
      try {
        const r = await window.storage.get(key, true);
        if (r && r.value) entries.push(JSON.parse(r.value));
      } catch(e) {}
    }
    return entries.sort((a,b) => b.score - a.score);
  } catch(e) { return []; }
}

function demoPLayers() {
  const ns=['KobiNzinga','AmaraGold','FatimaSeeds','DialloBaoulé','NalediStar','KwameRoots','AminaKola','SeydouFicus','ZaraOkra','IssaDiawara'];
  const ds=['debutant','initie','initie','avance','avance','avance','expert','expert','expert','expert'];
  return ns.map((n,i)=>({id:'demo_'+i,name:n,score:Math.floor(8200-i*650+Math.random()*200),wins:Math.floor(42-i*3+Math.random()*8),losses:Math.floor(4+i*2),coins:Math.floor(4200-i*320),level:Math.max(1,8-Math.floor(i*0.7)),difficulty:ds[i],avatar:getAvatar(n),lastPlayed:'2025-03-'+String(Math.floor(Math.random()*14)+1).padStart(2,'0')}));
}

async function refreshLb() {
  document.getElementById('lb-loading').style.display='block';
  document.getElementById('lb-table').style.display='none';
  document.getElementById('lb-empty').style.display='none';
  let real = await loadLb();
  const demos = demoPLayers();
  const realIds = new Set(real.map(p=>p.id));
  const fill = demos.filter(d=>!realIds.has(d.id));
  lbCache = [...real, ...fill].sort((a,b)=>b.score-a.score);
  renderLb();
}

function filterLb(f, btn) {
  lbFilter = f;
  document.querySelectorAll('.lb-filter').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderLb();
}

function renderLb() {
  // Register zone
  document.getElementById('lb-register').style.display = G.playerName ? 'none' : 'block';

  // My card
  const me = lbCache.find(p=>p.id===G.playerId);
  const myRank = lbCache.findIndex(p=>p.id===G.playerId)+1;
  const myCard = document.getElementById('lb-my-card');
  if (me && G.playerName) {
    myCard.style.display='flex';
    document.getElementById('lb-my-rank').textContent='#'+(myRank||'–');
    document.getElementById('lb-my-name').textContent=me.avatar+' '+me.name;
    document.getElementById('lb-my-stats').textContent=
      `🏆 ${me.wins} victoires · 💀 ${me.losses||0} défaites · 🪙 ${me.coins} pièces\n${diffLabel(me.difficulty)} · Score: ${me.score.toLocaleString()} pts`;
    const lv=getLevel(me.score);
    document.getElementById('lb-my-badge').textContent=lv.emoji+' '+lv.name;
    document.getElementById('menu-rank').textContent='#'+myRank;
  } else { myCard.style.display='none'; }

  document.getElementById('lb-loading').style.display='none';

  let list = lbFilter==='all' ? lbCache : lbCache.filter(p=>p.difficulty===lbFilter);
  list = list.sort((a,b)=>b.score-a.score);

  if (list.length===0) {
    document.getElementById('lb-empty').style.display='block';
    document.getElementById('lb-table').style.display='none';
    return;
  }
  document.getElementById('lb-table').style.display='table';
  document.getElementById('lb-empty').style.display='none';

  const tbody = document.getElementById('lb-tbody');
  tbody.innerHTML='';
  list.forEach((p,i)=>{
    const rank=i+1, isMe=p.id===G.playerId;
    const lv=getLevel(p.score);
    let rankHtml, rclass='lb-row';
    if(rank===1){rankHtml='<span class="rank-medal">🥇</span>';rclass+=' r1';}
    else if(rank===2){rankHtml='<span class="rank-medal">🥈</span>';rclass+=' r2';}
    else if(rank===3){rankHtml='<span class="rank-medal">🥉</span>';rclass+=' r3';}
    else rankHtml=`<span class="rank-num">#${rank}</span>`;
    if(isMe)rclass+=' is-me';

    const tr=document.createElement('tr');
    tr.className=rclass;
    tr.style.animationDelay=`${i*0.04}s`;
    tr.innerHTML=`
      <td>${rankHtml}</td>
      <td>
        <div class="pname">${p.avatar} ${p.name}${isMe?'<span style="color:var(--gold);font-size:.65rem;font-family:Raleway,sans-serif">(vous)</span>':''}</div>
        <div class="pname-sub">${lv.emoji} ${lv.name} · ${p.lastPlayed||'–'}</div>
      </td>
      <td style="text-align:center"><div class="pscore">${p.score.toLocaleString()}</div><div class="pscore-sub">pts</div></td>
      <td style="text-align:center"><div style="font-family:'Cinzel Decorative',serif;color:#81c784;font-size:.88rem">${p.wins}</div><div class="pscore-sub">victoires</div></td>
      <td style="text-align:center"><span class="diff-pill ${diffPillClass(p.difficulty)}">${diffLabel(p.difficulty).split(' ')[0]}</span></td>
    `;
    tbody.appendChild(tr);
  });
}

async function registerPlayer() {
  const input=document.getElementById('lb-input');
  const name=input.value.trim();
  if(name.length<2){input.style.borderColor='#f44336';return;}
  G.playerName=name;
  localStorage.setItem('awale_name',name);
  input.style.borderColor='#4caf50';
  await saveLb();
  await refreshLb();
}

// ============================================================
// CORE
// ============================================================
function saveData(){
  localStorage.setItem('awale_coins',G.coins);
  localStorage.setItem('awale_wins',G.wins);
  localStorage.setItem('awale_losses',G.losses||0);
  localStorage.setItem('awale_level',G.level);
  localStorage.setItem('awale_seeds',JSON.stringify(G.ownedSeeds));
}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(id==='menu')updateMenuStats();
  if(id==='shop')renderShop();
  if(id==='leaderboard')refreshLb();
}
function updateMenuStats(){
  document.getElementById('menu-coins').textContent=G.coins;
  document.getElementById('menu-wins').textContent=G.wins;
  document.getElementById('menu-level').textContent=G.level;
}
function setMode(m){G.mode=m;}
function setDiff(d,btn){G.difficulty=d;document.querySelectorAll('.diff-btn').forEach(b=>b.classList.remove('selected'));btn.classList.add('selected');}
function setTheme(t,btn){G.theme=t;document.querySelectorAll('#theme-selector .btn').forEach(b=>{b.classList.remove('btn-gold');b.classList.add('btn-outline');});btn.classList.remove('btn-outline');btn.classList.add('btn-gold');}
function openModal(id){document.getElementById(id).classList.add('active');}
function closeModal(id){document.getElementById(id).classList.remove('active');}

function startGame(){
  G.board=Array(12).fill(4);G.stores=[0,0];G.currentPlayer=0;G.round=1;G.gameOver=false;
  showScreen('game');renderBoard();updateUI();setMessage('🎮 Bienvenue ! Choisissez une case pour commencer.');showRandomFact();
}
function restartGame(){startGame();}

function renderBoard(){
  const theme=THEMES[G.theme];
  document.getElementById('theme-badge').textContent=theme.name;
  document.getElementById('p1-name').textContent=G.playerName||'JOUEUR 1';
  document.getElementById('p2-name').textContent=G.mode==='solo'?'INTELLIGENCE IA':'JOUEUR 2';
  const r1=document.getElementById('row-1');r1.innerHTML='';
  for(let i=0;i<6;i++)r1.appendChild(createPit(i,0));
  const r2=document.getElementById('row-2');r2.innerHTML='';
  for(let i=11;i>=6;i--)r2.appendChild(createPit(i,1));
}

function createPit(index,player){
  const div=document.createElement('div');
  const count=G.board[index];
  const seed=SEEDS[G.difficulty][index%6];
  const pitName=THEMES[G.theme].places[index]||'Case '+(index+1);
  div.className='pit';div.id='pit-'+index;
  if(count===0)div.classList.add('empty');
  div.innerHTML=`<div class="seed-count">${count}</div><div class="seed-emoji">${count>0?seed.emoji:'·'}</div><div class="pit-label">${pitName}</div>`;
  if(!G.gameOver&&G.currentPlayer===player&&count>0){div.classList.add('valid-move');div.onclick=()=>playMove(index);}
  else div.classList.add('disabled');
  return div;
}

function playMove(pitIndex){
  if(G.gameOver)return;
  if(G.currentPlayer===0&&pitIndex>=6)return;
  if(G.currentPlayer===1&&pitIndex<6)return;
  let seeds=G.board[pitIndex];if(seeds===0)return;
  G.board[pitIndex]=0;let cur=pitIndex;
  while(seeds>0){cur=(cur+1)%12;G.board[cur]++;seeds--;}
  captureSeeds(cur);G.coins+=1;checkEnd();
  if(!G.gameOver){
    G.currentPlayer=1-G.currentPlayer;updateUI();renderBoard();
    setMessage(G.currentPlayer===0?'🔵 Votre tour !':'🔴 Tour de l\'adversaire...');
    if(G.mode==='solo'&&G.currentPlayer===1)setTimeout(aiMove,G.aiDelay);
  }
}

function captureSeeds(last){
  let pos=last;const opp=1-G.currentPlayer;const rng=opp===0?[0,5]:[6,11];
  while(pos>=rng[0]&&pos<=rng[1]){const c=G.board[pos];if(c===2||c===3){G.stores[G.currentPlayer]+=c;G.board[pos]=0;G.coins+=c*2;pos--;}else break;}
}

function checkEnd(){
  const p1=G.board.slice(0,6).reduce((a,b)=>a+b,0);
  const p2=G.board.slice(6,12).reduce((a,b)=>a+b,0);
  if(G.stores[0]>24||G.stores[1]>24||p1===0||p2===0){
    G.stores[0]+=p1;G.stores[1]+=p2;G.board=Array(12).fill(0);G.gameOver=true;showEndModal();
  }
}

async function showEndModal(){
  updateUI();renderBoard();
  const p1=G.stores[0],p2=G.stores[1];let title,emoji,text;
  const reward=Math.floor(Math.random()*20)+10;
  const rankBefore=lbCache.findIndex(p=>p.id===G.playerId)+1;

  if(p1>p2){title='🏆 Victoire !';emoji='🥇';text=`Vous remportez la partie avec ${p1} graines contre ${p2} !`;G.wins++;G.coins+=reward+20;if(G.wins%3===0)G.level++;}
  else if(p2>p1){title='💀 Défaite...';emoji='😢';text=`L'adversaire remporte avec ${p2} graines contre ${p1}. Courage !`;G.losses=(G.losses||0)+1;G.coins+=Math.floor(reward/2);}
  else{title='🤝 Égalité !';emoji='⚖️';text=`Match nul ! ${p1} graines chacun.`;G.coins+=reward;}

  saveData();
  await saveLb();
  let real=await loadLb();
  const demos=demoPLayers();const realIds=new Set(real.map(p=>p.id));
  lbCache=[...real,...demos.filter(d=>!realIds.has(d.id))].sort((a,b)=>b.score-a.score);
  const rankAfter=lbCache.findIndex(p=>p.id===G.playerId)+1;

  document.getElementById('end-emoji').textContent=emoji;
  document.getElementById('end-title').textContent=title;
  document.getElementById('end-text').textContent=text;
  document.getElementById('end-reward').textContent=`🪙 +${p1>p2?reward+20:Math.floor(reward/2)} pièces ! Score total: ${calcScore().toLocaleString()} pts`;

  const rd=document.getElementById('end-rank');
  if(G.playerName&&rankAfter>0){
    rd.style.display='block';
    if(rankBefore>0&&rankAfter<rankBefore)rd.textContent=`📈 Rang amélioré ! #${rankBefore} → #${rankAfter} mondial 🎉`;
    else rd.textContent=`🏅 Votre rang mondial : #${rankAfter} sur ${lbCache.length} joueurs`;
    document.getElementById('menu-rank').textContent='#'+rankAfter;
  } else {
    rd.style.display='none';
  }
  openModal('end-modal');
}

function aiMove(){
  if(G.gameOver||G.currentPlayer!==1)return;
  const valid=[6,7,8,9,10,11].filter(i=>G.board[i]>0);if(valid.length===0)return;
  let chosen;
  if(G.difficulty==='debutant'){chosen=valid[Math.floor(Math.random()*valid.length)];}
  else{let best=-1,bp=valid[0];for(const p of valid){const s=evalMove(p);if(s>best){best=s;bp=p;}}chosen=bp;}
  playMove(chosen);
}
function evalMove(pit){const s=G.board[pit];let score=s;const lp=(pit+s)%12;if(lp<6){const c=G.board[lp]+1;if(c===2||c===3)score+=10;}return score;}

function updateUI(){
  document.getElementById('p1-score').textContent=G.stores[0];
  document.getElementById('p2-score').textContent=G.stores[1];
  document.getElementById('p1-coins').textContent='🪙 '+G.coins;
  document.getElementById('store1-count').textContent=G.stores[0];
  document.getElementById('store2-count').textContent=G.stores[1];
  document.getElementById('turn-display').textContent='Tour: '+(G.currentPlayer===0?'J1':(G.mode==='solo'?'IA':'J2'));
  document.getElementById('round-display').textContent='Manche '+G.round;
  const rs=SEEDS[G.difficulty][Math.floor(Math.random()*6)];
  document.getElementById('seed-fact').textContent=rs.emoji+' '+rs.name+' : '+rs.fact;
  const rf=THEMES[G.theme].facts[Math.floor(Math.random()*THEMES[G.theme].facts.length)];
  document.getElementById('place-fact').textContent=rf;
}
function setMessage(m){document.getElementById('game-message').textContent=m;}
function showRandomFact(){
  const s=SEEDS[G.difficulty][Math.floor(Math.random()*6)];
  document.getElementById('fact-emoji').textContent=s.emoji;
  document.getElementById('fact-title').textContent='Découverte : '+s.name;
  document.getElementById('fact-text').textContent=s.fact;
  G.coins+=5;saveData();setTimeout(()=>openModal('fact-modal'),1200);
}

function showQuiz(){
  const qs=THEMES[G.theme].quiz;const q=qs[Math.floor(Math.random()*qs.length)];
  document.getElementById('quiz-question').textContent=q.q;
  document.getElementById('quiz-feedback').style.display='none';
  document.getElementById('quiz-close').style.display='none';
  const c=document.getElementById('quiz-options');c.innerHTML='';
  q.opts.forEach((o,i)=>{const btn=document.createElement('button');btn.className='quiz-option';btn.textContent=['A','B','C','D'][i]+'. '+o;btn.onclick=()=>answerQuiz(i,q.a,q.exp,btn);c.appendChild(btn);});
  openModal('quiz-modal');
}
function answerQuiz(chosen,correct,exp,btn){
  document.querySelectorAll('.quiz-option').forEach(b=>b.onclick=null);
  const fb=document.getElementById('quiz-feedback');fb.style.display='block';
  document.getElementById('quiz-close').style.display='inline-block';
  if(chosen===correct){btn.classList.add('correct');fb.style.background='rgba(76,175,80,0.2)';fb.style.color='#81c784';fb.textContent='✅ Bravo ! +🪙20 | '+exp;G.coins+=20;}
  else{btn.classList.add('wrong');document.querySelectorAll('.quiz-option')[correct].classList.add('correct');fb.style.background='rgba(244,67,54,0.2)';fb.style.color='#e57373';fb.textContent='❌ Incorrect. '+exp;G.coins+=5;}
  saveData();updateUI();
}

function renderShop(){
  document.getElementById('shop-coins').textContent=G.coins;
  const grid=document.getElementById('shop-grid');grid.innerHTML='';
  SHOP_ITEMS.forEach(item=>{
    const owned=G.ownedSeeds.includes(item.id);
    const div=document.createElement('div');div.className='shop-item '+(owned?'owned':'');
    div.innerHTML=`<div class="item-icon">${item.icon}</div><div class="item-name">${item.name}</div><div class="item-desc">${item.desc}</div><div class="item-price">${owned?'✅ Possédé':(item.special==='reward'?'🎁 Gratuit':'🪙 '+item.price)}</div>`;
    if(!owned)div.onclick=()=>buyItem(item);
    grid.appendChild(div);
  });
}
function buyItem(item){
  if(item.special==='reward'){G.coins+=50;G.ownedSeeds.push(item.id);saveData();renderShop();return;}
  if(G.coins<item.price){alert('Pas assez de pièces !');return;}
  G.coins-=item.price;G.ownedSeeds.push(item.id);saveData();renderShop();
  document.getElementById('shop-coins').textContent=G.coins;
}

