<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Awalé Baoulé – Jeu de Connaissance</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Lora:ital,wght@0,400;0,600;1,400&family=Raleway:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --wood: #c8722a; --wood-dark: #8b4513; --wood-light: #e8a05a;
    --cream: #fdf3e3; --gold: #d4a017; --gold-light: #f0c040;
    --bg-deep: #1a0e05; --shadow: 0 8px 32px rgba(0,0,0,0.5);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg-deep);
    background-image: radial-gradient(ellipse at 20% 20%, #3d1a00 0%, transparent 60%), radial-gradient(ellipse at 80% 80%, #1a0e00 0%, transparent 60%),
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23c8722a' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    font-family: 'Lora', serif; color: var(--cream); min-height: 100vh; overflow-x: hidden;
  }
  .screen { display: none; min-height: 100vh; padding: 20px; }
  .screen.active { display: flex; flex-direction: column; align-items: center; }
  #menu { justify-content: center; text-align: center; gap: 14px; }
  .logo-title { font-family: 'Cinzel Decorative', serif; font-size: clamp(1.8rem,5vw,3rem); color: var(--gold-light); text-shadow: 0 0 30px rgba(212,160,23,0.5),2px 4px 8px rgba(0,0,0,0.8); line-height: 1.1; letter-spacing: 2px; }
  .logo-sub { font-family: 'Lora', serif; font-style: italic; font-size: 1rem; color: var(--wood-light); opacity: 0.85; margin-top: 4px; }
  .menu-card { background: linear-gradient(135deg,rgba(200,114,42,0.15),rgba(139,69,19,0.25)); border: 1px solid rgba(212,160,23,0.3); border-radius: 18px; padding: 22px 28px; width: min(480px,96vw); box-shadow: var(--shadow); backdrop-filter: blur(4px); }
  .menu-card h2 { font-family: 'Cinzel Decorative', serif; font-size: 0.9rem; color: var(--gold); margin-bottom: 14px; letter-spacing: 1px; }
  .btn { display: block; width: 100%; padding: 13px 22px; border: none; border-radius: 10px; font-family: 'Cinzel Decorative', serif; font-size: 0.82rem; cursor: pointer; transition: all 0.25s; letter-spacing: 1px; margin-bottom: 9px; }
  .btn-gold { background: linear-gradient(135deg,var(--gold),#b8860b); color: var(--bg-deep); box-shadow: 0 4px 15px rgba(212,160,23,0.4); }
  .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,160,23,0.6); }
  .btn-wood { background: linear-gradient(135deg,var(--wood),var(--wood-dark)); color: var(--cream); box-shadow: 0 4px 15px rgba(139,69,19,0.4); }
  .btn-wood:hover { transform: translateY(-2px); }
  .btn-outline { background: transparent; border: 2px solid var(--gold); color: var(--gold); }
  .btn-outline:hover { background: rgba(212,160,23,0.1); }
  .btn-sm { display: inline-block; width: auto; padding: 8px 16px; font-size: 0.72rem; margin: 3px; }
  .stats-bar { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin: 4px 0; }
  .stat-chip { background: rgba(212,160,23,0.15); border: 1px solid rgba(212,160,23,0.3); border-radius: 20px; padding: 6px 13px; font-size: 0.78rem; font-family: 'Raleway',sans-serif; color: var(--gold-light); }
  .stat-chip span { font-weight: 700; }
  .difficulty-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin: 8px 0; }
  .diff-btn { padding: 11px; border-radius: 10px; border: 2px solid transparent; cursor: pointer; font-family: 'Raleway',sans-serif; font-size: 0.78rem; font-weight: 600; transition: all 0.2s; text-align: center; }
  .diff-btn:hover, .diff-btn.selected { transform: scale(1.04); box-shadow: 0 0 15px rgba(255,255,255,0.2); }
  .diff-debutant { background: rgba(76,175,80,0.2); border-color: #4caf50; color: #81c784; }
  .diff-debutant.selected { background: rgba(76,175,80,0.4); }
  .diff-initie { background: rgba(33,150,243,0.2); border-color: #2196f3; color: #64b5f6; }
  .diff-initie.selected { background: rgba(33,150,243,0.4); }
  .diff-avance { background: rgba(255,152,0,0.2); border-color: #ff9800; color: #ffb74d; }
  .diff-avance.selected { background: rgba(255,152,0,0.4); }
  .diff-expert { background: rgba(244,67,54,0.2); border-color: #f44336; color: #e57373; }
  .diff-expert.selected { background: rgba(244,67,54,0.4); }

/* GAME */
#game { justify-content: flex-start; align-items: center; padding: 10px; gap: 9px; }
.game-header { display: flex; justify-content: space-between; align-items: center; width: min(700px,98vw); padding: 8px 14px; background: rgba(0,0,0,0.3); border-radius: 12px; border: 1px solid rgba(212,160,23,0.2); }
.player-info { text-align: center; min-width: 110px; }
.player-name { font-family: ‘Cinzel Decorative’,serif; font-size: 0.7rem; color: var(–gold); letter-spacing: 1px; }
.player-score { font-family: ‘Cinzel Decorative’,serif; font-size: 1.5rem; color: var(–cream); line-height: 1; }
.player-coins { font-size: 0.72rem; color: var(–gold-light); font-family: ‘Raleway’,sans-serif; }
.turn-indicator { text-align: center; font-size: 0.72rem; font-family: ‘Raleway’,sans-serif; color: var(–wood-light); }
.turn-indicator .current { font-family: ‘Cinzel Decorative’,serif; font-size: 0.82rem; color: var(–gold-light); }
.board-container { position: relative; width: min(700px,98vw); }
.board { background: linear-gradient(145deg,var(–wood-light) 0%,var(–wood) 40%,var(–wood-dark) 100%); border-radius: 60px; padding: 13px 18px; box-shadow: inset 0 4px 12px rgba(255,255,255,0.2),inset 0 -6px 16px rgba(0,0,0,0.4),0 12px 40px rgba(0,0,0,0.6); border: 3px solid var(–wood-dark); outline: 1px solid rgba(212,160,23,0.3); outline-offset: 3px; }
.board-row { display: flex; justify-content: space-around; gap: 7px; padding: 3px 0; }
.pit { width: clamp(62px,11vw,90px); height: clamp(62px,11vw,90px); border-radius: 50%; background: radial-gradient(circle at 35% 35%,rgba(255,255,255,0.15) 0%,transparent 60%),radial-gradient(circle at center,#7a3f10 0%,#4a1e05 100%); box-shadow: inset 0 6px 14px rgba(0,0,0,0.6),0 2px 4px rgba(0,0,0,0.3); cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; transition: all 0.2s; border: 2px solid rgba(0,0,0,0.3); }
.pit:hover:not(.empty):not(.disabled) { transform: scale(1.08); box-shadow: inset 0 6px 14px rgba(0,0,0,0.6),0 0 20px rgba(212,160,23,0.5),0 4px 12px rgba(0,0,0,0.4); }
.pit.valid-move { animation: pulse-gold 1.2s ease-in-out infinite; border-color: var(–gold); }
@keyframes pulse-gold { 0%,100%{box-shadow:inset 0 6px 14px rgba(0,0,0,0.6),0 0 10px rgba(212,160,23,0.3)} 50%{box-shadow:inset 0 6px 14px rgba(0,0,0,0.6),0 0 25px rgba(212,160,23,0.8)} }
.pit.disabled { cursor: default; opacity: 0.6; }
.pit.empty { cursor: default; }
.seed-count { font-family: ‘Cinzel Decorative’,serif; font-size: 1.1rem; color: var(–cream); text-shadow: 0 1px 3px rgba(0,0,0,0.8); z-index: 2; line-height: 1; }
.seed-emoji { font-size: clamp(13px,2vw,18px); margin-top: 1px; letter-spacing: -2px; line-height: 1; }
.pit-label { position: absolute; bottom: -19px; font-family: ‘Raleway’,sans-serif; font-size: 0.55rem; color: rgba(212,160,23,0.6); text-align: center; white-space: nowrap; width: 100%; }
.store-zone { display: flex; align-items: center; justify-content: center; }
.store { width: clamp(48px,8vw,68px); height: clamp(120px,18vw,165px); border-radius: 40px; background: radial-gradient(ellipse at 40% 30%,rgba(255,255,255,0.1),transparent 70%),linear-gradient(180deg,#5a2d0a 0%,#2c1205 100%); box-shadow: inset 0 8px 20px rgba(0,0,0,0.7),0 4px 12px rgba(0,0,0,0.5); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; border: 2px solid rgba(0,0,0,0.4); }
.store-count { font-family: ‘Cinzel Decorative’,serif; font-size: 1.3rem; color: var(–gold-light); text-shadow: 0 0 10px rgba(212,160,23,0.5); }
.store-label { font-size: 0.55rem; font-family: ‘Raleway’,sans-serif; color: var(–wood-light); opacity: 0.7; writing-mode: vertical-rl; letter-spacing: 2px; }
.board-middle { display: flex; align-items: center; gap: 5px; }
.pits-grid { display: flex; flex-direction: column; gap: 9px; flex: 1; padding: 7px 0; }
.info-panel { width: min(700px,98vw); background: rgba(0,0,0,0.4); border: 1px solid rgba(212,160,23,0.25); border-radius: 14px; padding: 12px 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.theme-badge { grid-column: 1/-1; text-align: center; padding: 7px; border-radius: 8px; font-family: ‘Cinzel Decorative’,serif; font-size: 0.75rem; letter-spacing: 1px; background: linear-gradient(90deg,transparent,rgba(212,160,23,0.2),transparent); color: var(–gold-light); border-bottom: 1px solid rgba(212,160,23,0.2); margin-bottom: 3px; }
.knowledge-box { background: rgba(200,114,42,0.1); border: 1px solid rgba(200,114,42,0.25); border-radius: 10px; padding: 9px 11px; }
.knowledge-box h4 { font-family: ‘Cinzel Decorative’,serif; font-size: 0.65rem; color: var(–gold); margin-bottom: 5px; letter-spacing: 1px; }
.knowledge-box p { font-size: 0.75rem; color: var(–cream); opacity: 0.85; line-height: 1.5; font-style: italic; }
.message-box { grid-column: 1/-1; text-align: center; padding: 9px; border-radius: 8px; font-family: ‘Raleway’,sans-serif; font-size: 0.82rem; background: rgba(212,160,23,0.1); border: 1px solid rgba(212,160,23,0.2); color: var(–gold-light); min-height: 36px; }

/* MODALS */
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.88); z-index: 100; align-items: center; justify-content: center; padding: 16px; overflow-y: auto; }
.modal-overlay.active { display: flex; }
.modal { background: linear-gradient(145deg,#2a1205,#1a0e05); border: 2px solid var(–gold); border-radius: 20px; padding: 28px; max-width: 520px; width: 100%; box-shadow: 0 0 60px rgba(212,160,23,0.3),var(–shadow); text-align: center; }
.modal h2 { font-family: ‘Cinzel Decorative’,serif; font-size: 1.3rem; color: var(–gold-light); margin-bottom: 10px; }
.modal p { color: var(–cream); opacity: 0.85; margin-bottom: 14px; line-height: 1.6; font-size: 0.88rem; }
.modal .emoji-big { font-size: 2.8rem; margin-bottom: 8px; display: block; }
.quiz-option { display: block; width: 100%; padding: 11px 15px; margin-bottom: 7px; border-radius: 10px; border: 2px solid rgba(200,114,42,0.4); background: rgba(200,114,42,0.1); color: var(–cream); font-family: ‘Raleway’,sans-serif; font-size: 0.83rem; cursor: pointer; text-align: left; transition: all 0.2s; }
.quiz-option:hover { border-color: var(–gold); }
.quiz-option.correct { border-color: #4caf50; background: rgba(76,175,80,0.2); color: #81c784; }
.quiz-option.wrong { border-color: #f44336; background: rgba(244,67,54,0.2); color: #e57373; }

/* SHOP */
#shop { justify-content: flex-start; padding: 20px; gap: 13px; align-items: center; }
.shop-title { font-family: ‘Cinzel Decorative’,serif; font-size: 1.5rem; color: var(–gold-light); text-align: center; }
.shop-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(155px,1fr)); gap: 12px; width: min(700px,98vw); }
.shop-item { background: linear-gradient(145deg,rgba(200,114,42,0.15),rgba(139,69,19,0.2)); border: 1px solid rgba(212,160,23,0.3); border-radius: 14px; padding: 16px 13px; text-align: center; cursor: pointer; transition: all 0.25s; }
.shop-item:hover { transform: translateY(-3px); border-color: var(–gold); box-shadow: 0 6px 20px rgba(212,160,23,0.2); }
.shop-item .item-icon { font-size: 2rem; margin-bottom: 7px; }
.shop-item .item-name { font-family: ‘Cinzel Decorative’,serif; font-size: 0.68rem; color: var(–gold); margin-bottom: 3px; }
.shop-item .item-desc { font-size: 0.7rem; color: var(–cream); opacity: 0.7; margin-bottom: 7px; line-height: 1.4; }
.shop-item .item-price { font-family: ‘Raleway’,sans-serif; font-weight: 700; color: var(–gold-light); font-size: 0.82rem; }
.shop-item.owned { border-color: #4caf50; background: rgba(76,175,80,0.1); }
.shop-item.owned .item-price { color: #81c784; }

/* RULES */
#rules { padding: 22px 16px; gap: 13px; align-items: center; }
.rules-card { background: rgba(0,0,0,0.4); border: 1px solid rgba(212,160,23,0.25); border-radius: 16px; padding: 20px 22px; width: min(680px,98vw); }
.rules-card h3 { font-family: ‘Cinzel Decorative’,serif; font-size: 0.85rem; color: var(–gold); margin-bottom: 9px; letter-spacing: 1px; }
.rules-card p, .rules-card li { font-size: 0.83rem; line-height: 1.7; color: var(–cream); opacity: 0.9; margin-bottom: 5px; }
.rules-card ul { padding-left: 18px; }

/* ===== LEADERBOARD ===== */
#leaderboard { justify-content: flex-start; padding: 20px 16px; gap: 16px; align-items: center; }
.lb-title { font-family: ‘Cinzel Decorative’,serif; font-size: clamp(1.4rem,4vw,2rem); color: var(–gold-light); text-shadow: 0 0 20px rgba(212,160,23,0.4); text-align: center; }
.lb-subtitle { font-family: ‘Lora’,serif; font-style: italic; font-size: 0.88rem; color: var(–wood-light); opacity: 0.8; text-align: center; margin-top: 2px; }

.lb-my-card {
width: min(680px,98vw); background: linear-gradient(135deg,rgba(212,160,23,0.18),rgba(139,69,19,0.3));
border: 2px solid var(–gold); border-radius: 16px; padding: 18px 22px;
display: flex; align-items: center; gap: 16px; box-shadow: 0 0 30px rgba(212,160,23,0.2);
}
.lb-my-rank { font-family: ‘Cinzel Decorative’,serif; font-size: 2.4rem; color: var(–gold-light); min-width: 64px; text-align: center; text-shadow: 0 0 15px rgba(212,160,23,0.6); }
.lb-my-info { flex: 1; }
.lb-my-name { font-family: ‘Cinzel Decorative’,serif; font-size: 1rem; color: var(–cream); margin-bottom: 4px; }
.lb-my-stats { font-family: ‘Raleway’,sans-serif; font-size: 0.76rem; color: var(–wood-light); line-height: 1.6; }
.lb-level-badge { display: inline-block; padding: 5px 14px; border-radius: 20px; font-family: ‘Cinzel Decorative’,serif; font-size: 0.68rem; letter-spacing: 1px; background: linear-gradient(135deg,var(–gold),#b8860b); color: var(–bg-deep); box-shadow: 0 2px 10px rgba(212,160,23,0.4); white-space: nowrap; }

.lb-filters { display: flex; gap: 7px; flex-wrap: wrap; justify-content: center; width: min(680px,98vw); }
.lb-filter { padding: 7px 15px; border-radius: 20px; border: 1px solid rgba(212,160,23,0.4); background: transparent; color: var(–gold-light); font-family: ‘Raleway’,sans-serif; font-size: 0.74rem; cursor: pointer; transition: all 0.2s; }
.lb-filter:hover, .lb-filter.active { background: rgba(212,160,23,0.2); border-color: var(–gold); }

.lb-wrap { width: min(680px,98vw); }

.lb-table { width: 100%; border-collapse: separate; border-spacing: 0 5px; }
.lb-row { background: rgba(0,0,0,0.35); border-radius: 12px; transition: background 0.2s; }
.lb-row:hover { background: rgba(200,114,42,0.15); }
.lb-row.is-me { background: linear-gradient(90deg,rgba(212,160,23,0.15),rgba(139,69,19,0.2)) !important; outline: 1px solid rgba(212,160,23,0.4); outline-offset: -1px; }
.lb-row.r1 { background: linear-gradient(90deg,rgba(255,215,0,0.14),rgba(184,134,11,0.1)); }
.lb-row.r2 { background: linear-gradient(90deg,rgba(192,192,192,0.1),rgba(100,100,100,0.08)); }
.lb-row.r3 { background: linear-gradient(90deg,rgba(205,127,50,0.12),rgba(139,69,19,0.08)); }
.lb-row td { padding: 10px 11px; font-family: ‘Raleway’,sans-serif; font-size: 0.8rem; color: var(–cream); vertical-align: middle; }
.lb-row td:first-child { border-radius: 12px 0 0 12px; width: 50px; text-align: center; }
.lb-row td:last-child { border-radius: 0 12px 12px 0; }
.rank-num { font-family: ‘Cinzel Decorative’,serif; font-size: 1.05rem; color: var(–wood-light); }
.rank-medal { font-size: 1.4rem; }
.pname { font-weight: 600; color: var(–cream); display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.pname-sub { font-size: 0.67rem; color: var(–wood-light); margin-top: 1px; }
.pscore { font-family: ‘Cinzel Decorative’,serif; font-size: 0.95rem; color: var(–gold-light); }
.pscore-sub { font-size: 0.63rem; color: var(–wood-light); }
.diff-pill { display: inline-block; padding: 3px 9px; border-radius: 10px; font-size: 0.65rem; font-family: ‘Cinzel Decorative’,serif; }
.dp-d { background: rgba(76,175,80,0.2); color: #81c784; border: 1px solid rgba(76,175,80,0.35); }
.dp-i { background: rgba(33,150,243,0.2); color: #64b5f6; border: 1px solid rgba(33,150,243,0.35); }
.dp-a { background: rgba(255,152,0,0.2); color: #ffb74d; border: 1px solid rgba(255,152,0,0.35); }
.dp-e { background: rgba(244,67,54,0.2); color: #e57373; border: 1px solid rgba(244,67,54,0.35); }

.lb-loading { text-align: center; padding: 36px; font-family: ‘Raleway’,sans-serif; color: var(–wood-light); font-size: 0.9rem; }
.lb-empty { text-align: center; padding: 36px; color: var(–wood-light); font-style: italic; font-size: 0.88rem; }

.register-zone { width: min(680px,98vw); background: rgba(212,160,23,0.1); border: 1px solid rgba(212,160,23,0.3); border-radius: 14px; padding: 20px 22px; text-align: center; }
.register-zone p { margin-bottom: 12px; font-family: ‘Raleway’,sans-serif; font-size: 0.85rem; color: var(–cream); opacity: 0.9; }
.reg-input { width: 100%; padding: 12px 16px; border-radius: 10px; border: 2px solid rgba(212,160,23,0.4); background: rgba(0,0,0,0.4); color: var(–cream); font-family: ‘Raleway’,sans-serif; font-size: 0.9rem; text-align: center; margin-bottom: 10px; outline: none; transition: border-color 0.2s; }
.reg-input:focus { border-color: var(–gold); }
.reg-input::placeholder { color: rgba(255,255,255,0.3); }

@keyframes rowIn { from{opacity:0;transform:translateX(-16px)} to{opacity:1;transform:translateX(0)} }
.lb-row { animation: rowIn 0.3s ease both; }

@media (max-width: 480px) {
.pit { width: 50px; height: 50px; }
.store { height: 106px; width: 42px; }
.info-panel { grid-template-columns: 1fr; }
.board { padding: 7px 10px; border-radius: 36px; }
.lb-my-card { gap: 10px; padding: 14px 14px; }
.lb-row td { padding: 8px 7px; font-size: 0.74rem; }
}
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(–bg-deep); }
::-webkit-scrollbar-thumb { background: var(–wood); border-radius: 3px; }
</style>

</head>
<body>

<!-- ===== MENU ===== -->

<div id="menu" class="screen active">
  <div style="margin-bottom:6px">
    <div class="logo-title">🌰 AWALÉ BAOULÉ</div>
    <div class="logo-sub">Le Jeu des Graines &amp; de la Sagesse</div>
  </div>
  <div class="stats-bar">
    <div class="stat-chip">🪙 Pièces: <span id="menu-coins">0</span></div>
    <div class="stat-chip">🏆 Victoires: <span id="menu-wins">0</span></div>
    <div class="stat-chip">⭐ Niveau: <span id="menu-level">1</span></div>
    <div class="stat-chip" style="cursor:pointer" onclick="showScreen('leaderboard')">🥇 Rang: <span id="menu-rank">–</span></div>
  </div>
  <div class="menu-card">
    <h2>⚔ Mode de Jeu</h2>
    <button class="btn btn-gold" onclick="setMode('solo')">🤖 Solo vs IA</button>
    <button class="btn btn-wood" onclick="setMode('2players')">👥 2 Joueurs</button>
  </div>
  <div class="menu-card">
    <h2>🎯 Difficulté</h2>
    <div class="difficulty-grid">
      <button class="diff-btn diff-debutant selected" onclick="setDiff('debutant',this)">🌱 Débutant<br><small style="opacity:.7">Graines simples</small></button>
      <button class="diff-btn diff-initie" onclick="setDiff('initie',this)">🌿 Initié<br><small style="opacity:.7">Graines rares</small></button>
      <button class="diff-btn diff-avance" onclick="setDiff('avance',this)">💎 Avancé<br><small style="opacity:.7">Pierres précieuses</small></button>
      <button class="diff-btn diff-expert" onclick="setDiff('expert',this)">🌌 Expert<br><small style="opacity:.7">Gemmes &amp; Cosmos</small></button>
    </div>
  </div>
