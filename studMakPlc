  document.getElementById('bookingSummary').innerHTML = `
    <div class="summary-row"><span>Studio × ${dur}h</span><span>${studio}€</span></div>
    <div class="summary-row"><span>Frais de service (8%)</span><span>${fee}€</span></div>
