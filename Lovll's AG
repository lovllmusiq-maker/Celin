</div>

<!-- ══════════ PAGE 2 : FLUX & MESSAGES ══════════ -->

<div class="pg" id="pg-f">
  <div class="fl-l">
    <canvas id="cv-f"></canvas>
    <div class="fl-scene">
      <div class="orch" id="orch-f" style="transform:translate(-50%,-58%)">
        <div class="or-wrap" style="width:76px;height:76px">
          <div class="or-r1" style="width:76px;height:76px"></div>
          <div class="or-r2" style="width:54px;height:54px"></div>
          <div class="or-core" style="width:50px;height:50px;font-size:.48rem">ORCH<br>ESTR.</div>
        </div>
        <div class="or-lbl" style="font-size:.5rem">Coordinateur</div>
      </div>
      <div class="ag-s" id="f-agM" data-id="agM" style="top:7%;left:50%"><div class="hw-s"><svg viewBox="0 0 56 56"><polygon points="28,3 53,15 53,41 28,53 3,41 3,15" fill="#000" stroke="#00d4ff" stroke-width="1.2"/></svg><div class="hi-s"><div class="al-s" style="color:#00d4ff">M</div><div class="as-s" style="color:#00d4ff">Agent</div></div></div><div class="an-s">Monitoring</div></div>
      <div class="ag-s" id="f-agI" data-id="agI" style="top:22%;right:5%;transform:translate(0,-50%)"><div class="hw-s"><svg viewBox="0 0 56 56"><polygon points="28,3 53,15 53,41 28,53 3,41 3,15" fill="#000" stroke="#7c3aed" stroke-width="1.2"/></svg><div class="hi-s"><div class="al-s" style="color:#7c3aed">I</div><div class="as-s" style="color:#7c3aed">Agent</div></div></div><div class="an-s">Intelligence</div></div>
      <div class="ag-s" id="f-agA" data-id="agA" style="bottom:22%;right:5%;transform:translate(0,50%)"><div class="hw-s"><svg viewBox="0 0 56 56"><polygon points="28,3 53,15 53,41 28,53 3,41 3,15" fill="#000" stroke="#00ff88" stroke-width="1.2"/></svg><div class="hi-s"><div class="al-s" style="color:#00ff88">A</div><div class="as-s" style="color:#00ff88">Agent</div></div></div><div class="an-s">Automatisation</div></div>
      <div class="ag-s" id="f-agV" data-id="agV" style="bottom:7%;left:50%;transform:translate(-50%,0)"><div class="hw-s"><svg viewBox="0 0 56 56"><polygon points="28,3 53,15 53,41 28,53 3,41 3,15" fill="#000" stroke="#ff4d6d" stroke-width="1.2"/></svg><div class="hi-s"><div class="al-s" style="color:#ff4d6d">V</div><div class="as-s" style="color:#ff4d6d">Agent</div></div></div><div class="an-s">Validation</div></div>
      <div class="ag-s" id="f-agP" data-id="agP" style="bottom:22%;left:5%;transform:translate(0,50%)"><div class="hw-s"><svg viewBox="0 0 56 56"><polygon points="28,3 53,15 53,41 28,53 3,41 3,15" fill="#000" stroke="#ff8c42" stroke-width="1.2"/></svg><div class="hi-s"><div class="al-s" style="color:#ff8c42">P</div><div class="as-s" style="color:#ff8c42">Agent</div></div></div><div class="an-s">Production</div></div>
      <div class="ag-s" id="f-agR" data-id="agR" style="top:22%;left:5%;transform:translate(0,-50%)"><div class="hw-s"><svg viewBox="0 0 56 56"><polygon points="28,3 53,15 53,41 28,53 3,41 3,15" fill="#000" stroke="#3b82f6" stroke-width="1.2"/></svg><div class="hi-s"><div class="al-s" style="color:#3b82f6">R</div><div class="as-s" style="color:#3b82f6">Agent</div></div></div><div class="an-s">Reporting</div></div>
    </div>
  </div>
  <div class="fl-r">
    <div class="rph">Métriques temps réel <em id="lc">0 msg</em></div>
    <div class="sg">
      <div class="st"><div class="st-l">Messages</div><div class="st-v" id="s-msg" style="color:var(--cyan)">0</div><div class="st-s">session</div></div>
      <div class="st"><div class="st-l">Tâches actives</div><div class="st-v" id="s-tasks" style="color:var(--green)">0</div><div class="st-s">en cours</div></div>
      <div class="st"><div class="st-l">Latence moy.</div><div class="st-v" id="s-lat" style="color:var(--gold)">—</div><div class="st-s">ms</div></div>
      <div class="st"><div class="st-l">Uptime</div><div class="st-v" id="s-up" style="color:var(--violet);font-size:.75rem">00:00:00</div><div class="st-s">actif</div></div>
    </div>
    <div class="rh">Activité par agent</div>
    <div class="ar"><div class="ar-d" style="background:#00d4ff"></div><div class="ar-i" style="color:#00d4ff">AgM</div><div class="ar-r">Monitoring</div><div class="ar-c" id="cnt-agM">0</div></div>
    <div class="ar"><div class="ar-d" style="background:#7c3aed;animation-delay:.3s"></div><div class="ar-i" style="color:#7c3aed">AgI</div><div class="ar-r">Intelligence</div><div class="ar-c" id="cnt-agI">0</div></div>
