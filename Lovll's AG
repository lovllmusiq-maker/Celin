    <div class="hw" id="hw-agA"><svg viewBox="0 0 110 110"><polygon points="55,6 104,30 104,80 55,104 6,80 6,30" fill="#000" stroke="#00ff88" stroke-width="1.8"/><polygon points="55,16 94,38 94,72 55,94 16,72 16,38" fill="none" stroke="rgba(0,255,136,.08)" stroke-width="1"/></svg><div class="hi"><div class="al" style="color:#00ff88">A</div><div class="as2" style="color:#00ff88;font-size:.5rem">Agent</div></div></div>
