<div class="tt" id="tt"><div class="tt-n" id="tt-n"></div><div class="tt-d" id="tt-d"></div></div>

<script>
const AGENTS={
  agM:{label:'AgentM',color:'#00d4ff',role:'Monitoring',   desc:'Surveille métriques, performances et anomalies en temps réel.'},
  agI:{label:'AgentI',color:'#7c3aed',role:'Intelligence',  desc:'Analyse via LLM, génère insights et décisions contextuelles.'},
  agA:{label:'AgentA',color:'#00ff88',role:'Automatisation',desc:'Exécute actions automatisées, API et workflows Make.com.'},
  agV:{label:'AgentV',color:'#ff4d6d',role:'Validation',    desc:'Vérifie conformité et qualité de chaque output.'},
  agP:{label:'AgentP',color:'#ff8c42',role:'Production',    desc:'Déploiement Vercel, mises à jour prod et synchronisation.'},
  agR:{label:'AgentR',color:'#3b82f6',role:'Reporting',     desc:'Agrège données de tous les agents, génère les rapports.'},
};
const IDS=Object.keys(AGENTS);
const MSGS=[
  ['agM','ORCH','Anomalie détectée : latence +120ms'],
  ['ORCH','agI','Analyse requise sur flux entrant'],
  ['agI','ORCH','Classification terminée : priorité haute'],
  ['ORCH','agA','Déclencher workflow Make.com #47'],
  ['agA','agV','Output prêt pour validation'],
  ['agV','ORCH','Validation OK · conformité 98.4%'],
  ['ORCH','agP','Déployer en production Vercel'],
  ['agP','agR','Déploiement réussi · build #312'],
  ['agR','ORCH','Rapport synthèse généré'],
  ['agM','agR','KPIs mis à jour · all OK'],
  ['agI','agA','Nouvelle tâche : enrichissement data'],
  ['ORCH','agV','Audit sécurité demandé'],
];

const cvA=document.getElementById('cv-a'),ctxA=cvA.getContext('2d');
const cvF=document.getElementById('cv-f'),ctxF=cvF.getContext('2d');
let bA=[],bF=[],posA={},posF={};
let curTab='a',totalMsgs=0,agCnts={agM:0,agI:0,agA:0,agV:0,agP:0,agR:0};
const t0=Date.now();

function sz(){
  const pa=document.getElementById('pg-a');
  cvA.width=pa.offsetWidth;cvA.height=pa.offsetHeight;
  const fl=document.querySelector('.fl-l');
  if(fl){cvF.width=fl.offsetWidth;cvF.height=fl.offsetHeight;}
}
sz();
window.addEventListener('resize',()=>{sz();placeA();setTimeout(updPos,80);});

function placeA(){
  const pa=document.getElementById('pg-a');
  const cx=pa.offsetWidth/2,cy=pa.offsetHeight/2;
  const R=Math.min(pa.offsetWidth,pa.offsetHeight)*0.34;
  const hx=Math.min(pa.offsetWidth,pa.offsetHeight)*0.14;
  const oa=document.getElementById('orch-a');
  oa.style.left=cx+'px';oa.style.top=cy+'px';
  const cs=hx*.9,rs=cs*1.7;
  document.getElementById('orw-a').style.cssText=`width:${rs}px;height:${rs}px`;
  document.getElementById('orr1-a').style.cssText=`width:${rs}px;height:${rs}px`;
  document.getElementById('orr2-a').style.cssText=`width:${rs*.72}px;height:${rs*.72}px`;
  const c=document.getElementById('orc-a');
  c.style.width=cs+'px';c.style.height=cs+'px';c.style.fontSize=(cs*.12)+'px';
  posA.orch={x:cx,y:cy};
  IDS.forEach((id,i)=>{
    const a=-Math.PI/2+(i/IDS.length)*Math.PI*2;
    const x=cx+R*Math.cos(a),y=cy+R*Math.sin(a);
    const el=document.getElementById('a-'+id);
    el.style.left=x+'px';el.style.top=y+'px';
    document.getElementById('hw-'+id).style.cssText=`width:${hx}px;height:${hx}px`;
    el.querySelector('.al').style.fontSize=(hx*.36)+'px';
    posA[id]={x,y};
  });
}
setTimeout(()=>{placeA();setTimeout(updPos,150);},80);

function updPos(){
  const pa=document.getElementById('pg-a'),pr=pa.getBoundingClientRect();
  IDS.forEach(id=>{const el=document.getElementById('a-'+id);if(!el)return;const r=el.getBoundingClientRect();posA[id]={x:r.left+r.width/2-pr.left,y:r.top+r.height/2-pr.top};});
  const oa=document.getElementById('orch-a');if(oa){const r=oa.getBoundingClientRect();posA.orch={x:r.left+r.width/2-pr.left,y:r.top+r.height/2-pr.top};}
  const fl=document.querySelector('.fl-l');if(!fl)return;
  const fr=fl.getBoundingClientRect();
  IDS.forEach(id=>{const el=document.getElementById('f-'+id);if(!el)return;const r=el.getBoundingClientRect();posF[id]={x:r.left+r.width/2-fr.left,y:r.top+r.height/2-fr.top};});
  const of2=document.getElementById('orch-f');if(of2){const r=of2.getBoundingClientRect();posF.orch={x:r.left+r.width/2-fr.left,y:r.top+r.height/2-fr.top};}
}

function mkBeam(arr,pos,fr,to,col,sz=3){
  const fk=fr==='ORCH'?'orch':fr,tk=to==='ORCH'?'orch':to;
  const f=pos[fk],t=pos[tk];if(!f||!t)return;
  arr.push({fx:f.x,fy:f.y,tx:t.x,ty:t.y,t:0,speed:.009+Math.random()*.007,color:col,size:sz,tail:[]});
}

function drawScene(ctx,cv,beams,pos,pulse){
  ctx.clearRect(0,0,cv.width,cv.height);
  const o=pos.orch;
  if(o){
    IDS.forEach(id=>{
      const n=pos[id];if(!n)return;
      const g=ctx.createLinearGradient(o.x,o.y,n.x,n.y);
      g.addColorStop(0,'rgba(201,168,76,.09)');g.addColorStop(1,AGENTS[id].color+'15');
      ctx.beginPath();ctx.moveTo(o.x,o.y);ctx.lineTo(n.x,n.y);
      ctx.strokeStyle=g;ctx.lineWidth=1;ctx.stroke();
    });
    for(let i=0;i<IDS.length;i++)for(let j=i+1;j<IDS.length;j++){
      const a=pos[IDS[i]],b=pos[IDS[j]];if(!a||!b)continue;
      ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
      ctx.strokeStyle='rgba(255,255,255,.015)';ctx.lineWidth=1;
      ctx.setLineDash([3,10]);ctx.stroke();ctx.setLineDash([]);
    }
    if(pulse){
      const t=Date.now()/1000;
      [1,.7,.45].forEach((s,i)=>{
        const r=Math.min(cv.width,cv.height)*.09*s;
        const al=(.08-i*.022)+Math.sin(t*1.6+i)*.022;
        ctx.beginPath();ctx.arc(o.x,o.y,r,0,Math.PI*2);
        ctx.strokeStyle=`rgba(201,168,76,${Math.max(0,al)})`;ctx.lineWidth=1;ctx.stroke();
      });
    }
  }
  for(let i=beams.length-1;i>=0;i--){
    const b=beams[i];b.t+=b.speed;
    if(b.t>1){beams.splice(i,1);continue;}
    const e=b.t<.5?2*b.t*b.t:1-Math.pow(-2*b.t+2,2)/2;
    const x=b.fx+(b.tx-b.fx)*e,y=b.fy+(b.ty-b.fy)*e;
    b.tail.push({x,y});if(b.tail.length>22)b.tail.shift();
    b.tail.forEach((p,j)=>{
      const a=j/b.tail.length;
      ctx.beginPath();ctx.arc(p.x,p.y,b.size*a*.85,0,Math.PI*2);
      ctx.fillStyle=b.color+(Math.round(a*95).toString(16).padStart(2,'0'));ctx.fill();
    });
    ctx.beginPath();ctx.arc(x,y,b.size,0,Math.PI*2);
    ctx.fillStyle=b.color;ctx.shadowBlur=16;ctx.shadowColor=b.color;ctx.fill();ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(x,y,b.size*2.5,0,Math.PI*2);
    ctx.strokeStyle=b.color+'32';ctx.lineWidth=.7;ctx.stroke();
  }
}

function loop(){
  drawScene(ctxA,cvA,bA,posA,true);
  if(curTab==='f'){
    drawScene(ctxF,cvF,bF,posF,false);
    document.getElementById('s-lat').textContent=Math.round(70+Math.random()*60);
    document.getElementById('s-tasks').textContent=Math.round(1+Math.random()*5);
    document.getElementById('s-up').textContent=fup(Date.now()-t0);
  }
  requestAnimationFrame(loop);
}
loop();

// ambient page 1
setInterval(()=>{const id=IDS[Math.floor(Math.random()*IDS.length)];mkBeam(bA,posA,id,'ORCH',AGENTS[id].color,3.5);setTimeout(()=>mkBeam(bA,posA,'ORCH',id,AGENTS[id].color,3.5),800);},1500);
setInterval(()=>{const s=[...IDS].sort(()=>Math.random()-.5);mkBeam(bA,posA,s[0],s[1],AGENTS[s[0]].color,2.2);},2300);
setInterval(()=>{const id=IDS[Math.floor(Math.random()*IDS.length)];mkBeam(bA,posA,'ORCH',id,AGENTS[id].color,4);},3100);
setTimeout(()=>IDS.forEach(id=>mkBeam(bA,posA,id,'ORCH',AGENTS[id].color,3)),500);

function go(tab){
  curTab=tab;
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on'));
  document.getElementById('tab-'+tab).classList.add('on');
  document.getElementById('pg-'+tab).classList.add('on');
  setTimeout(()=>{sz();placeA();updPos();},60);
}

// messages
const logEl=document.getElementById('log');let mi=0;
function fup(ms){const s=Math.floor(ms/1000)%60,m=Math.floor(ms/60000)%60,h=Math.floor(ms/3600000);return`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;}
function nows(){const d=new Date();return`${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}`;}
function fire(){
  const[fr,to,txt]=MSGS[mi%MSGS.length];mi++;
  const fa=AGENTS[fr],ta=AGENTS[to];
  mkBeam(bF,posF,fr,to,fa?.color||'#c9a84c',3.2);
  totalMsgs++;
  document.getElementById('s-msg').textContent=totalMsgs;
  document.getElementById('lc').textContent=totalMsgs+' msg';
  if(agCnts[fr]!==undefined){agCnts[fr]++;document.getElementById('cnt-'+fr).textContent=agCnts[fr];}
  if(to!=='ORCH'&&agCnts[to]!==undefined){agCnts[to]++;document.getElementById('cnt-'+to).textContent=agCnts[to];}
  const e=document.createElement('div');e.className='le';
  e.innerHTML=`<div class="lt"><span class="lt-t">${nows()}</span><span class="lt-f" style="color:${fa?.color||'#c9a84c'}">${fa?.label||'ORCH'}</span><span class="lt-a">→</span><span class="lt-o" style="color:${ta?.color||'#c9a84c'}">${ta?.label||'ORCH'}</span></div><div class="lm">${txt}</div>`;
  logEl.prepend(e);while(logEl.children.length>30)logEl.removeChild(logEl.lastChild);
}
setTimeout(()=>{fire();setInterval(fire,2000);},700);

// tooltip
const tt=document.getElementById('tt');
IDS.forEach(id=>{
  ['a-'+id,'f-'+id].forEach(domId=>{
    const el=document.getElementById(domId);if(!el)return;
    el.addEventListener('mousemove',e=>{
      const a=AGENTS[id];
      document.getElementById('tt-n').textContent=a.label+' – '+a.role;
      document.getElementById('tt-n').style.color=a.color;
      document.getElementById('tt-d').textContent=a.desc;
      tt.classList.add('show');tt.style.left=(e.clientX+14)+'px';tt.style.top=(e.clientY-52)+'px';
    });
    el.addEventListener('mouseleave',()=>tt.classList.remove('show'));
    el.addEventListener('click',()=>{
      const arr=curTab==='a'?bA:bF,pos2=curTab==='a'?posA:posF;
      mkBeam(arr,pos2,id,'ORCH',AGENTS[id].color,5);
      setTimeout(()=>mkBeam(arr,pos2,'ORCH',id,AGENTS[id].color,5),600);
    });
  });
});
</script>

