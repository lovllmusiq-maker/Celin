<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LOVLL – Architecture Multi-Agents</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Syne:wght@700;800&display=swap');

*{margin:0;padding:0;box-sizing:border-box}
:root{
–bg:#000;
–s1:#070810;
–s2:#0c0d18;
–b1:#0f1120;
–b2:#1a1d2e;
–gold:#c9a84c;
–cyan:#00d4ff;
–violet:#7c3aed;
–green:#00ff88;
–red:#ff4d6d;
–orange:#ff8c42;
–blue:#3b82f6;
–mono:‘JetBrains Mono’,monospace;
–display:‘Syne’,sans-serif;
–nav:54px;
–tabs:44px;
–top:98px;
}
html,body{width:100%;height:100%;background:var(–bg);overflow:hidden;font-family:var(–mono);color:#e2e8f0}

/* ══ HEADER ══ */
.hdr{
position:fixed;top:0;left:0;right:0;z-index:100;height:var(–nav);
display:flex;align-items:center;justify-content:space-between;
padding:0 2rem;background:#000;
border-bottom:1px solid var(–b1);
}
.hdr-logo{font-family:var(–display);font-size:1.1rem;font-weight:800;color:var(–gold);letter-spacing:.1em}
.hdr-mid{font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(201,168,76,.3)}
.hdr-ok{display:flex;align-items:center;gap:.5rem;font-size:.58rem;color:var(–green)}
.dot{width:7px;height:7px;border-radius:50%;background:var(–green);animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.18}}

/* ══ TABS ══ */
.tabs{
position:fixed;top:var(–nav);left:0;right:0;z-index:99;height:var(–tabs);
display:flex;background:#000;border-bottom:1px solid var(–b1);
}
.tab{
flex:1;height:100%;display:flex;align-items:center;justify-content:center;gap:.55rem;
font-family:var(–mono);font-size:.63rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
color:#202436;background:transparent;border:none;border-bottom:2px solid transparent;
cursor:pointer;transition:color .2s,border-color .2s,background .2s;
}
.tab:hover{color:#475569;background:rgba(255,255,255,.012)}
.tab.on{color:var(–gold);border-bottom-color:var(–gold);background:rgba(201,168,76,.03)}
.tsep{width:1px;background:var(–b1);flex-shrink:0}

/* ══ PAGES ══ */
.pg{position:fixed;top:var(–top);left:0;right:0;bottom:0;display:none}
.pg.on{display:block}

/* ════════════════════════════════════════
PAGE 1 — VUE AGENTS (fullscreen)
════════════════════════════════════════ */
#pg-a{background:#000}
#cv-a{position:absolute;inset:0;width:100%;height:100%}

.orch{
position:absolute;transform:translate(-50%,-50%);
display:flex;flex-direction:column;align-items:center;gap:.55rem;z-index:20;
}
.or-wrap{position:relative;display:flex;align-items:center;justify-content:center}
.or-r1,.or-r2{position:absolute;border-radius:50%}
.or-r1{border:1px solid rgba(201,168,76,.22);animation:spin 12s linear infinite}
.or-r2{border:1px dashed rgba(201,168,76,.09);animation:spin 8s linear infinite reverse}
@keyframes spin{to{transform:rotate(360deg)}}
.or-core{
border-radius:50%;background:radial-gradient(circle at 38% 32%,#161000,#040300);
border:1.5px solid var(–gold);
display:flex;align-items:center;justify-content:center;
font-family:var(–display);font-weight:800;color:var(–gold);
letter-spacing:.07em;text-align:center;line-height:1.45;z-index:1;
animation:glwO 3s ease-in-out infinite;
}
@keyframes glwO{
0%,100%{box-shadow:0 0 28px rgba(201,168,76,.22),0 0 70px rgba(201,168,76,.05)}
50%    {box-shadow:0 0 55px rgba(201,168,76,.5),0 0 120px rgba(201,168,76,.14)}
}
.or-lbl{font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(201,168,76,.36)}

.ag{
position:absolute;transform:translate(-50%,-50%);
display:flex;flex-direction:column;align-items:center;gap:.5rem;
cursor:pointer;z-index:20;transition:filter .25s;
}
.ag:hover{filter:brightness(1.4) drop-shadow(0 0 10px currentColor)}
.hw{position:relative;display:flex;align-items:center;justify-content:center}
.hw svg{position:absolute;inset:0;width:100%;height:100%}
.hi{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:3px}
.al{font-family:var(–display);font-weight:800;line-height:1}
.as2{letter-spacing:.1em;opacity:.6}
.an{font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:#252840;white-space:nowrap}
.ab{font-size:.57rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.18rem .65rem;border-radius:2px;white-space:nowrap}

/* ════════════════════════════════════════
PAGE 2 — FLUX & MESSAGES
════════════════════════════════════════ */
#pg-f{display:none;grid-template-columns:1fr 300px}
#pg-f.on{display:grid}

.fl-l{position:relative;overflow:hidden;background:#000}
#cv-f{position:absolute;inset:0;width:100%;height:100%}
.fl-scene{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}

.ag-s{
position:absolute;transform:translate(-50%,-50%);
display:flex;flex-direction:column;align-items:center;gap:.32rem;
cursor:pointer;z-index:20;transition:filter .2s;
}
.ag-s:hover{filter:brightness(1.3)}
.hw-s{position:relative;width:56px;height:56px;display:flex;align-items:center;justify-content:center}
.hw-s svg{position:absolute;inset:0;width:100%;height:100%}
.hi-s{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:1px}
.al-s{font-family:var(–display);font-size:1rem;font-weight:800;line-height:1}
.as-s{font-size:.42rem;opacity:.6;letter-spacing:.08em}
.an-s{font-size:.52rem;letter-spacing:.12em;text-transform:uppercase;color:#1a1e30;white-space:nowrap}

.fl-r{
background:var(–s1);border-left:1px solid var(–b1);
display:flex;flex-direction:column;overflow:hidden;
}
.rph{
padding:.55rem 1rem;font-size:.52rem;letter-spacing:.16em;text-transform:uppercase;
color:#1a1e30;border-bottom:1px solid var(–b1);
display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.rph em{color:var(–green);font-style:normal;font-size:.56rem}
.sg{display:grid;grid-template-columns:1fr 1fr;flex-shrink:0}
.st{padding:.58rem .85rem;border-right:1px solid var(–b1);border-bottom:1px solid var(–b1)}
.st:nth-child(2n){border-right:none}
.st-l{font-size:.47rem;letter-spacing:.12em;text-transform:uppercase;color:#1a1e30;margin-bottom:.2rem}
.st-v{font-family:var(–display);font-size:.95rem;font-weight:700;line-height:1}
.st-s{font-size:.45rem;color:#0f1120;margin-top:.12rem}
.rh{padding:.4rem .9rem;font-size:.48rem;letter-spacing:.14em;text-transform:uppercase;color:#0f1120;border-bottom:1px solid var(–b1);flex-shrink:0}
.ar{display:flex;align-items:center;gap:.5rem;padding:.34rem .9rem;border-bottom:1px solid rgba(15,17,32,.6)}
.ar-d{width:5px;height:5px;border-radius:50%;flex-shrink:0;animation:blink 2s ease-in-out infinite}
.ar-i{font-size:.57rem;font-weight:600;min-width:26px}
.ar-r{font-size:.52rem;color:#1a1e30;flex:1}
.ar-c{font-size:.52rem;color:#0f1120;font-weight:600}
.lh{padding:.4rem .9rem;font-size:.48rem;letter-spacing:.14em;text-transform:uppercase;color:#0f1120;border-bottom:1px solid var(–b1);flex-shrink:0}
.ls{flex:1;overflow-y:auto}
.ls::-webkit-scrollbar{width:2px}
.ls::-webkit-scrollbar-thumb{background:var(–b1)}
.le{padding:.42rem .9rem;border-bottom:1px solid rgba(15,17,32,.5);animation:sli .3s ease both}
@keyframes sli{from{opacity:0;transform:translateX(6px)}to{opacity:1;transform:none}}
.lt{display:flex;align-items:center;gap:.38rem;margin-bottom:.15rem}
.lt-t{font-size:.47rem;color:#0a0c14;flex-shrink:0}
.lt-f{font-size:.53rem;font-weight:600;flex-shrink:0}
.lt-a{font-size:.47rem;color:#0a0c14}
.lt-o{font-size:.53rem;flex-shrink:0}
.lm{font-size:.52rem;color:#1a1e30;line-height:1.4}

/* ════════════════════════════════════════
PAGE 3 — ÉQUIPE (9 members)
════════════════════════════════════════ */
#pg-e{display:none;background:#000;align-items:flex-start;justify-content:center;padding:2.5rem 3rem;overflow-y:auto}
#pg-e.on{display:flex;flex-direction:column}

.team-hdr{
margin-bottom:2.5rem;
}
.team-eyebrow{font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(201,168,76,.4);display:flex;align-items:center;gap:.7rem;margin-bottom:.8rem}
.team-eyebrow::before{content:’’;display:block;width:1.4rem;height:1px;background:rgba(201,168,76,.4)}
.team-title{font-family:var(–display);font-size:clamp(1.4rem,3vw,2.2rem);font-weight:800;color:#e2e8f0;line-height:1.1}
.team-title em{font-style:italic;color:var(–gold)}
.team-sub{font-size:.7rem;color:#252840;margin-top:.5rem;letter-spacing:.05em}

/* Department sections */
.dept{margin-bottom:2rem}
.dept-label{
font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;color:#1a1e30;
margin-bottom:1rem;padding-bottom:.5rem;
border-bottom:1px solid var(–b1);
display:flex;align-items:center;gap:.6rem;
}
.dept-label::before{content:’’;display:inline-block;width:4px;height:4px;border-radius:50%}

.member-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1px;background:var(–b1)}
.member{
background:#000;
padding:1.2rem 1.4rem;
display:flex;align-items:flex-start;gap:1rem;
transition:background .2s;
cursor:default;
}
.member:hover{background:var(–s1)}
.m-hex{
width:44px;height:44px;flex-shrink:0;
position:relative;display:flex;align-items:center;justify-content:center;
}
.m-hex svg{position:absolute;inset:0;width:100%;height:100%}
.m-init{position:relative;z-index:1;font-family:var(–display);font-size:.7rem;font-weight:800}
.m-info{display:flex;flex-direction:column;gap:.2rem;min-width:0}
.m-name{font-family:var(–display);font-size:.82rem;font-weight:700;color:#c8d0e0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.m-role{font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;font-weight:600}
.m-dept{font-size:.55rem;color:#1a1e30;margin-top:.1rem}

/* ══ TOOLTIP ══ */
.tt{position:fixed;background:rgba(0,0,0,.97);border:1px solid var(–b2);border-radius:2px;padding:.6rem .85rem;font-size:.6rem;line-height:1.6;z-index:500;pointer-events:none;opacity:0;transition:opacity .14s;max-width:210px}
.tt.show{opacity:1}
.tt-n{font-family:var(–display);font-size:.8rem;font-weight:700;margin-bottom:.28rem}
.tt-d{color:#475569;font-size:.56rem}
</style>

</head>
<body>

