<header class="hdr">
  <div class="hdr-logo">LOVLL</div>
  <div class="hdr-mid">Architecture Multi-Agents · V2.0</div>
  <div class="hdr-ok"><div class="dot"></div>Système actif</div>
</header>

<!-- TABS -->

<div class="tabs">
  <button class="tab on" id="tab-a" onclick="go('a')">⬡ &nbsp;Vue Agents</button>
  <div class="tsep"></div>
  <button class="tab" id="tab-f" onclick="go('f')">⇄ &nbsp;Flux &amp; Messages</button>
  <div class="tsep"></div>
  <button class="tab" id="tab-e" onclick="go('e')">◈ &nbsp;Équipe</button>
</div>

<!-- ══════════ PAGE 1 : VUE AGENTS ══════════ -->

<div class="pg on" id="pg-a">
  <canvas id="cv-a"></canvas>

  <div class="orch" id="orch-a">
    <div class="or-wrap" id="orw-a">
      <div class="or-r1" id="orr1-a"></div>
