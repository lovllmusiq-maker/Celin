      <div style={{display:"grid",gridTemplateColumns:`repeat(${COLS},${CELL}px)`,gridTemplateRows:`repeat(${ROWS},${CELL}px)`,border:"3px solid rgba(255,255,255,.55)",position:"relative",boxShadow:"0 0 50px rgba(0,0,0,.9)"}}>
        {/* Marquages terrain */}
        <div style={{position:"absolute",top:H/2-2,left:0,right:0,height:4,background:"rgba(255,255,255,.72)",pointerEvents:"none",zIndex:3}}/>
        {/* Rond central : rayon = 2 cases = 2*CELL px, diamètre 4*CELL */}
        <div style={{position:"absolute",top:H/2-(2*CELL),left:W/2-(2*CELL),width:4*CELL,height:4*CELL,borderRadius:"50%",border:"3px solid rgba(255,255,255,.68)",pointerEvents:"none",zIndex:3}}/>
        {/* Point central */}
        <div style={{position:"absolute",top:H/2-5,left:W/2-5,width:10,height:10,borderRadius:"50%",background:"rgba(255,255,255,.85)",pointerEvents:"none",zIndex:3}}/>
        {/* Surfaces de réparation haut et bas (3 lignes de haut) */}
        <div style={{position:"absolute",top:0,left:W*.15,width:W*.7,height:CELL*3,border:"3px solid rgba(255,255,255,.62)",borderTop:"none",pointerEvents:"none",zIndex:3}}/>
        <div style={{position:"absolute",bottom:0,left:W*.15,width:W*.7,height:CELL*3,border:"3px solid rgba(255,255,255,.62)",borderBottom:"none",pointerEvents:"none",zIndex:3}}/>
        {/* Petits rectangles (surface de but) */}
        <div style={{position:"absolute",top:0,left:W*.3,width:W*.4,height:CELL*1.5,border:"3px solid rgba(255,255,255,.52)",borderTop:"none",pointerEvents:"none",zIndex:3}}/>
        <div style={{position:"absolute",bottom:0,left:W*.3,width:W*.4,height:CELL*1.5,border:"3px solid rgba(255,255,255,.52)",borderBottom:"none",pointerEvents:"none",zIndex:3}}/>

        {/* Cellules — joueurs sur cases CLAIRES uniquement, damier maintenu visuellement */}
        {Array(ROWS).fill(null).map((_,r)=>
          Array(COLS).fill(null).map((_,c)=>{
            const light=(r+c)%2===0;  // case claire = jouable
            const piece=board[r][c];
            const isSel=sel&&sel[0]===r&&sel[1]===c;
            const mv=valids.find(m=>m.to[0]===r&&m.to[1]===c);
            const stripe=Math.floor(r/2)%2===0;
            const bg=light?(stripe?"#38c45c":"#32b350"):(stripe?"#1a6830":"#1c7035");
            const clickable=light&&(!!(piece&&piece.team===turn)||!!mv);
            return(
              <div key={`${r}-${c}`} onClick={()=>light&&handleCell(r,c)}
                style={{width:CELL,height:CELL,background:bg,display:"flex",alignItems:"center",justifyContent:"center",cursor:clickable?"pointer":"default",boxSizing:"border-box",position:"relative",zIndex:1,outline:isSel?"3px solid #FFD700":mv?`2px solid ${mv.capture?"#ff4444":"#44ff88"}`:"none",outlineOffset:"-2px"}}>
                {light&&piece&&(
                  <PlayerSVG t={piece} num={piece.number} pos={piece.pos} isKing={piece.isKing} isGK={piece.isGK} size={CELL-4} facingDown={piece.team==="team2"}/>
                )}
                {light&&!piece&&mv&&(
                  <div style={{width:CELL*.44,height:CELL*.44,borderRadius:"50%",background:mv.capture?"rgba(255,50,50,.72)":"rgba(60,255,120,.72)",boxShadow:mv.capture?"0 0 10px #ff3333":"0 0 10px #3dff78",animation:"pulse .75s infinite"}}/>
                )}
              </div>
            );
          })
        )}

        {goalAnim&&(
          <div style={{position:"absolute",inset:0,background:"rgba(255,220,0,.18)",animation:"goal 2.6s ease forwards",pointerEvents:"none",zIndex:10,display:"flex",alignItems:"center",justifyContent:"center"}}>
            <span style={{fontSize:68,animation:"bounce .42s infinite"}}>⚽</span>
          </div>
        )}
      </div>

      {/* Cage bas — team2 défend (GK team2 est sur row 14, devant) */}
      <div style={{width:W,height:GOAL_H,position:"relative"}}>
        <div style={{position:"absolute",left:GOAL_X,top:0,width:GOAL_W,height:GOAL_H}}>
          <GoalSVG accentColor={t2.accent} W={GOAL_W} H={GOAL_H} barreEnHaut={false}/>
        </div>
        <div style={{position:"absolute",right:4,top:"50%",transform:"translateY(-50%)",color:t2.accent,fontSize:7.5,fontWeight:900}}>{t2.flag} BUT</div>
      </div>

      {/* Tribunes bas */}
      <div style={{width:W}}>
        <Crowd color={t2.crowd||t2.jersey} accent={t2.accent} count={Math.floor(W/17)} side="bottom" height={46}/>
      </div>
    </div>

    {/* ── COLONNE BANCS (haut = team2, bas = team1) ── */}
    {bench&&(
      <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:4,paddingTop:46}}>
        <BenchPanel subs={bench.team2} team="team2" tData={t2} score={scores.team2} pieces={countPieces("team2")} onCoachClick={()=>setShowFormPicker(f=>f==="team2"?null:"team2")} onBenchClick={()=>{setShowSubPanel("team2");setSubSelected([]);}} currentForm={form2}/>

        <BenchPanel subs={bench.team1} team="team1" tData={t1} score={scores.team1} pieces={countPieces("team1")} onCoachClick={()=>setShowFormPicker(f=>f==="team1"?null:"team1")} onBenchClick={()=>{setShowSubPanel("team1");setSubSelected([]);}} currentForm={form1}/>
      </div>
    )}
  </div>

  {/* ── MODAL REMPLACEMENT ── */}
  {showSubPanel&&phase==="playing"&&(
    <div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.78)",zIndex:50,display:"flex",alignItems:"center",justifyContent:"center"}}
      onClick={()=>{setShowSubPanel(null);setSubSelected([]);}}>
      <div onClick={e=>e.stopPropagation()} style={{
        background:"linear-gradient(135deg,#0d2a10,#1a3a1a)",
        border:`2px solid ${showSubPanel==="team1"?t1.accent:t2.accent}`,
        borderRadius:16,padding:"16px 14px",width:270,
        boxShadow:"0 20px 60px rgba(0,0,0,.9)",
      }}>
        {/* Header */}
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12}}>
          <span style={{fontSize:22}}>{showSubPanel==="team1"?t1.flag:t2.flag}</span>
          <div>
            <div style={{color:"#fff",fontWeight:900,fontSize:13}}>{showSubPanel==="team1"?t1.name:t2.name}</div>
            <div style={{color:"rgba(255,255,255,.45)",fontSize:10}}>Choisir les remplaçants à faire rentrer</div>
          </div>
          <button onClick={()=>{setShowSubPanel(null);setSubSelected([]);}} style={{marginLeft:"auto",background:"none",border:"none",color:"rgba(255,255,255,.4)",fontSize:18,cursor:"pointer"}}>✕</button>
        </div>

        {/* Liste des remplaçants */}
        <div style={{display:"flex",flexDirection:"column",gap:6,marginBottom:12}}>
          {(showSubPanel==="team1"?bench.team1:bench.team2).map((s,i)=>{
            const tData=showSubPanel==="team1"?t1:t2;
            const isSelected=subSelected.includes(i);
            const isUsed=s.used;
            return(
              <div key={s.id} onClick={()=>{
                if(isUsed)return;
                setSubSelected(prev=>prev.includes(i)?prev.filter(x=>x!==i):[...prev,i]);
              }} style={{
                display:"flex",alignItems:"center",gap:10,
                background:isUsed?"rgba(0,0,0,.2)":isSelected?"rgba(0,255,100,.12)":"rgba(255,255,255,.05)",
                border:`1.5px solid ${isUsed?"rgba(255,255,255,.05)":isSelected?"#00ff88":"rgba(255,255,255,.1)"}`,
                borderRadius:10,padding:"8px 10px",
                cursor:isUsed?"default":"pointer",
                opacity:isUsed?.35:1,
                transition:"all .15s",
              }}>
                <PlayerSVG t={tData} num={s.number} pos="SUB" size={28} faded={isUsed} facingDown={showSubPanel==="team2"}/>
                <div style={{flex:1}}>
                  <div style={{color:isUsed?"#555":"#fff",fontWeight:900,fontSize:14}}>#{s.number}</div>
                  <div style={{color:isUsed?"#444":"rgba(255,255,255,.5)",fontSize:9}}>{isUsed?"Déjà rentré":"Disponible"}</div>
                </div>
                {/* Checkbox */}
                {!isUsed&&(
                  <div style={{
                    width:20,height:20,borderRadius:4,border:`2px solid ${isSelected?"#00ff88":"rgba(255,255,255,.3)"}`,
                    background:isSelected?"#00ff88":"transparent",
                    display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,
                  }}>
                    {isSelected&&<span style={{color:"#000",fontSize:12,fontWeight:900}}>✓</span>}
                  </div>
                )}
              </div>
            );
          })}
        </div>

        {/* Boutons d'action */}
        <div style={{display:"flex",gap:6,flexDirection:"column"}}>
          {/* Sélection rapide */}
          <div style={{display:"flex",gap:4}}>
            {[1,2,3].map(n=>{
              const avail=(showSubPanel==="team1"?bench.team1:bench.team2).filter(s=>!s.used);
              return avail.length>=n&&(
                <button key={n} onClick={()=>{
                  const av=(showSubPanel==="team1"?bench.team1:bench.team2)
                    .map((s,i)=>({s,i})).filter(({s})=>!s.used).slice(0,n).map(({i})=>i);
                  setSubSelected(av);
                }} style={{flex:1,padding:"4px 0",background:"rgba(255,255,255,.08)",border:"1px solid rgba(255,255,255,.15)",borderRadius:6,color:"#fff",cursor:"pointer",fontSize:10,fontWeight:700}}>
                  {n} rempla.
                </button>
              );
            })}
          </div>
          {/* Confirmer */}
          <button
            disabled={subSelected.length===0}
            onClick={()=>confirmSubs(showSubPanel)}
            style={{
              padding:"10px 0",
              background:subSelected.length>0?"linear-gradient(135deg,#00cc55,#009933)":"rgba(255,255,255,.1)",
              border:"none",borderRadius:10,
              color:subSelected.length>0?"#fff":"rgba(255,255,255,.3)",
              fontWeight:900,fontSize:14,cursor:subSelected.length>0?"pointer":"default",
              letterSpacing:1,transition:"all .2s",
            }}>
            {subSelected.length===0
              ? "Sélectionne des joueurs"
              : `↩ Faire rentrer ${subSelected.length} joueur${subSelected.length>1?"s":""}`
            }
          </button>
        </div>
      </div>
    </div>
  )}

  {/* ── SÉLECTEUR DE FORMATION (modal) ── */}
  {showFormPicker&&phase==="playing"&&(
    <div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.75)",zIndex:50,display:"flex",alignItems:"center",justifyContent:"center"}}
      onClick={()=>setShowFormPicker(null)}>
      <div onClick={e=>e.stopPropagation()} style={{
        background:"linear-gradient(135deg,#0e2a0e,#1a3a1a)",
        border:`2px solid ${showFormPicker==="team1"?t1.accent:t2.accent}`,
        borderRadius:16,padding:"16px 14px",width:280,
        boxShadow:"0 20px 60px rgba(0,0,0,.9)",
      }}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12}}>
          <span style={{fontSize:20}}>{showFormPicker==="team1"?t1.flag:t2.flag}</span>
          <div>
            <div style={{color:"#fff",fontWeight:900,fontSize:13}}>{showFormPicker==="team1"?t1.name:t2.name}</div>
            <div style={{color:"rgba(255,255,255,.45)",fontSize:10}}>Choisir une formation tactique</div>
          </div>
          <button onClick={()=>setShowFormPicker(null)} style={{marginLeft:"auto",background:"none",border:"none",color:"rgba(255,255,255,.4)",fontSize:18,cursor:"pointer",lineHeight:1}}>✕</button>
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:6}}>
          {Object.entries(FORMATIONS).map(([key,f])=>{
            const isCurrent=(showFormPicker==="team1"?form1:form2)===key;
            return(
              <div key={key} onClick={()=>changeFormation(showFormPicker,key)}
                style={{
                  display:"flex",alignItems:"center",gap:10,
                  background:isCurrent?"rgba(255,215,0,.18)":"rgba(255,255,255,.05)",
                  border:`1.5px solid ${isCurrent?"#FFD700":"rgba(255,255,255,.1)"}`,
                  borderRadius:10,padding:"8px 10px",cursor:"pointer",
                  transition:"background .15s, border .15s",
                }}
                onMouseEnter={e=>{if(!isCurrent)e.currentTarget.style.background="rgba(255,255,255,.1)"}}
                onMouseLeave={e=>{if(!isCurrent)e.currentTarget.style.background="rgba(255,255,255,.05)"}}>
                {/* Mini visualisation de la formation */}
                <div style={{width:36,height:48,background:"#1a5c2a",borderRadius:4,position:"relative",flexShrink:0,border:"1px solid rgba(255,255,255,.2)"}}>
                  <div style={{position:"absolute",top:"50%",left:0,right:0,height:1,background:"rgba(255,255,255,.3)"}}/>
                  {f.lines.flat().map((n,li)=>{
                    const totalLines=f.lines.flat().length;
                    const y=((li+1)/(totalLines+1))*100;
                    return Array.from({length:n},(_,pi)=>(
                      <div key={`${li}-${pi}`} style={{
                        position:"absolute",
                        top:`${y}%`,left:`${((pi+1)/(n+1))*100}%`,
                        width:5,height:5,borderRadius:"50%",
                        background:isCurrent?"#FFD700":"rgba(255,255,255,.7)",
                        transform:"translate(-50%,-50%)",
                      }}/>
                    ));
                  })}
                </div>
                <div style={{flex:1}}>
                  <div style={{color:isCurrent?"#FFD700":"#fff",fontWeight:900,fontSize:14,letterSpacing:1}}>{f.label}</div>
                  <div style={{color:"rgba(255,255,255,.5)",fontSize:9,marginTop:2}}>{f.desc}</div>
                </div>
                {isCurrent&&<span style={{color:"#FFD700",fontSize:14}}>✓</span>}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  {phase==="over"&&(
    <div style={{background:"linear-gradient(135deg,rgba(255,215,0,.18),rgba(255,140,0,.12))",border:"2px solid #FFD700",borderRadius:14,padding:"12px 24px",textAlign:"center",animation:"up .4s"}}>
      <div style={{fontSize:34}}>🏆</div>
      <div style={{color:"#FFD700",fontWeight:900,fontSize:18,letterSpacing:2}}>FIN DU MATCH</div>
      <div style={{color:"#fff",fontSize:14,marginTop:4}}>{t1.flag} <b>{scores.team1}</b> — <b>{scores.team2}</b> {t2.flag}</div>
      <button onClick={start} style={{marginTop:10,padding:"8px 18px",background:"linear-gradient(135deg,#FFD700,#FF8C00)",border:"none",borderRadius:8,color:"#000",fontWeight:900,fontSize:12,cursor:"pointer"}}>🔄 Rejouer</button>
    </div>
  )}
</div>
