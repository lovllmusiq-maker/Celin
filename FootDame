// ─── CAGE SVG seule (sans GK — le GK est sur le terrain) ─────────────────────
function GoalSVG({ accentColor, W, H, barreEnHaut }) {
const netC=8, netR=4;
return (
<svg width={W} height={H} viewBox={`0 0 ${W} ${H}`} style={{display:“block”}}>
<rect x="0" y="0" width={W} height={H} fill="rgba(255,255,255,.05)" rx="2"/>
{Array(netC+1).fill(null).map((*,i)=><line key={`v${i}`} x1={i*(W/netC)} y1=“0” x2={i*(W/netC)} y2={H} stroke=“rgba(255,255,255,.18)” strokeWidth=”.8”/>)}
{Array(netR+1).fill(null).map((*,i)=><line key={`h${i}`} x1=“0” y1={i*(H/netR)} x2={W} y2={i*(H/netR)} stroke=“rgba(255,255,255,.18)” strokeWidth=”.8”/>)}
{/* Poteaux */}
<rect x="0"   y="0" width="5" height={H} fill="white" rx="2"/>
<rect x={W-5} y="0" width="5" height={H} fill="white" rx="2"/>
{/* Barre */}
{barreEnHaut
? <rect x="0" y="0"   width={W} height="5" fill="white" rx="2"/>
: <rect x="0" y={H-5} width={W} height="5" fill="white" rx="2"/>
}
{/* Accent couleur sur poteaux */}
<rect x="2"   y="2" width="2" height={H-4} fill={accentColor} opacity=".45" rx="1"/>
<rect x={W-4} y="2" width="2" height={H-4} fill={accentColor} opacity=".45" rx="1"/>
</svg>
);
}

