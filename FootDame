{[.12,.42,.68,.88].map((p,i)=>(
<div key={i} style={{position:“absolute”,left:`${p*100}%`,top:side===“top”?4:undefined,bottom:side===“bottom”?4:undefined,background:i%2===0?color:accent,width:24,height:14,borderRadius:2,fontSize:7,display:“flex”,alignItems:“center”,justifyContent:“center”,color:”#fff”,fontWeight:900,boxShadow:“0 2px 6px rgba(0,0,0,.6)”,transform:`rotate(${i%2===0?-3:3}deg)`}}>{“⚽🏆👊🔥”[i]}</div>
