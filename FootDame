function darkCells(row,count,rev=false){
const cells=[],range=rev?Array.from({length:COLS},(*,i)=>COLS-1-i):Array.from({length:COLS},(*,i)=>i);
for(const c of range) if((row+c)%2===1&&cells.length<count) cells.push(c);
return cells;
}

// Cases claires d’une ligne (r+c)%2===0 → joueurs posés ici
// Cases sombres (r+c)%2===1 → vides, cases de déplacement dames

// Retourne les colonnes CLAIRES espacées pour n joueurs sur une ligne
function lightColsSpaced(row, n) {
const lights = [];
for (let c = 0; c < COLS; c++) if ((row+c)%2===0) lights.push(c);
// COLS=11 → 6 cases claires (row pair) ou 5 (row impair)
if (n <= 0) return [];
if (n >= lights.length) return lights;
if (n === 1) return [lights[Math.floor(lights.length/2)]];
const step = (lights.length-1)/(n-1);
return Array.from({length:n},(_,i)=>lights[Math.round(i*step)]);
}

function place(b,row,col,team,tKey,tData,num,pos,id){
b[row][col]={team,key:tKey,…tData,number:num,pos,isKing:false,isGK:false,id};
}

function applyFormation(b,team,tKey,tData,formation,isTeam2){
// Place les joueurs de champ (hors GK) selon la formation
// isTeam2=true → rows du haut (rows2), isTeam2=false → rows du bas (rows1)
const f=FORMATIONS[formation]||FORMATIONS[“4-3-3”];
const rows=isTeam2?f.rows2:f.rows1;
const allPos=f.pos;
let numIdx=1; // #1 = GK, on commence à #2
let lineIdx=0;
for(let li=0;li<f.lines.length;li++){
const lineCounts=f.lines[li];
const lineRows=Array.isArray(lineCounts)?lineCounts:[lineCounts];
for(let ri=0;ri<lineRows.length;ri++){
const n=lineRows[ri];
const row=rows[lineIdx]||rows[rows.length-1];
lineIdx++;
const posArr=allPos[lineIdx-1+(lineIdx>rows.length?1:0)]||allPos[allPos.length-1]||[];
lightColsSpaced(row,n).forEach((c,i)=>{
const p=posArr[i]||“CM”;
b[row][c]={team,key:tKey,…tData,number:NUMBERS[numIdx],pos:p,isKing:false,isGK:false,id:`${team}-f${row}-${i}`};
numIdx++;
});
}
}
}

function initBoard(t1k,t2k,kickoffTeam,form1=“4-3-3”,form2=“4-3-3”){
const b=Array(ROWS).fill(null).map(()=>Array(COLS).fill(null));
const t1=TEAMS[t1k],t2=TEAMS[t2k];

// ── GK team2 (haut) row 1 ──
lightColsSpaced(1,1).forEach(c=>{
b[1][c]={team:“team2”,key:t2k,…t2,number:1,pos:“GK”,isKing:false,isGK:true,id:“t2-gk”};
});
// ── Formation team2 ──
applyFormation(b,“team2”,t2k,t2,form2,true);

// ── GK team1 (bas) row 15 ──
lightColsSpaced(15,1).forEach(c=>{
b[15][c]={team:“team1”,key:t1k,…t1,number:1,pos:“GK”,isKing:false,isGK:true,id:“t1-gk”};
});
// ── Formation team1 ──
applyFormation(b,“team1”,t1k,t1,form1,false);

// ── COUP D’ENVOI ──
// 2 joueurs de kickoffTeam SEULEMENT sur leur ligne (row 9 ou 8)
// → DANS le cercle (rayon 2 = rows 7-11 côté hauteur, mais cols centrales)
// L’adversaire reste sur row 7 ou 10 → à l’extérieur du cercle
const kt=kickoffTeam===“team1”?t1:t2, ktk=kickoffTeam===“team1”?t1k:t2k;
// team1 engage depuis row 9 (sa moitié), team2 depuis row 8 (sa moitié)
const koRow=kickoffTeam===“team1”?9:8;
// Vider cette ligne (sécurité)
for(let c=0;c<COLS;c++) b[koRow][c]=null;
// 2 cases claires les plus centrales de koRow
const allLight=[];
for(let c=0;c<COLS;c++) if((koRow+c)%2===0) allLight.push(c);
const mid=Math.floor(allLight.length/2);
const koCols=allLight.length>=2?[allLight[mid-1],allLight[mid]]:[allLight[0]];

// ── RETIRER 2 ATT du kickoffTeam pour rester à 11 joueurs ──
// Les 2 joueurs KO REMPLACENT 2 ATT (ST et un ailier) — pas des joueurs en plus
const attRow=kickoffTeam===“team1”?10:6;
let removed=0;
for(let c=0;c<COLS&&removed<2;c++){
if(b[attRow][c]&&b[attRow][c].team===kickoffTeam){ b[attRow][c]=null; removed++; }
}

koCols.forEach((c,i)=>{
b[koRow][c]={team:kickoffTeam,key:ktk,…kt,number:NUMBERS[9+i],pos:i===0?“ST”:“LW”,isKing:false,isGK:false,id:`${kickoffTeam}-ko${i}`};
});

return b;
}

function initBench(t1k,t2k){
return {
team1:[11,12,13].map(i=>({team:“team1”,key:t1k,…TEAMS[t1k],number:NUMBERS[i],pos:“SUB”,isKing:false,id:`t1-b${i}`,used:false})),
team2:[11,12,13].map(i=>({team:“team2”,key:t2k,…TEAMS[t2k],number:NUMBERS[i],pos:“SUB”,isKing:false,id:`t2-b${i}`,used:false})),
};
}

function getMoves(board,r,c,team){
const p=board[r][c]; if(!p||p.team!==team) return [];
// Déplacements en diagonale — vers cases claires uniquement : (nr+nc)%2===0
const dirs=p.isKing?[[-1,-1],[-1,1],[1,-1],[1,1]]:team===“team1”?[[-1,-1],[-1,1]]:[[1,-1],[1,1]];
const mvs=[];
for(const[dr,dc]of dirs){
const nr=r+dr, nc=c+dc;
if(nr<0||nr>=ROWS||nc<0||nc>=COLS) continue;
if((nr+nc)%2!==0) continue; // case sombre → interdite
if(!board[nr][nc]){
mvs.push({from:[r,c],to:[nr,nc],capture:null});
} else if(board[nr][nc].team!==team){
const jr=nr+dr, jc=nc+dc;
if(jr>=0&&jr<ROWS&&jc>=0&&jc<COLS&&(jr+jc)%2===0&&!board[jr][jc])
mvs.push({from:[r,c],to:[jr,jc],capture:[nr,nc]});
}
}
return mvs;
}
function allMoves(board,team){
const all=[];
for(let r=0;r<ROWS;r++)for(let c=0;c<COLS;c++)all.push(…getMoves(board,r,c,team));
const caps=all.filter(m=>m.capture);
return caps.length?caps:all;
}
function applyMove(board,mv){
const nb=board.map(row=>row.map(c=>c?{…c}:null));
const p={…nb[mv.from[0]][mv.from[1]]};
nb[mv.from[0]][mv.from[1]]=null;
if(mv.capture)nb[mv.capture[0]][mv.capture[1]]=null;
// Promotion capitaine : atteindre la dernière ligne adverse
if(p.team===“team1”&&mv.to[0]===0&&!mv.capture)p.isKing=true;
if(p.team===“team2”&&mv.to[0]===ROWS-1&&!mv.capture)p.isKing=true;
nb[mv.to[0]][mv.to[1]]=p;
return nb;
}
function isGoal(mv,team){
if(mv.capture)return false;
// team1 marque en atteignant row 0, team2 en atteignant row ROWS-1 (16)
return(team===“team1”&&mv.to[0]===0)||(team===“team2”&&mv.to[0]===ROWS-1);
}

