const [earnedXP, setEarnedXP] = useState(0);
const [tab, setTab] = useState(“learn”);
const [flip, setFlip] = useState(false);

const startLesson = (lesson) => {
if (!lesson.free && !isPremium) { setShowPremium(true); return; }
setSelectedLesson(lesson);
setLessonPhase(“vocab”);
setVocabIndex(0);
setQuizIndex(0);
setSelectedAnswer(null);
setIsCorrect(null);
setQuizComplete(false);
setEarnedXP(0);
setFlip(false);
setScreen(“lesson”);
};

const nextVocab = () => {
setFlip(false);
if (vocabIndex < selectedLesson.words.length - 1) {
setTimeout(() => setVocabIndex(v => v + 1), 100);
} else {
setLessonPhase(“quiz”);
}
};

const handleAnswer = (answer) => {
if (selectedAnswer) return;
const correct = answer === selectedLesson.exercises[quizIndex].answer;
setSelectedAnswer(answer);
setIsCorrect(correct);
if (!correct && hearts > 0) setHearts(h => h - 1);
if (correct) setEarnedXP(e => e + 10);
};

const nextQuiz = () => {
if (quizIndex < selectedLesson.exercises.length - 1) {
setQuizIndex(q => q + 1);
setSelectedAnswer(null);
setIsCorrect(null);
} else {
const finalXP = selectedLesson.xp + earnedXP;
setXp(x => x + finalXP);
setEarnedXP(finalXP);
setCoins(c => c + Math.floor(finalXP / 2));
if (!completedLessons.includes(selectedLesson.id)) {
setCompletedLessons(l => […l, selectedLesson.id]);
}
setQuizComplete(true);
}
};

const xpForLevel = (lvl) => lvl * 200;
const currentLevel = Math.floor(xp / 200) + 1;
const xpProgress = ((xp % 200) / 200) * 100;

