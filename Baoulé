              <div key={i} style={{ display: "flex", alignItems: "center", gap: 14, padding: "14px 16px", borderRadius: 18, background: item.color, border: "1px solid #ffffff10", marginBottom: 10 }}>
                <div style={{ fontSize: 32 }}>{item.icon}</div>
                <div style={{ flex: 1 }}>
                  <div style={{ fontWeight: 800, fontSize: 14 }}>{item.name}</div>
                  <div style={{ color: "#888", fontSize: 12 }}>{item.desc}</div>
                </div>
                <button onClick={() => { if (coins >= item.price) { setCoins(c => c - item.price); setHearts(Math.min(5, hearts + (item.name === "Recharge vies" ? 5 : 0))); }}} className="btn" style={{ padding: "8px 14px", borderRadius: 12, background: coins >= item.price ? "linear-gradient(135deg, #f5a623, #e8891a)" : "#333", color: "#fff", fontWeight: 800, fontSize: 13 }}>
