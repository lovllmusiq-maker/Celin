<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IvoireStay — Résidences Meublées en Côte d'Ivoire</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #faf8f4;
  --bg2: #f2ede4;
  --bg3: #ebe4d6;
  --surface: #ffffff;
  --surface2: #f7f3ec;
  --border: #e5ddd0;
  --border2: #d6ccb8;
  --orange: #e8701a;
  --orange2: #f08832;
  --orange-dim: rgba(232,112,26,0.1);
  --green: #1a7a3c;
  --green2: #22a050;
  --green-dim: rgba(26,122,60,0.1);
  --gold: #c49a2e;
  --gold-dim: rgba(196,154,46,0.12);
  --text: #1a1410;
  --text2: #5a4e3a;
  --text3: #9a8a72;
  --red: #c0392b;
  --radius: 14px;
  --font-head: 'Playfair Display', serif;
  --font-body: 'Plus Jakarta Sans', sans-serif;
  --shadow: 0 4px 24px rgba(26,20,16,0.08);
  --shadow-lg: 0 16px 60px rgba(26,20,16,0.14);
}

- { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }

body {
font-family: var(–font-body);
background: var(–bg);
color: var(–text);
min-height: 100vh;
overflow-x: hidden;
}

::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background: var(–bg2); }
::-webkit-scrollbar-thumb { background: var(–border2); border-radius:3px; }

/* ─── HEADER ─── */
header {
position: fixed; top:0; left:0; right:0; z-index:100;
display:flex; align-items:center; justify-content:space-between;
padding: 0 44px; height:70px;
background: rgba(250,248,244,0.95);
backdrop-filter: blur(20px);
border-bottom: 1px solid var(–border);
box-shadow: 0 1px 20px rgba(26,20,16,0.06);
}

.logo {
font-family: var(–font-head); font-size:24px; font-weight:800;
color: var(–text); display:flex; align-items:center; gap:10px; cursor:pointer;
letter-spacing:-0.5px;
}
.logo-flag { display:flex; gap:2px; align-items:center; }
.flag-stripe { width:8px; height:22px; border-radius:2px; }
.logo em { font-style:normal; color:var(–orange); }

nav { display:flex; align-items:center; gap:6px; }
nav a {
font-size:14px; font-weight:500; color:var(–text2);
padding:7px 16px; border-radius:10px; cursor:pointer;
transition:all .2s; text-decoration:none;
}
nav a:hover { color:var(–orange); background:var(–orange-dim); }

.header-actions { display:flex; align-items:center; gap:10px; }
.btn-outline {
font-family:var(–font-body); font-size:14px; font-weight:600;
padding:9px 20px; border-radius:10px; cursor:pointer;
background:transparent; border:1.5px solid var(–border2); color:var(–text2);
transition:all .2s;
}
.btn-outline:hover { border-color:var(–orange); color:var(–orange); }
.btn-primary {
font-family:var(–font-body); font-size:14px; font-weight:700;
padding:9px 22px; border-radius:10px; cursor:pointer;
background:var(–orange); border:none; color:#fff;
transition:all .2s; box-shadow:0 4px 16px rgba(232,112,26,0.3);
}
.btn-primary:hover { background:var(–orange2); transform:translateY(-1px); box-shadow:0 6px 24px rgba(232,112,26,0.4); }

/* ─── HERO ─── */
.hero {
padding: 110px 44px 70px;
display:flex; flex-direction:column; align-items:center;
text-align:center; position:relative; overflow:hidden;
min-height: 620px; justify-content:center;
}

.hero-bg {
position:absolute; inset:0; z-index:0;
background:
radial-gradient(ellipse 70% 60% at 15% 50%, rgba(232,112,26,0.08) 0%, transparent 70%),
radial-gradient(ellipse 60% 70% at 85% 30%, rgba(26,122,60,0.06) 0%, transparent 70%),
radial-gradient(ellipse 50% 50% at 50% 100%, rgba(196,154,46,0.05) 0%, transparent 60%);
}

.hero-pattern {
position:absolute; inset:0; z-index:0; opacity:.04;
background-image: url(“data:image/svg+xml,%3Csvg width=‘60’ height=‘60’ viewBox=‘0 0 60 60’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cg fill=‘none’ fill-rule=‘evenodd’%3E%3Cg fill=’%23e8701a’ fill-opacity=‘1’%3E%3Cpath d=‘M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z’/%3E%3C/g%3E%3C/g%3E%3C/svg%3E”);
}

.hero-badge {
position:relative; z-index:1;
display:inline-flex; align-items:center; gap:8px;
background:var(–orange-dim); border:1px solid rgba(232,112,26,0.25);
border-radius:100px; padding:6px 18px; font-size:12.5px;
color:var(–orange); font-weight:700; letter-spacing:0.4px;
margin-bottom:28px; animation:fadeUp .6s ease both;
}

@keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
@keyframes shimmer { from{background-position:200% 0} to{background-position:-200% 0} }

h1 {
position:relative; z-index:1;
font-family:var(–font-head); font-size:clamp(38px, 5.5vw, 72px);
font-weight:800; line-height:1.08; letter-spacing:-1.5px;
color:var(–text); max-width:860px;
animation:fadeUp .6s .1s ease both;
}
h1 em { font-style:italic; color:var(–orange); }
h1 span.vert { color:var(–green); }

.hero-sub {
position:relative; z-index:1;
font-size:17px; color:var(–text2); max-width:520px;
line-height:1.75; margin-top:20px; font-weight:400;
animation:fadeUp .6s .2s ease both;
}

/* ─── SEARCH BAR ─── */
.search-wrap {
position:relative; z-index:1; margin-top:40px;
width:100%; max-width:820px;
animation:fadeUp .6s .3s ease both;
}
.search-bar {
display:flex; align-items:center;
background:var(–surface); border:1.5px solid var(–border);
border-radius:18px; padding:7px 7px 7px 24px;
gap:0; box-shadow: var(–shadow-lg);
transition:border-color .2s, box-shadow .2s;
}
.search-bar:focus-within {
border-color:var(–orange);
box-shadow:0 0 0 4px rgba(232,112,26,0.1), var(–shadow-lg);
}
.search-divider { width:1px; height:36px; background:var(–border); flex-shrink:0; margin:0 4px; }
.search-field { display:flex; flex-direction:column; flex:1; min-width:0; padding:0 12px; }
.search-field label { font-size:10px; font-weight:700; color:var(–text3); letter-spacing:.6px; text-transform:uppercase; margin-bottom:2px; }
.search-field input, .search-field select {
background:transparent; border:none; outline:none;
font-family:var(–font-body); font-size:14px; font-weight:500; color:var(–text);
}
.search-field select option { background:var(–surface); color:var(–text); }
.btn-search {
background:var(–orange); border:none; border-radius:13px;
padding:15px 30px; font-family:var(–font-head); font-size:15px;
font-weight:700; color:#fff; cursor:pointer; white-space:nowrap;
transition:all .2s; flex-shrink:0;
box-shadow:0 4px 16px rgba(232,112,26,0.35);
}
.btn-search:hover { background:var(–orange2); transform:scale(1.02); }

.hero-stats {
position:relative; z-index:1;
display:flex; align-items:center; gap:44px; margin-top:40px;
animation:fadeUp .6s .4s ease both;
}
.stat { text-align:center; }
.stat strong { font-family:var(–font-head); font-size:28px; font-weight:800; color:var(–text); display:block; }
.stat span { font-size:12px; color:var(–text3); font-weight:500; }
.stat-sep { width:1px; height:40px; background:var(–border2); }

/* ─── VILLES ─── */
.villes-section { padding:60px 44px 0; }
.villes-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(150px,1fr)); gap:14px; margin-top:28px; }
.ville-card {
background:var(–surface); border:1.5px solid var(–border);
border-radius:16px; padding:20px 16px; text-align:center;
cursor:pointer; transition:all .25s; position:relative; overflow:hidden;
}
.ville-card::before {
content:’’; position:absolute; bottom:0; left:0; right:0; height:3px;
background:linear-gradient(90deg, var(–orange), var(–gold));
transform:scaleX(0); transition:transform .3s; transform-origin:left;
}
.ville-card:hover::before { transform:scaleX(1); }
.ville-card:hover { border-color:var(–orange); transform:translateY(-4px); box-shadow:var(–shadow-lg); }
.ville-emoji { font-size:32px; margin-bottom:8px; display:block; }
.ville-name { font-family:var(–font-head); font-size:15px; font-weight:700; color:var(–text); }
.ville-count { font-size:11.5px; color:var(–text3); margin-top:3px; font-weight:500; }

/* ─── SECTION ─── */
section { padding:72px 44px; }
.section-head {
display:flex; align-items:flex-end; justify-content:space-between;
margin-bottom:36px;
}
.section-head h2 {
font-family:var(–font-head); font-size:32px; font-weight:800;
letter-spacing:-1px; color:var(–text);
}
.section-head p { font-size:14px; color:var(–text3); margin-top:5px; font-weight:400; }
.see-all {
font-size:13.5px; font-weight:700; color:var(–orange); cursor:pointer;
border:1.5px solid rgba(232,112,26,0.3); padding:8px 18px;
border-radius:10px; transition:all .2s; background:transparent;
font-family:var(–font-body);
}
.see-all:hover { background:var(–orange-dim); border-color:var(–orange); }

/* ─── FILTERS ─── */
.filters { display:flex; align-items:center; gap:8px; margin-bottom:28px; flex-wrap:wrap; }
.filter-chip {
padding:8px 18px; border-radius:100px; font-size:13px; font-weight:600;
border:1.5px solid var(–border); background:var(–surface); color:var(–text2);
cursor:pointer; transition:all .2s;
}
.filter-chip:hover, .filter-chip.active {
border-color:var(–orange); color:var(–orange); background:var(–orange-dim);
}

/* ─── RESIDENCE GRID ─── */
.residence-grid {
display:grid; grid-template-columns:repeat(auto-fill, minmax(340px, 1fr));
gap:26px;
}
.res-card {
background:var(–surface); border:1.5px solid var(–border);
border-radius:20px; overflow:hidden; transition:all .28s; cursor:pointer;
box-shadow:var(–shadow);
}
.res-card:hover {
border-color:rgba(232,112,26,0.4); transform:translateY(-6px);
box-shadow: var(–shadow-lg);
}
.card-img {
position:relative; height:220px; overflow:hidden;
background:linear-gradient(135deg, var(–bg2), var(–bg3));
}
.card-img-inner {
width:100%; height:100%;
display:flex; align-items:center; justify-content:center;
font-size:90px; transition:transform .5s;
}
.res-card:hover .card-img-inner { transform:scale(1.06); }

.card-badge {
position:absolute; top:14px; left:14px;
background:rgba(255,255,255,0.92); backdrop-filter:blur(8px);
border-radius:9px; padding:4px 12px;
font-size:11.5px; font-weight:700; color:var(–orange);
}
.card-fav {
position:absolute; top:14px; right:14px;
width:36px; height:36px; background:rgba(255,255,255,0.9);
border-radius:50%; display:flex; align-items:center; justify-content:center;
font-size:17px; cursor:pointer; transition:all .2s; border:none;
box-shadow:0 2px 8px rgba(0,0,0,.12);
}
.card-fav:hover { transform:scale(1.15); background:#fff; }
.card-avail {
position:absolute; bottom:14px; left:14px;
border-radius:8px; padding:4px 12px;
font-size:11.5px; font-weight:700;
}
.avail-yes { background:rgba(26,122,60,0.9); color:#fff; }
.avail-no { background:rgba(192,57,43,0.85); color:#fff; }

.card-body { padding:20px; }
.card-location {
font-size:12px; color:var(–text3); display:flex; align-items:center; gap:4px;
margin-bottom:7px; font-weight:600;
}
.card-name {
font-family:var(–font-head); font-size:19px; font-weight:700;
color:var(–text); letter-spacing:-.3px; margin-bottom:7px;
}
.card-desc { font-size:13.5px; color:var(–text2); line-height:1.65; margin-bottom:14px; }
.card-amenities { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
.amenity {
display:flex; align-items:center; gap:4px;
padding:4px 10px; border-radius:8px; font-size:12px; font-weight:600;
background:var(–surface2); color:var(–text2); border:1px solid var(–border);
}
.card-footer {
display:flex; align-items:center; justify-content:space-between;
padding-top:14px; border-top:1px solid var(–border);
}
.card-rating { display:flex; align-items:center; gap:6px; font-size:13px; }
.stars { color:var(–orange); font-size:13px; }
.rating-val { font-weight:700; color:var(–text); }
.rating-count { color:var(–text3); font-size:12px; }
.card-price { text-align:right; }
.price-from { font-size:10.5px; color:var(–text3); text-transform:uppercase; letter-spacing:.5px; font-weight:600; }
.price-val { font-family:var(–font-head); font-size:22px; font-weight:800; color:var(–orange); }
.price-unit { font-size:12px; color:var(–text3); }

/* ─── MAP ─── */
.map-section { padding:0 44px 72px; }
.map-wrap {
border-radius:24px; overflow:hidden; border:1.5px solid var(–border);
background:var(–surface2); position:relative; height:440px;
display:flex; align-items:center; justify-content:center;
box-shadow:var(–shadow);
}
.map-bg {
position:absolute; inset:0;
background:
linear-gradient(180deg, rgba(26,122,60,0.06) 0%, transparent 40%),
repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(200,185,160,0.3) 49px, rgba(200,185,160,0.3) 50px),
repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(200,185,160,0.3) 49px, rgba(200,185,160,0.3) 50px);
}
.map-ci-outline {
position:absolute; font-size:240px; opacity:.04; user-select:none;
}
.map-center { text-align:center; position:relative; z-index:1; }
.map-center h3 { font-family:var(–font-head); font-size:22px; font-weight:700; color:var(–text); margin-bottom:8px; }
.map-center p { font-size:14px; color:var(–text2); margin-bottom:22px; }
.map-pins { position:absolute; inset:0; pointer-events:none; }
.map-pin {
position:absolute; transform:translate(-50%,-100%);
display:flex; flex-direction:column; align-items:center;
pointer-events:all; cursor:pointer;
}
.pin-body {
background:var(–orange); border-radius:50% 50% 50% 0;
transform:rotate(-45deg); width:46px; height:46px;
display:flex; align-items:center; justify-content:center;
box-shadow:0 6px 20px rgba(232,112,26,0.5); transition:transform .2s;
}
.map-pin:hover .pin-body { transform:rotate(-45deg) scale(1.18); }
.pin-body span { transform:rotate(45deg); font-size:20px; }
.pin-price {
background:var(–surface); border:1.5px solid var(–border);
border-radius:8px; padding:4px 10px; font-size:11px;
font-weight:700; color:var(–orange); margin-top:6px;
white-space:nowrap; opacity:0; transition:opacity .2s;
box-shadow:var(–shadow);
}
.map-pin:hover .pin-price { opacity:1; }

/* ─── GESTIONNAIRES / PROPRIETAIRES ─── */
.owner-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:20px; }
.owner-card {
background:var(–surface); border:1.5px solid var(–border);
border-radius:18px; padding:24px; transition:all .25s; cursor:pointer;
display:flex; flex-direction:column; gap:16px; box-shadow:var(–shadow);
}
.owner-card:hover { border-color:rgba(232,112,26,0.35); transform:translateY(-4px); box-shadow:var(–shadow-lg); }
.owner-top { display:flex; align-items:center; gap:14px; }
.owner-avatar {
width:58px; height:58px; border-radius:50%; flex-shrink:0;
display:flex; align-items:center; justify-content:center;
font-size:28px; font-weight:800; border:2px solid var(–border);
}
.owner-name { font-family:var(–font-head); font-size:17px; font-weight:700; color:var(–text); }
.owner-title { font-size:12px; color:var(–text3); margin-top:2px; font-weight:500; }
.owner-badge { font-size:11.5px; color:var(–green); font-weight:700; margin-top:3px; }
.owner-bio { font-size:13px; color:var(–text2); line-height:1.65; }
.owner-langs { display:flex; gap:6px; flex-wrap:wrap; }
.lang-tag {
padding:3px 10px; border-radius:6px; font-size:11.5px; font-weight:700;
background:var(–orange-dim); color:var(–orange); border:1px solid rgba(232,112,26,0.25);
}
.owner-footer {
display:flex; align-items:center; justify-content:space-between;
padding-top:12px; border-top:1px solid var(–border);
}
.owner-stat { font-size:12px; color:var(–text3); }
.owner-stat strong { color:var(–text); font-weight:700; }
.owner-response { font-size:12px; color:var(–green); font-weight:600; }

/* ─── PRICING ─── */
.pricing-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(290px,1fr)); gap:22px; }
.price-card {
background:var(–surface); border:1.5px solid var(–border);
border-radius:22px; padding:34px 30px; position:relative;
transition:all .25s; box-shadow:var(–shadow);
}
.price-card:hover { transform:translateY(-5px); box-shadow:var(–shadow-lg); }
.price-card.featured {
border-color:var(–orange);
background:linear-gradient(160deg, var(–surface), rgba(232,112,26,0.04));
}
.price-pop {
position:absolute; top:-14px; left:50%; transform:translateX(-50%);
background:var(–orange); color:#fff; font-size:11.5px; font-weight:800;
padding:5px 18px; border-radius:100px; letter-spacing:.5px; white-space:nowrap;
box-shadow:0 4px 16px rgba(232,112,26,0.4);
}
.price-name { font-family:var(–font-head); font-size:14px; font-weight:700; color:var(–text3); text-transform:uppercase; letter-spacing:1px; margin-bottom:10px; }
.price-amount { font-family:var(–font-head); font-size:44px; font-weight:800; color:var(–text); letter-spacing:-2px; line-height:1; }
.price-amount sup { font-size:20px; vertical-align:top; margin-top:10px; display:inline-block; color:var(–text3); font-family:var(–font-body); }
.price-per { font-size:13px; color:var(–text3); margin-top:5px; margin-bottom:26px; font-weight:500; }
.price-features { list-style:none; display:flex; flex-direction:column; gap:11px; margin-bottom:30px; }
.price-features li { display:flex; align-items:center; gap:10px; font-size:14px; color:var(–text2); }
.price-features li::before { content:‘✓’; color:var(–green); font-weight:800; font-size:13px; flex-shrink:0; }
.price-features li.no { color:var(–text3); }
.price-features li.no::before { content:‘✕’; color:var(–border2); }
.btn-price {
width:100%; padding:14px; border-radius:13px;
font-family:var(–font-body); font-size:14.5px; font-weight:700;
cursor:pointer; transition:all .2s;
border:1.5px solid var(–border); background:var(–bg2); color:var(–text);
}
.btn-price:hover { border-color:var(–orange); color:var(–orange); background:var(–orange-dim); }
.price-card.featured .btn-price {
background:var(–orange); color:#fff; border-color:var(–orange);
box-shadow:0 4px 16px rgba(232,112,26,0.35);
}
.price-card.featured .btn-price:hover { background:var(–orange2); }

/* ─── MODAL ─── */
.modal-overlay {
position:fixed; inset:0; z-index:200;
background:rgba(26,20,10,0.75); backdrop-filter:blur(10px);
display:flex; align-items:center; justify-content:center;
padding:20px; opacity:0; pointer-events:none; transition:opacity .3s;
}
.modal-overlay.open { opacity:1; pointer-events:all; }
.modal {
background:var(–surface); border:1.5px solid var(–border);
border-radius:24px; width:100%; max-width:960px;
max-height:92vh; overflow-y:auto;
transform:translateY(40px) scale(.96); transition:transform .35s;
position:relative; box-shadow:0 30px 100px rgba(26,20,10,0.25);
}
.modal-overlay.open .modal { transform:none; }
.modal-close {
position:absolute; top:18px; right:18px; z-index:2;
width:38px; height:38px; border-radius:50%; background:rgba(255,255,255,0.9);
border:1.5px solid var(–border); cursor:pointer;
display:flex; align-items:center; justify-content:center;
font-size:18px; color:var(–text2); transition:all .2s;
box-shadow:var(–shadow);
}
.modal-close:hover { border-color:var(–orange); color:var(–orange); }

.modal-img-zone {
height:300px; position:relative; border-radius:24px 24px 0 0; overflow:hidden;
background:linear-gradient(135deg, var(–bg2), var(–bg3));
display:flex; align-items:center; justify-content:center; font-size:100px;
}
.modal-img-overlay {
position:absolute; inset:0;
background:linear-gradient(to top, rgba(255,255,255,1) 0%, transparent 55%);
}
.modal-img-info {
position:absolute; bottom:22px; left:30px; right:80px;
}
.modal-img-info h2 {
font-family:var(–font-head); font-size:28px; font-weight:800;
color:var(–text); letter-spacing:-.5px;
}
.modal-img-info p { font-size:14px; color:var(–text2); margin-top:5px; font-weight:500; }

