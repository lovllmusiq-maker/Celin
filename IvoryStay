// ─── MODAL ────────────────────────────────────────────────────────────────
let currentPrice = 150000, selectedDay = null;

function openResidence(i) {
  const r = residences[i];
  currentPrice = r.priceNum;
  document.getElementById('modalName').textContent = r.name;
  document.getElementById('modalLocation').textContent = '📍 ' + r.location + '  ·  ' + r.type;
  document.getElementById('modalDesc').textContent = r.desc;
  document.getElementById('modalImg').textContent = r.emoji;
  document.getElementById('modalPrice').textContent = r.price;
  document.getElementById('modalAmenities').innerHTML = r.amenities.map(a=>`<span class="amenity-item">${a}</span>`).join('');
  document.getElementById('modalGallery').innerHTML = (r.galleryEmojis||['🛋','🛏','🍳','🚿']).map(e=>`<div class="gallery-thumb">${e}</div>`).join('');
  const o = owners.find(x=>x.name===r.owner)||owners[0];
  document.getElementById('modalOwner').innerHTML = `
    <div style="display:flex;align-items:center;gap:14px;padding:14px;background:var(--surface2);border-radius:12px;border:1px solid var(--border);">
      <div style="width:48px;height:48px;border-radius:50%;background:${o.bg};display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;">${o.avatar}</div>
      <div>
        <div style="font-weight:700;color:var(--text);font-family:var(--font-head);">${o.name}</div>
        <div style="font-size:12px;color:var(--text3);margin-top:2px;">${o.title} · ${o.badge}</div>
        <div style="font-size:12px;color:var(--green);font-weight:600;margin-top:3px;">⚡ ${o.response}</div>
      </div>
    </div>`;
  document.getElementById('modalReviews').innerHTML = (r.reviewList||[]).map(rv=>`
    <div style="padding:12px 0;border-bottom:1px solid var(--border);">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
        <strong style="font-size:13px;color:var(--text);font-family:var(--font-head);">${rv.user}</strong>
        <span style="color:var(--orange);font-size:13px;">${'★'.repeat(rv.r)}</span>
      </div>
      <div style="font-size:13.5px;color:var(--text2);font-style:italic;">"${rv.txt}"</div>
    </div>`).join('');
  buildCalendar();
  updateSummary();
  document.getElementById('residenceModal').classList.add('open');
}

function closeModal() { document.getElementById('residenceModal').classList.remove('open'); }

// ─── CALENDAR ─────────────────────────────────────────────────────────────
let calYear = new Date().getFullYear(), calMonth = new Date().getMonth();
const monthNames = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

function buildCalendar() {
  const today = new Date();
  const booked = [5, 12, 19, 24];
  document.getElementById('calMonthLabel').textContent = monthNames[calMonth] + ' ' + calYear;
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const offset = firstDay === 0 ? 6 : firstDay - 1;
  const days = new Date(calYear, calMonth + 1, 0).getDate();
  const headers = ['L','M','M','J','V','S','D'];
  let html = headers.map(d => `<div class="cal-day header">${d}</div>`).join('');
  for(let i = 0; i < offset; i++) html += `<div class="cal-day empty"></div>`;
  for(let d = 1; d <= days; d++) {
    const isPast = (calYear === today.getFullYear() && calMonth === today.getMonth() && d < today.getDate()) || calMonth < today.getMonth();
    const isBooked = booked.includes(d);
    const isToday = d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear();
    let cls = 'cal-day ';
    if(isPast||isBooked) cls+='booked'; else cls+='available';
    if(isToday) cls+=' today';
    if(selectedDay===d && !isPast && !isBooked) cls+=' selected';
    html += `<div class="${cls}" onclick="selectDay(this,${d})">${d}</div>`;
  }
  document.getElementById('calendarGrid').innerHTML = html;
}

function prevMonth() { calMonth--; if(calMonth<0){calMonth=11;calYear--;} buildCalendar(); }
function nextMonth() { calMonth++; if(calMonth>11){calMonth=0;calYear++;} buildCalendar(); }
function selectDay(el, d) { selectedDay=d; buildCalendar(); updateSummary(); }

function updateSummary() {
  const dur = parseInt(document.getElementById('dureeSelect')?.value || 1);
  const loyer = currentPrice;
  const caution = loyer;
  const frais = Math.round(loyer * 0.05);
  const total = loyer + caution + frais;
  const fmt = n => n.toLocaleString('fr-FR') + ' FCFA';
  document.getElementById('s-loyer').textContent = fmt(loyer) + ' × ' + dur + ' mois';
  document.getElementById('s-caution').textContent = fmt(caution);
  document.getElementById('s-frais').textContent = fmt(frais);
  document.getElementById('s-total').textContent = fmt(total);
}

function doReservation() {
  if(!selectedDay) { showToast('⚠️','Veuillez sélectionner une date d\'entrée'); return; }
  showToast('🎉','Réservation confirmée ! Vous recevrez un SMS de confirmation.');
  setTimeout(closeModal, 1400);
}

// ─── UTILS ────────────────────────────────────────────────────────────────
function showSection(name) {
  ['home','residences','proprietaires','pricing','monetisation'].forEach(s => {
    const el = document.getElementById('section-'+s);
    if(el) el.style.display = s===name ? '' : 'none';
  });
  window.scrollTo({top:0, behavior:'smooth'});
  if(name==='residences') { renderResidences(); renderMapPins(); }
  if(name==='proprietaires') renderOwners();
  if(name==='pricing') {
    renderPricing(pricingProprio,'pgProprio');
    renderPricing(pricingLocataire,'pgLocataire');
    renderPricing(pricingAnnonceur,'pgAnnonceur');
  }
}

function toggleFilter(el) {
  document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
}

function toggleFav(el) {
  el.textContent = el.textContent==='🤍' ? '❤️' : '🤍';
  showToast('❤️','Résidence ajoutée à vos favoris');
}

function activateGeo() {
  showToast('📍','Géolocalisation activée — résidences proches de vous !');
  document.getElementById('mapCenter').style.opacity='0';
}

function switchTab(el, id) {
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['tab-proprio','tab-locataire','tab-annonceur'].forEach(t=>{
    document.getElementById(t).style.display = t===id?'':'none';
  });
}

let toastTimer;
function showToast(icon, msg) {
  const t = document.getElementById('toast');
  document.getElementById('toastIcon').textContent = icon;
  document.getElementById('toastMsg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), 3200);
}

document.getElementById('residenceModal').addEventListener('click', e=>{
  if(e.target===document.getElementById('residenceModal')) closeModal();
});

showSection('home');
</script>

