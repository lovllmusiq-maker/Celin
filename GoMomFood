function switchAuthTab(tab) {
  document.getElementById('loginForm').style.display    = tab === 'login'    ? 'block' : 'none';
  document.getElementById('registerForm').style.display = tab === 'register' ? 'block' : 'none';
  document.getElementById('loginTab').classList.toggle('active',    tab === 'login');
  document.getElementById('registerTab').classList.toggle('active', tab === 'register');
}
function togglePwd(id, btn) {
  const el = document.getElementById(id);
  el.type = el.type === 'password' ? 'text' : 'password';
  btn.textContent = el.type === 'password' ? '👁️' : '🙈';
}
function doLogin() {
  const email = document.getElementById('loginEmail').value.trim().toLowerCase();
  const pwd   = document.getElementById('loginPwd').value;
  const errEl = document.getElementById('loginErr');
  if (!email || !pwd) { errEl.textContent = 'Veuillez remplir tous les champs.'; return; }
  const users = loadUsers();
  const user  = users[email];
  if (!user || user.pwd !== btoa(pwd)) { errEl.textContent = '❌ Email ou code d\'accès incorrect.'; return; }
  errEl.textContent = '';
  currentUser = { ...user }; delete currentUser.pwd;
  saveSession(currentUser); updateAccountTab(); updateAdminTab();
  renderAccount(); showToast(`✅ Bienvenue ${currentUser.prenom} !`);
}
function doRegister() {
  const prenom  = document.getElementById('regPrenom').value.trim();
  const nom     = document.getElementById('regNom').value.trim();
  const email   = document.getElementById('regEmail').value.trim().toLowerCase();
  const tel     = document.getElementById('regTel').value.trim();
  const adresse = document.getElementById('regAdresse').value.trim();
  const cp      = document.getElementById('regCp').value.trim();
  const ville   = document.getElementById('regVille').value.trim();
  const pwd     = document.getElementById('regPwd').value;
  const pwd2    = document.getElementById('regPwd2').value;
  const errEl   = document.getElementById('registerErr');
  if (!prenom||!nom||!email||!tel||!adresse||!cp||!ville||!pwd) { errEl.textContent = '⚠️ Tous les champs sont obligatoires.'; return; }
  if (pwd.length < 6)  { errEl.textContent = '⚠️ Code d\'accès : minimum 6 caractères.'; return; }
  if (pwd !== pwd2)    { errEl.textContent = '⚠️ Les codes d\'accès ne correspondent pas.'; return; }
  const users = loadUsers();
  if (users[email]) { errEl.textContent = '❌ Cet email est déjà utilisé.'; return; }
  const newUser = { prenom, nom, email, tel, adresse, codePostal:cp, ville, pwd:btoa(pwd), subscription:null, isAdmin:false };
  users[email] = newUser; saveUsers(users);
  currentUser = { prenom, nom, email, tel, adresse, codePostal:cp, ville, subscription:null, isAdmin:false };
  saveSession(currentUser); updateAccountTab(); updateAdminTab();
  renderAccount(); showToast(`🎉 Compte créé ! Bienvenue ${prenom} !`);
}
function logout() { clearSession(); renderAccount(); showToast('👋 À bientôt !'); }
