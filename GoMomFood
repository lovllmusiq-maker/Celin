<!-- ADMIN LOGIN MODAL -->

<div class="order-modal" id="adminLoginModal">
  <div class="order-modal-box" style="max-width:380px;">
    <div style="text-align:center;margin-bottom:6px;">
      <div style="font-size:56px;">🔐</div>
      <h2 class="modal-title">Espace Administrateur</h2>
      <p style="font-size:12.5px;color:#9a8070;margin-bottom:20px;">Accès restreint — Propriétaire uniquement</p>
    </div>
    <div class="form-group">
      <label>Code secret administrateur</label>
      <div class="input-eye-wrap">
        <input type="password" id="adminCode" placeholder="••••••••••" autocomplete="off"
          onkeyup="if(event.key==='Enter') doAdminLogin()">
        <button class="eye-btn" type="button" onclick="togglePwd('adminCode',this)">👁️</button>
      </div>
    </div>
    <div class="auth-error" id="adminCodeErr"></div>
    <div class="modal-btns" style="margin-top:16px;">
      <button class="modal-btn-cancel" onclick="closeAdminLogin()">Annuler</button>
      <button class="modal-btn-confirm" onclick="doAdminLogin()" style="background:var(--brown);">🔐 Accéder</button>
    </div>
    <p style="text-align:center;font-size:11px;color:#C8A97A;margin-top:12px;">
      🔒 Accès sécurisé — Données chiffrées
    </p>
  </div>
</div>

<!-- SUBSCRIPTION PAYMENT MODAL -->

<div class="order-modal" id="subPayModal">
  <div class="order-modal-box">
    <div class="modal-icon">⭐</div>
    <h2 class="modal-title" id="subPayTitle">Abonnement</h2>
    <div class="sub-pay-amount" id="subPayAmount"></div>
    <div class="pay-secure" style="margin:8px 0;">🔒 Paiement sécurisé SSL — Renouvellement mensuel</div>
    <div class="form-group"><label>Nom sur la carte</label>
      <input type="text" id="subCardName" placeholder="JEAN DUPONT"></div>
    <div class="form-group"><label>Numéro de carte</label>
      <input type="text" id="subCardNum" placeholder="1234 5678 9012 3456" maxlength="19"
        oninput="this.value=this.value.replace(/\D/g,'').replace(/(.{4})/g,'$1 ').trim()"></div>
    <div class="form-row">
      <div class="form-group"><label>Expiration</label>
        <input type="text" id="subCardExp" placeholder="MM/AA" maxlength="5"
          oninput="this.value=this.value.replace(/\D/g,'').replace(/^(\d{2})(\d)/,'$1/$2')"></div>
      <div class="form-group"><label>CVV</label>
        <input type="text" id="subCardCvv" placeholder="123" maxlength="3"
          oninput="this.value=this.value.replace(/\D/g,'')"></div>
    </div>
    <div class="auth-error" id="subPayErr"></div>
    <div class="modal-btns">
      <button class="modal-btn-cancel" onclick="closeSubPay()">Annuler</button>
      <button class="modal-btn-confirm" id="subPayBtn">💳 Souscrire</button>
    </div>
  </div>
</div>

