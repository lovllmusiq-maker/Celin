function closeSubPay() { document.getElementById('subPayModal').classList.remove('show'); }
function processSubPayment(plan) {
  const num  = document.getElementById('subCardNum').value.replace(/\s/g,'');
  const exp  = document.getElementById('subCardExp').value;
  const cvv  = document.getElementById('subCardCvv').value;
  const name = document.getElementById('subCardName').value.trim();
  const err  = document.getElementById('subPayErr');
  if (num.length < 16 || !exp || cvv.length < 3 || !name) { err.textContent = '⚠️ Veuillez remplir tous les champs.'; return; }
  err.textContent = '';
  const btn = document.getElementById('subPayBtn');
  btn.textContent = '⏳ Traitement...'; btn.disabled = true;
  setTimeout(() => {
    btn.textContent = '💳 Souscrire'; btn.disabled = false;
    closeSubPay();
    const users = loadUsers();
    const sub = { id:plan.id, label:plan.label, count:plan.count, remaining:plan.count, price:plan.price.toFixed(2), since:new Date().toISOString() };
    users[currentUser.email].subscription = sub; saveUsers(users);
    currentUser.subscription = sub; saveSession(currentUser);
    showToast(`🎉 Abonnement ${plan.label} activé !`); renderAccount();
  }, 2000);
}

