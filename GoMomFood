@media (max-width: 600px) {
  .form-row { flex-direction: column; gap: 0; }
}

/* ── GPS ── */
.addr-wrap { display: flex; gap: 8px; align-items: stretch; }
.addr-wrap input { flex: 1; }
.gps-btn {
  padding: 0 14px;
  background: var(--green); color: white; border: none; border-radius: 12px;
  font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 12px;
  cursor: pointer; white-space: nowrap; transition: background 0.2s;
  display: flex; align-items: center; gap: 4px;
}
.gps-btn:hover { background: #1e5c38; }
.gps-btn:active { transform: scale(0.97); }
.gps-status { font-size: 12px; margin-top: 5px; min-height: 16px; line-height: 1.4; }
.gps-loading { color: #E67E22; animation: pulse 1s infinite; }
.gps-ok { color: #2D7A4F; font-weight: 700; }
