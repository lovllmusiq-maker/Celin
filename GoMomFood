var currentSubPlan = null;

function showSubPayment(plan) {
  currentSubPlan = plan;
  document.getElementById('subPayModal').classList.add('show');
  document.getElementById('subPayTitle').textContent  = 'Abonnement ' + plan.label;
  document.getElementById('subPayAmount').textContent = plan.price.toFixed(2) + ' € / mois';
  ['subCardName','subCardNum','subCardExp','subCardCvv','subPaypalEmail'].forEach(function(id){
    var el = document.getElementById(id); if(el) el.value = '';
  });
  document.getElementById('subPayErr').textContent = '';
  switchSubTab('card');
}

function switchSubTab(tab) {
  var cardDiv   = document.getElementById('subCardFormDiv');
  var ppDiv     = document.getElementById('subPaypalDiv');
  var cardBtn   = document.getElementById('subCardTabBtn');
  var ppBtn     = document.getElementById('subPaypalTabBtn');
  var payBtn    = document.getElementById('subPayBtn');
  if (cardDiv)  cardDiv.style.display  = tab === 'card'   ? 'block' : 'none';
  if (ppDiv)    ppDiv.style.display    = tab === 'paypal' ? 'block' : 'none';
  if (cardBtn)  cardBtn.classList.toggle('active',  tab === 'card');
  if (ppBtn)    ppBtn.classList.toggle('active', tab === 'paypal');
  if (!payBtn) return;
  if (tab === 'paypal') {
    payBtn.textContent = '🅿️ Payer avec PayPal';
    payBtn.onclick = function() { processSubPaypal(currentSubPlan); };
  } else {
    payBtn.textContent = '💳 Souscrire maintenant';
    payBtn.onclick = function() { processSubPayment(currentSubPlan); };
  }
}

function processSubPaypal(plan) {
  var emailEl = document.getElementById('subPaypalEmail');
  var err     = document.getElementById('subPayErr');
  var email   = emailEl ? emailEl.value.trim() : '';
  if (!email || !email.includes('@')) { err.textContent = '⚠️ Veuillez entrer une adresse PayPal valide.'; return; }
  err.textContent = '';
  var btn = document.getElementById('subPayBtn');
  btn.textContent = '⏳ Connexion PayPal...'; btn.disabled = true;
  setTimeout(function() {
    btn.textContent = '🅿️ Payer avec PayPal'; btn.disabled = false;
    closeSubPay();
    activateSubscription(plan);
  }, 2200);
}

function activateSubscription(plan) {
  var users = loadUsers();
  var u = users[currentUser.email];
  if (!u) return;
  u.subscription = {
    id: plan.id, label: plan.label, count: plan.count,
    remaining: plan.count, price: plan.price.toFixed(2),
    since: new Date().toISOString()
  };
  users[currentUser.email] = u;
  saveUsers(users);
  currentUser.subscription = u.subscription;
  saveSession(currentUser);
  showToast('🎉 Abonnement ' + plan.label + ' activé !');
  renderAccount();
}

// Card brand detection on number input
setTimeout(function() {
  var el = document.getElementById('subCardNum');
  if (el) el.addEventListener('input', function() {
    var v = this.value.replace(/\s/g,'');
    var brandEl = document.getElementById('subCardBrand');
    if (!brandEl) return;
    if      (v.startsWith('4')) brandEl.textContent = '💳';
    else if (v.startsWith('5')) brandEl.textContent = '🟠';
    else if (v.startsWith('3')) brandEl.textContent = '🟢';
    else brandEl.textContent = '';
  });
}, 500);

// ═══════════════════════════════════════════════════════
// GPS
// ═══════════════════════════════════════════════════════
function detectGPS(prefix) {
  const statusEl   = document.getElementById(prefix + 'GpsStatus');
  const addrInput  = document.getElementById(prefix === 'reg' ? 'regAdresse' : 'editAdresse');
  const cpInput    = document.getElementById(prefix === 'reg' ? 'regCp'      : 'editCp');
  const villeInput = document.getElementById(prefix === 'reg' ? 'regVille'   : 'editVille');
  if (!navigator.geolocation) { statusEl.innerHTML = '❌ Géolocalisation non supportée.'; return; }
  statusEl.innerHTML = '<span class="gps-loading">📡 Localisation en cours...</span>';
  navigator.geolocation.getCurrentPosition(async (pos) => {
    statusEl.innerHTML = '<span class="gps-loading">🔍 Identification de l\'adresse...</span>';
    try {
      const r = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&addressdetails=1&accept-language=fr`);
      const d = await r.json(); const a = d.address || {};
      const street = ((a.house_number||'')+' '+(a.road||a.pedestrian||'')).trim();
      const cp = a.postcode||''; const city = a.city||a.town||a.village||'';
      if (street) addrInput.value = street;
      if (cp)     cpInput.value   = cp;
      if (city)   villeInput.value = city;
      statusEl.innerHTML = `<span class="gps-ok">✅ ${street}, ${cp} ${city}</span>`;
      setTimeout(() => { statusEl.innerHTML = ''; }, 4000);
    } catch(e) { statusEl.innerHTML = '⚠️ Impossible d\'identifier l\'adresse.'; }
  }, (err) => { statusEl.innerHTML = '❌ Accès à la position refusé.'; }, { enableHighAccuracy:true, timeout:10000, maximumAge:0 });
}

// ═══════════════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════════════
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

// ═══════════════════════════════════════════════════════
// INIT
