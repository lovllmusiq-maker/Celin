<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Go Mom Food</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --brown: #6B3A2A;
    --tan: #C8A97A;
    --sand: #E8D5A3;
    --cream: #F5EDD8;
    --green: #2D7A4F;
    --red: #C0392B;
    --orange: #E67E22;
    --dark: #2C1810;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Nunito', sans-serif; background: var(--cream); color: var(--dark); min-height: 100vh; }

.header { background: var(–brown); padding: 0 0 0; text-align: center; position: relative; overflow: hidden; }
.header::before {
content: ‘’; position: absolute; top: 0; left: 0; right: 0; height: 6px;
background: repeating-linear-gradient(90deg,
var(–red) 0px,var(–red) 20px,var(–orange) 20px,var(–orange) 40px,
var(–green) 40px,var(–green) 60px,var(–tan) 60px,var(–tan) 80px,
#3a6fb5 80px,#3a6fb5 100px);
}
.mask-icon { font-size: 52px; margin: 28px 0 6px; display: block; }
.logo-wrap { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 2px; }
.go-badge { background: var(–red); color: white; font-family: ‘Playfair Display’,serif; font-size: 36px; font-weight: 900; padding: 4px 18px; border-radius: 8px; letter-spacing: 2px; }
.truck-icon { font-size: 34px; }
.logo-mom { color: var(–green); font-family: ‘Playfair Display’,serif; font-size: 48px; font-weight: 900; letter-spacing: 4px; line-height: 1; }
.logo-food { color: var(–orange); font-family: ‘Playfair Display’,serif; font-size: 48px; font-weight: 900; letter-spacing: 8px; line-height: 1; }
.kente-strip { height: 13px; background: repeating-linear-gradient(90deg, var(–red) 0px,var(–red) 16px,var(–orange) 16px,var(–orange) 32px,var(–green) 32px,var(–green) 48px,var(–tan) 48px,var(–tan) 64px,#3a6fb5 64px,#3a6fb5 80px,var(–dark) 80px,var(–dark) 88px); margin: 14px 0 0; }

.tabs { display: flex; justify-content: center; gap: 8px; padding: 16px 16px 18px; flex-wrap: wrap; background: var(–brown); }
.tab { background: rgba(255,255,255,0.12); color: var(–sand); border: 2px solid rgba(200,169,122,0.3); padding: 8px 18px; border-radius: 50px; font-family: ‘Nunito’,sans-serif; font-weight: 700; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.tab-admin { display: none !important; }
.tab-admin.admin-visible { display: inline-block !important; }
.tab:hover, .tab.active { background: var(–orange); border-color: var(–orange); color: white; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(230,126,34,0.4); }

main { max-width: 960px; margin: 0 auto; padding: 32px 16px 80px; }
.section { display: none; }
.section.active { display: block; }

.section-title { font-family: ‘Playfair Display’,serif; font-size: 26px; font-weight: 700; color: var(–brown); text-align: center; margin-bottom: 28px; }
.section-title::after { content: ‘’; display: block; width: 56px; height: 4px; background: var(–orange); border-radius: 2px; margin: 8px auto 0; }

/* MENU CARDS */
.menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 22px; }

.card { background: white; border-radius: 22px; overflow: hidden; box-shadow: 0 4px 20px rgba(107,58,42,0.1); transition: transform 0.25s, box-shadow 0.25s; animation: fadeUp 0.4s ease both; cursor: pointer; }
.card:hover { transform: translateY(-6px); box-shadow: 0 14px 38px rgba(107,58,42,0.18); }
@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

.card-img-wrap {
height: 180px; overflow: hidden; position: relative;
background: linear-gradient(135deg, var(–sand), var(–tan));
}
.card-img-wrap img {
width: 100%; height: 100%; object-fit: cover;
transition: transform 0.4s ease;
}
.card:hover .card-img-wrap img { transform: scale(1.07); }
.price-badge { position: absolute; top: 12px; right: 12px; background: var(–brown); color: var(–sand); font-weight: 800; font-size: 14px; padding: 4px 14px; border-radius: 50px; box-shadow: 0 2px 8px rgba(0,0,0,0.25); }

.card-body { padding: 16px 18px 6px; }
.card-name { font-family: ‘Playfair Display’,serif; font-size: 19px; font-weight: 700; color: var(–brown); margin-bottom: 6px; }
.card-desc { font-size: 12.5px; color: #7a6050; line-height: 1.6; }

.add-btn { display: block; width: calc(100% - 32px); margin: 10px 16px 16px; background: var(–orange); color: white; border: none; border-radius: 50px; padding: 10px; font-family: ‘Nunito’,sans-serif; font-weight: 800; font-size: 14px; cursor: pointer; transition: background 0.2s, transform 0.15s; }
.add-btn:hover { background: var(–brown); transform: scale(1.02); }

/* DRINKS */
.drinks-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; }
.drink-card { background: white; border-radius: 18px; padding: 22px 14px; text-align: center; box-shadow: 0 4px 16px rgba(107,58,42,0.1); transition: transform 0.2s; cursor: pointer; animation: fadeUp 0.4s ease both; }
.drink-card:hover { transform: translateY(-4px); }
.drink-card .emoji { font-size: 40px; margin-bottom: 8px; }
.drink-card .drink-photo { width: 90px; height: 110px; object-fit: cover; border-radius: 12px; margin-bottom: 8px; display: block; margin-left: auto; margin-right: auto; }
.drink-card .name { font-weight: 700; color: var(–brown); font-size: 15px; }
.drink-card .sub { font-size: 11.5px; color: #9a8070; margin-top: 2px; }
.drink-card .price { font-weight: 800; color: var(–orange); margin-top: 10px; font-size: 17px; }

/* CART */
.cart-empty { text-align: center; padding: 60px 20px; color: #9a8070; font-size: 16px; }
.cart-empty .big { font-size: 56px; margin-bottom: 12px; }
.cart-item { background: white; border-radius: 16px; padding: 14px 18px; margin-bottom: 12px; display: flex; align-items: center; gap: 14px; box-shadow: 0 2px 12px rgba(107,58,42,0.08); animation: fadeUp 0.3s ease both; }
.cart-item img { width: 56px; height: 56px; border-radius: 12px; object-fit: cover; flex-shrink: 0; }
.cart-item .ci-emoji { font-size: 30px; flex-shrink: 0; }
.cart-item .ci-info { flex: 1; }
.cart-item .ci-name { font-weight: 700; color: var(–brown); font-size: 14px; }
.cart-item .ci-price { font-size: 12.5px; color: #9a8070; margin-top: 2px; }
.qty-ctrl { display: flex; align-items: center; gap: 10px; }
.qty-btn { background: var(–sand); border: none; width: 30px; height: 30px; border-radius: 50%; font-size: 18px; font-weight: 700; cursor: pointer; color: var(–brown); transition: background 0.15s; }
.qty-btn:hover { background: var(–tan); }
.qty-num { font-weight: 800; font-size: 16px; min-width: 20px; text-align: center; }
.total-box { background: var(–brown); color: white; border-radius: 20px; padding: 22px 26px; margin-top: 24px; display: flex; justify-content: space-between; align-items: center; }
.total-label { font-size: 13px; opacity: 0.75; margin-bottom: 4px; }
.total-amount { font-family: ‘Playfair Display’,serif; font-size: 38px; font-weight: 700; color: var(–orange); }
.order-btn { display: block; width: 100%; margin-top: 14px; background: var(–green); color: white; border: none; border-radius: 50px; padding: 16px; font-family: ‘Nunito’,sans-serif; font-weight: 800; font-size: 16px; cursor: pointer; transition: background 0.2s; letter-spacing: 0.5px; }
.order-btn:hover { background: #1e5c38; }

/* CONTACT */
.contact-card { background: white; border-radius: 24px; padding: 36px; box-shadow: 0 4px 24px rgba(107,58,42,0.1); text-align: center; max-width: 460px; margin: 0 auto; }
.contact-card h2 { font-family: ‘Playfair Display’,serif; font-size: 24px; color: var(–brown); margin-bottom: 26px; }
.contact-row { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; background: var(–cream); border-radius: 14px; padding: 14px 18px; text-align: left; }
.contact-row-clickable { cursor: pointer; transition: background 0.18s, transform 0.15s; user-select: none; }
.contact-row-clickable:hover { background: #EDD9B0; }
.contact-row-clickable:active { transform: scale(0.98); background: #E0C98A; }
.contact-icon { font-size: 26px; flex-shrink: 0; }
.contact-label { font-size: 11px; color: #9a8070; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
.contact-value { font-weight: 700; color: var(–dark); font-size: 14px; margin-top: 2px; }
.contact-value a { color: var(–orange); text-decoration: none; }

/* BADGE */
.nav-cart-wrap { position: relative; display: inline-flex; align-items: center; }
.cart-badge { position: absolute; top: -7px; right: -7px; background: var(–red); color: white; border-radius: 50%; width: 20px; height: 20px; font-size: 11px; font-weight: 800; display: none; align-items: center; justify-content: center; pointer-events: none; }

/* TOAST */
.toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(–green); color: white; padding: 12px 28px; border-radius: 50px; font-weight: 700; font-size: 14px; box-shadow: 0 8px 24px rgba(0,0,0,0.2); transition: transform 0.3s; z-index: 999; pointer-events: none; white-space: nowrap; }
.toast.show { transform: translateX(-50%) translateY(0); }

@media (max-width: 600px) {
.logo-mom, .logo-food { font-size: 38px; }
.go-badge { font-size: 26px; }
main { padding: 20px 10px 60px; }
.menu-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
.card-img-wrap { height: 130px; }
.card-name { font-size: 15px; }
.card-desc { display: none; }
.add-btn { font-size: 12px; padding: 8px; }
}

.pay-badge { background:#f0f7f0; color:#2D7A4F; font-size:11px; font-weight:700; padding:4px 10px; border-radius:20px; border:1px solid #c8e6c9; }
</style>

<script defer>


// Make functions available globally before DOM loads
// All function declarations are hoisted automatically

const PHOTOS = {"tieb_poulet": "data:image/jpeg;base64,", "tieb_poisson": "data:image/jpeg;base64,", "sauce_graine": "data:image/jpeg;base64,", "attieke_poisson": "data:image/jpeg;base64,", "poulet_yassa": "data:image/jpeg;base64,", "poulet_mafe": "data:image/jpeg;base64,", "poisson_braise": "data:image/jpeg;base64,", "poulet_braise": "data:image/jpeg;base64,", "alloco": "data:image/jpeg;base64,", "attieke": "data:image/jpeg;base64,", "pastel": "data:image/jpeg;base64,", "aller_retour": "data:image/jpeg;base64,", "blofoto": "data:image/jpeg;base64,", "degue": "data:image/jpeg;base64,", "gingembre": "data:image/jpeg;base64,", "bissap": "data:image/jpeg;base64,", "canettes": "data:image/jpeg;base64,", "eauplate": "data:image/jpeg;base64,", "eaugaz": "data:image/jpeg;base64,", "coca": "data:image/jpeg;base64,", "oasis": "data:image/jpeg;base64,", "lipton": "data:image/jpeg;base64,", "sprite": "data:image/jpeg;base64,", "cristaline": "data:image/jpeg;base64,"};

var cart = [];

// ═══════════════════════════════════════════════════════
// SECTION NAVIGATION
// ═══════════════════════════════════════════════════════
function showSection(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  const sec = document.getElementById(id);
  if (sec) sec.classList.add('active');
  document.querySelectorAll('.tab').forEach(t => {
    if (t.getAttribute('onclick') === `showSection('${id}')`) t.classList.add('active');
  });
  if (id === 'commande') renderCart();
  if (id === 'compte')   renderAccount();
  if (id === 'admin')    renderAdmin();
}

// ═══════════════════════════════════════════════════════
// CART
// ═══════════════════════════════════════════════════════
function addToCart(name, price, photoKey) {
  const existing = cart.find(i => i.name === name);
  if (existing) existing.qty++;
  else cart.push({ name, price, photoKey, qty: 1 });
  updateBadge();
  showToast('✓ ' + name + ' ajouté !');
}
function updateBadge() {
  const total = cart.reduce((s,i) => s + i.qty, 0);
  const badge = document.getElementById('cartBadge');
  badge.textContent = total;
  badge.style.display = total > 0 ? 'flex' : 'none';
}
function renderCart() {
  const el = document.getElementById('cartContent');
  if (cart.length === 0) {
    el.innerHTML = `<div class="cart-empty"><div class="big">🛒</div>Votre panier est vide.<br>Ajoutez des plats depuis le menu !</div>`;
    return;
  }
  const total = cart.reduce((s,i) => s + i.price * i.qty, 0);
  let html = cart.map((item, idx) => {
    const imgHtml = item.photoKey && PHOTOS[item.photoKey]
      ? `<img src="${PHOTOS[item.photoKey]}" alt="${item.name}">`
      : `<span class="ci-emoji">🥤</span>`;
    return `<div class="cart-item">
        ${imgHtml}
        <div class="ci-info">
          <div class="ci-name">${item.name}</div>
          <div class="ci-price">${item.price.toFixed(2)} € × ${item.qty} = ${(item.price * item.qty).toFixed(2)} €</div>
        </div>
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="changeQty(${idx}, -1)">−</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${idx}, 1)">+</button>
        </div>
      </div>`;
  }).join('');
  html += `<div class="total-box">
      <div><div class="total-label">Total commande</div><div class="total-amount">${total.toFixed(2)} €</div></div>
      <span style="font-size:36px">🧾</span>
    </div>
    <button class="order-btn" onclick="placeOrder()">🛍️ Valider la commande</button>`;
  el.innerHTML = html;
}
function changeQty(idx, delta) {
  cart[idx].qty += delta;
  if (cart[idx].qty <= 0) cart.splice(idx, 1);
  updateBadge(); renderCart();
}

// ═══════════════════════════════════════════════════════
// ORDER FLOW
// ═══════════════════════════════════════════════════════
function placeOrder() {
  if (cart.length === 0) return;
  if (!currentUser) { showToast('👤 Connectez-vous pour commander !'); showSection('compte'); return; }
  showOrderModal();
}
function showOrderModal() {
  const total = cart.reduce((s,i) => s + i.price * i.qty, 0).toFixed(2);
  document.getElementById('modalItems').textContent = cart.map(i => `• ${i.qty}× ${i.name} (${(i.price*i.qty).toFixed(2)} €)`).join('\n');
  document.getElementById('modalTotal').textContent = total + ' €';
  if (currentUser) document.getElementById('modalAddr').textContent = `📦 ${currentUser.prenom} ${currentUser.nom} — ${currentUser.adresse}, ${currentUser.codePostal} ${currentUser.ville}`;
  document.getElementById('orderModal').classList.add('show');
}
function confirmOrder() { document.getElementById('orderModal').classList.remove('show'); showPaymentModal(); }
function cancelOrder()  { document.getElementById('orderModal').classList.remove('show'); }

// ═══════════════════════════════════════════════════════
// PAYMENT
// ═══════════════════════════════════════════════════════
function showPaymentModal()  { document.getElementById('paymentModal').classList.add('show'); }
function closePaymentModal() { document.getElementById('paymentModal').classList.remove('show'); }
function switchPayTab(tab) {
  document.getElementById('payCardForm').style.display  = tab === 'card'  ? 'block' : 'none';
  document.getElementById('payPhoneForm').style.display = tab === 'phone' ? 'block' : 'none';
  document.getElementById('payCardTab').classList.toggle('active',  tab === 'card');
  document.getElementById('payPhoneTab').classList.toggle('active', tab === 'phone');
}
function processPayment() {
  const num  = document.getElementById('cardNum').value.replace(/\s/g,'');
  const exp  = document.getElementById('cardExp').value;
  const cvv  = document.getElementById('cardCvv').value;
  const name = document.getElementById('cardName').value.trim();
  if (num.length < 16 || !exp || cvv.length < 3 || !name) {
    document.getElementById('payErr').textContent = '⚠️ Veuillez remplir tous les champs correctement.'; return;
  }
  document.getElementById('payErr').textContent = '';
  const btn = document.getElementById('payBtn');
  btn.textContent = '⏳ Traitement...'; btn.disabled = true;
  setTimeout(() => {
    closePaymentModal(); btn.textContent = '💳 Payer maintenant'; btn.disabled = false;
    finishOrder('card');
  }, 2000);
}
function payByPhone_real() {
  closePaymentModal();
  sendWhatsApp('livraison');
  saveOrderRecord('livraison');
  cart = []; updateBadge(); showConfirmation();
}
function finishOrder(paymentMethod) {
  saveOrderRecord(paymentMethod || 'card');
  sendWhatsApp(paymentMethod);
  cart = []; updateBadge(); showConfirmation();
}
function sendWhatsApp(paymentMethod) {
  const total = cart.reduce((s,i) => s + i.price * i.qty, 0).toFixed(2);
  const items = cart.map(i => `${i.qty}x ${i.name}`).join(', ');
  const addr  = currentUser ? `${currentUser.adresse}, ${currentUser.codePostal} ${currentUser.ville}` : '';
  const pay   = paymentMethod === 'livraison' ? '💳 Paiement à la livraison' : '✅ Payé en ligne';
  const sub   = currentUser && currentUser.subscription ? `\n⭐ Abonnement : ${currentUser.subscription.label} (${currentUser.subscription.remaining} restante(s))` : '';
  const msg = encodeURIComponent(`🍽️ NOUVELLE COMMANDE GO MOM FOOD\n\n👤 ${currentUser ? currentUser.prenom+' '+currentUser.nom : 'Invité'}\n📞 ${currentUser ? currentUser.tel : ''}\n📦 ${addr}\n\n${items}\nTotal : ${total} €\n\n${pay}${sub}`);
  window.open(`https://wa.me/33685553026?text=${msg}`, '_blank');
}
function showConfirmation() {
  document.getElementById('confirmScreen').classList.add('show');
  setTimeout(() => { document.getElementById('confirmScreen').classList.remove('show'); showSection('plats'); }, 4000);
}

// ═══════════════════════════════════════════════════════
// STORAGE
// ═══════════════════════════════════════════════════════
var currentUser = null;
const ADMIN_CODE = 'GOMOM2025';
const PLANS = [
  { id:'plan4',  label:'4 commandes',  count:4,  price:19.90, popular:false },
  { id:'plan8',  label:'8 commandes',  count:8,  price:34.90, popular:true  },
  { id:'plan12', label:'12 commandes', count:12, price:49.90, popular:false },
  { id:'plan16', label:'16 commandes', count:16, price:62.90, popular:false },
  { id:'plan20', label:'20 commandes', count:20, price:74.90, popular:false },
];
function loadUsers()    { try { return JSON.parse(localStorage.getItem('gmf_users') || '{}'); } catch(e) { return {}; } }
function saveUsers(u)   { localStorage.setItem('gmf_users', JSON.stringify(u)); }
function loadOrders()   { try { return JSON.parse(localStorage.getItem('gmf_orders') || '[]'); } catch(e) { return []; } }
function saveOrders(o)  { localStorage.setItem('gmf_orders', JSON.stringify(o)); }
function saveSession(u) { localStorage.setItem('gmf_session', JSON.stringify(u)); }
function clearSession() { localStorage.removeItem('gmf_session'); currentUser = null; updateAccountTab(); updateAdminTab(); }
function loadCurrentUser() {
  try {
    const u = JSON.parse(localStorage.getItem('gmf_session') || 'null');
    if (u) {
      u.isAdmin = false; // Admin access never persists across reloads
      currentUser = u;
      updateAccountTab();
      updateAdminTab();
    }
  } catch(e) {}
}

// ═══════════════════════════════════════════════════════
// TAB HELPERS
// ═══════════════════════════════════════════════════════
function updateAccountTab() {
  const tab = document.getElementById('accountTab');
  if (tab) tab.textContent = currentUser ? `👤 ${currentUser.prenom}` : '👤 Mon Compte';
}
function updateAdminTab() {
  const tab = document.getElementById('adminTab');
  if (!tab) return;
  tab.style.display = (currentUser && currentUser.isAdmin) ? 'inline-block' : 'none';
}

// ═══════════════════════════════════════════════════════
// ACCOUNT RENDER
// ═══════════════════════════════════════════════════════
function renderAccount() {
  var el    = document.getElementById('accountContent');
  var title = document.getElementById('accountSectionTitle');
  if (!el) return;

  if (currentUser && currentUser.email !== '__admin__') {
    // ── LOGGED IN ──
    title.textContent = 'Mon Compte';
    var sub = currentUser.subscription;
    var subHtml = '';
    if (sub) {
      subHtml = '<div class="sub-badge active-sub">'
        + '<span class="sub-badge-icon">⭐</span>'
        + '<div><div class="sub-badge-name">Abonnement ' + sub.label + '</div>'
        + '<div class="sub-badge-detail">' + sub.remaining + ' commande' + (sub.remaining > 1 ? 's' : '') + ' restante' + (sub.remaining > 1 ? 's' : '') + ' ce mois</div></div>'
        + '<span class="sub-badge-pill">' + sub.price + ' €/mois</span></div>';
    } else {
      subHtml = '<div class="sub-badge no-sub" onclick="showSubscriptions()" style="cursor:pointer;">'
        + '<span class="sub-badge-icon">🎁</span>'
        + '<div><div class="sub-badge-name">Aucun abonnement actif</div>'
        + '<div class="sub-badge-detail">Souscrire un abonnement mensuel</div></div>'
        + '<span class="sub-badge-pill cta">Voir →</span></div>';
    }

    var mapsUrl = 'https://www.google.com/maps/search/?api=1&query='
      + encodeURIComponent((currentUser.adresse || '') + ' ' + (currentUser.codePostal || '') + ' ' + (currentUser.ville || ''));

    el.innerHTML = '<div class="account-card">'
      + '<div class="account-avatar">👤</div>'
      + '<div class="account-name">' + currentUser.prenom + ' ' + currentUser.nom + '</div>'
      + '<div class="account-email">' + currentUser.email + '</div>'
      + subHtml
      + '<div class="account-section-title">📦 Adresse de livraison</div>'
      + '<div class="account-info-row"><span>Adresse</span>'
      + '<strong><a class="addr-link" href="' + mapsUrl + '" target="_blank">📍 ' + (currentUser.adresse || '—') + '</a></strong></div>'
      + '<div class="account-info-row"><span>Code postal</span><strong>' + (currentUser.codePostal || '—') + '</strong></div>'
      + '<div class="account-info-row"><span>Ville</span><strong>' + (currentUser.ville || '—') + '</strong></div>'
      + '<div class="account-info-row"><span>Téléphone</span><strong>' + (currentUser.tel || '—') + '</strong></div>'
      + '<div class="account-section-title" style="margin-top:18px;">📋 Mes commandes</div>'
      + renderOrderHistory()
      + '<div style="display:flex;gap:10px;margin-top:20px;flex-wrap:wrap;">'
