<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Go Mom Food</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --brown: #6B3A2A;
    --tan: #C8A97A;
    --sand: #E8D5A3;
    --cream: #F5EDD8;
    --green: #2D7A4F;
    --red: #C0392B;
    --orange: #E67E22;
    --dark: #2C1810;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘Nunito’, sans-serif;
background: var(–cream);
color: var(–dark);
min-height: 100vh;
}

/* HEADER */
.header {
background: var(–brown);
padding: 0 0 32px;
text-align: center;
position: relative;
overflow: hidden;
}

.header::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 6px;
background: repeating-linear-gradient(90deg,
var(–red) 0px, var(–red) 20px,
var(–orange) 20px, var(–orange) 40px,
var(–green) 40px, var(–green) 60px,
var(–tan) 60px, var(–tan) 80px,
#3a6fb5 80px, #3a6fb5 100px
);
}

.mask-icon {
font-size: 56px;
margin: 32px 0 8px;
display: block;
filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
}

.logo-wrap {
display: flex;
align-items: center;
justify-content: center;
gap: 12px;
margin-bottom: 4px;
}

.go-badge {
background: var(–red);
color: white;
font-family: ‘Playfair Display’, serif;
font-size: 38px;
font-weight: 900;
padding: 4px 20px;
border-radius: 8px;
letter-spacing: 2px;
position: relative;
}

.truck-icon { font-size: 36px; }

.logo-mom {
color: var(–green);
font-family: ‘Playfair Display’, serif;
font-size: 52px;
font-weight: 900;
letter-spacing: 4px;
line-height: 1;
}

.logo-food {
color: var(–orange);
font-family: ‘Playfair Display’, serif;
font-size: 52px;
font-weight: 900;
letter-spacing: 8px;
line-height: 1;
}

.kente-strip {
height: 14px;
background: repeating-linear-gradient(90deg,
var(–red) 0px, var(–red) 16px,
var(–orange) 16px, var(–orange) 32px,
var(–green) 32px, var(–green) 48px,
var(–tan) 48px, var(–tan) 64px,
#3a6fb5 64px, #3a6fb5 80px,
var(–dark) 80px, var(–dark) 88px
);
margin: 16px 0 0;
}

/* TABS */
.tabs {
display: flex;
justify-content: center;
gap: 8px;
padding: 20px 16px 0;
flex-wrap: wrap;
background: var(–brown);
}

.tab {
background: rgba(255,255,255,0.12);
color: var(–sand);
border: 2px solid rgba(200,169,122,0.3);
padding: 8px 20px;
border-radius: 50px;
font-family: ‘Nunito’, sans-serif;
font-weight: 700;
font-size: 14px;
cursor: pointer;
transition: all 0.2s;
letter-spacing: 0.5px;
}

.tab:hover, .tab.active {
background: var(–orange);
border-color: var(–orange);
color: white;
transform: translateY(-2px);
box-shadow: 0 4px 12px rgba(230,126,34,0.4);
}

/* MAIN */
main {
max-width: 900px;
margin: 0 auto;
padding: 32px 16px 80px;
}

.section { display: none; }
.section.active { display: block; }

.section-title {
font-family: ‘Playfair Display’, serif;
font-size: 28px;
font-weight: 700;
color: var(–brown);
text-align: center;
margin-bottom: 28px;
position: relative;
}

.section-title::after {
content: ‘’;
display: block;
width: 60px;
height: 4px;
background: var(–orange);
border-radius: 2px;
margin: 8px auto 0;
}

/* MENU GRID */
.menu-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
gap: 20px;
}

.card {
background: white;
border-radius: 20px;
overflow: hidden;
box-shadow: 0 4px 20px rgba(107,58,42,0.1);
transition: transform 0.25s, box-shadow 0.25s;
animation: fadeUp 0.4s ease both;
cursor: pointer;
}

.card:hover {
transform: translateY(-6px);
box-shadow: 0 12px 36px rgba(107,58,42,0.18);
}

@keyframes fadeUp {
from { opacity: 0; transform: translateY(20px); }
to   { opacity: 1; transform: translateY(0); }
}

.card-emoji {
background: linear-gradient(135deg, var(–sand) 0%, var(–tan) 100%);
height: 110px;
display: flex;
align-items: center;
justify-content: center;
font-size: 52px;
position: relative;
}

.price-badge {
position: absolute;
top: 12px;
right: 12px;
background: var(–brown);
color: var(–sand);
font-weight: 800;
font-size: 14px;
padding: 4px 12px;
border-radius: 50px;
}

.card-body { padding: 16px 18px 20px; }

.card-name {
font-family: ‘Playfair Display’, serif;
font-size: 20px;
font-weight: 700;
color: var(–brown);
margin-bottom: 6px;
}

.card-desc {
font-size: 13px;
color: #7a6050;
line-height: 1.6;
}

.add-btn {
display: block;
width: calc(100% - 36px);
margin: 12px 18px 0;
background: var(–orange);
color: white;
border: none;
border-radius: 50px;
padding: 10px;
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 14px;
cursor: pointer;
transition: background 0.2s, transform 0.15s;
margin-bottom: 4px;
}

.add-btn:hover { background: var(–brown); transform: scale(1.02); }

/* BOISSONS */
.drinks-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
gap: 16px;
}

.drink-card {
background: white;
border-radius: 16px;
padding: 20px 16px;
text-align: center;
box-shadow: 0 4px 16px rgba(107,58,42,0.1);
transition: transform 0.2s;
cursor: pointer;
animation: fadeUp 0.4s ease both;
}

.drink-card:hover { transform: translateY(-4px); }
.drink-card .emoji { font-size: 40px; margin-bottom: 8px; }
.drink-card .name { font-weight: 700; color: var(–brown); font-size: 15px; }
.drink-card .sub { font-size: 12px; color: #9a8070; margin-top: 2px; }
.drink-card .price { font-weight: 800; color: var(–orange); margin-top: 8px; font-size: 16px; }

/* COMMANDE */
.cart-empty {
text-align: center;
padding: 60px 20px;
color: #9a8070;
font-size: 16px;
}

.cart-empty .big { font-size: 56px; margin-bottom: 12px; }

.cart-item {
background: white;
border-radius: 16px;
padding: 16px 20px;
margin-bottom: 12px;
display: flex;
align-items: center;
gap: 16px;
box-shadow: 0 2px 12px rgba(107,58,42,0.08);
animation: fadeUp 0.3s ease both;
}

.cart-item .ci-emoji { font-size: 32px; }

.cart-item .ci-info { flex: 1; }
.cart-item .ci-name { font-weight: 700; color: var(–brown); }
.cart-item .ci-price { font-size: 13px; color: #9a8070; }

.qty-ctrl {
display: flex;
align-items: center;
gap: 10px;
}

.qty-btn {
background: var(–sand);
border: none;
width: 30px; height: 30px;
border-radius: 50%;
font-size: 18px;
font-weight: 700;
cursor: pointer;
color: var(–brown);
transition: background 0.15s;
}

.qty-btn:hover { background: var(–tan); }
.qty-num { font-weight: 800; font-size: 16px; min-width: 20px; text-align: center; }

.total-box {
background: var(–brown);
color: white;
border-radius: 20px;
padding: 24px;
margin-top: 24px;
display: flex;
justify-content: space-between;
align-items: center;
}

.total-label { font-size: 14px; opacity: 0.8; }
.total-amount { font-family: ‘Playfair Display’, serif; font-size: 36px; font-weight: 700; color: var(–orange); }

.order-btn {
display: block;
width: 100%;
margin-top: 16px;
background: var(–green);
color: white;
border: none;
border-radius: 50px;
padding: 16px;
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 16px;
cursor: pointer;
transition: background 0.2s;
letter-spacing: 1px;
}

.order-btn:hover { background: #1e5c38; }

/* CONTACT */
.contact-card {
background: white;
border-radius: 24px;
padding: 36px;
box-shadow: 0 4px 24px rgba(107,58,42,0.1);
text-align: center;
max-width: 480px;
margin: 0 auto;
}

.contact-card h2 {
font-family: ‘Playfair Display’, serif;
font-size: 26px;
color: var(–brown);
margin-bottom: 28px;
}

.contact-row {
display: flex;
align-items: center;
gap: 14px;
margin-bottom: 20px;
background: var(–cream);
border-radius: 14px;
padding: 16px 20px;
text-align: left;
}

.contact-icon { font-size: 28px; }

.contact-label { font-size: 12px; color: #9a8070; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
.contact-value { font-weight: 700; color: var(–dark); font-size: 15px; margin-top: 2px; }

.contact-value a { color: var(–orange); text-decoration: none; }
.contact-value a:hover { text-decoration: underline; }

/* CART BADGE */
.cart-tab-wrap { position: relative; display: inline-block; }
.cart-badge {
position: absolute;
top: -6px; right: -6px;
background: var(–red);
color: white;
border-radius: 50%;
width: 20px; height: 20px;
font-size: 11px;
font-weight: 800;
display: flex; align-items: center; justify-content: center;
display: none;
}

/* TOAST */
.toast {
position: fixed;
bottom: 24px;
left: 50%;
transform: translateX(-50%) translateY(80px);
background: var(–green);
color: white;
padding: 12px 28px;
border-radius: 50px;
font-weight: 700;
font-size: 14px;
box-shadow: 0 8px 24px rgba(0,0,0,0.2);
transition: transform 0.3s;
z-index: 999;
pointer-events: none;
}

.toast.show { transform: translateX(-50%) translateY(0); }

@media (max-width: 600px) {
.logo-mom, .logo-food { font-size: 40px; }
.go-badge { font-size: 28px; }
main { padding: 20px 12px 60px; }
.menu-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
.card-emoji { height: 80px; font-size: 36px; }
.card-name { font-size: 16px; }
.add-btn { display: none; }
}
</style>

