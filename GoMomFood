/* ── Address link in profile ── */
.addr-link { color: #2D7A4F; text-decoration: none; }
.addr-link:hover { text-decoration: underline; }

/* ── SUBSCRIPTION PLANS ── */
.plans-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; margin-bottom: 16px; }
.plan-card { background: white; border-radius: 20px; padding: 20px 14px; text-align: center; box-shadow: 0 4px 18px rgba(107,58,42,0.1); cursor: pointer; border: 2px solid transparent; transition: all 0.22s; position: relative; }
.plan-card:hover { transform: translateY(-3px); border-color: var(--orange); }
.plan-card.plan-popular { border-color: var(--orange); background: linear-gradient(135deg, #fff9f0, #fff); }
.plan-card.plan-current { border-color: var(--green); }
.plan-badge { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: var(--orange); color: white; font-size: 10px; font-weight: 800; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
.plan-count { font-family: 'Playfair Display', serif; font-size: 38px; font-weight: 900; color: var(--brown); line-height: 1; }
.plan-unit { font-size: 11px; color: #9a8070; margin-bottom: 10px; }
.plan-price { font-size: 20px; font-weight: 800; color: var(--orange); }
.plan-price span { font-size: 12px; color: #9a8070; font-weight: 400; }
.plan-per { font-size: 10px; color: #9a8070; margin: 4px 0 12px; }
.plan-btn { width: 100%; padding: 9px; background: var(--orange); color: white; border: none; border-radius: 50px; font-family: 'Nunito',sans-serif; font-weight: 800; font-size: 12px; cursor: pointer; }
.plan-btn.plan-btn-active { background: var(--green); }
.sub-badge { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border-radius: 16px; margin-bottom: 18px; cursor: pointer; }
.sub-badge.active-sub { background: linear-gradient(135deg, #e8f5ee, #f0faf4); border: 1.5px solid var(--green); }
.sub-badge.no-sub { background: #FEF3E5; border: 1.5px dashed var(--orange); }
.sub-badge-icon { font-size: 28px; }
.sub-badge-name { font-weight: 700; color: var(--brown); font-size: 14px; }
.sub-badge-detail { font-size: 12px; color: #9a8070; }
.sub-badge-pill { margin-left: auto; font-size: 12px; font-weight: 800; background: var(--green); color: white; padding: 4px 10px; border-radius: 20px; white-space: nowrap; }
.sub-badge-pill.cta { background: var(--orange); }
.sub-pay-amount { text-align: center; font-size: 22px; font-weight: 800; color: var(--orange); margin: 4px 0 8px; }

/* ── ADMIN DASHBOARD ── */
.admin-dashboard { max-width: 900px; margin: 0 auto; }
.admin-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; margin-bottom: 28px; }
.admin-stat-card { background: white; border-radius: 16px; padding: 16px; text-align: center; box-shadow: 0 3px 12px rgba(107,58,42,0.1); }
.admin-stat-icon { font-size: 26px; margin-bottom: 6px; }
.admin-stat-value { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--brown); }
.admin-stat-label { font-size: 11px; color: #9a8070; margin-top: 2px; }
.admin-section { background: white; border-radius: 20px; padding: 20px; margin-bottom: 20px; box-shadow: 0 4px 16px rgba(107,58,42,0.08); }
.admin-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.admin-section-header h3 { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--brown); }
.admin-export-btn { padding: 8px 16px; background: var(--green); color: white; border: none; border-radius: 50px; font-family: 'Nunito',sans-serif; font-weight: 700; font-size: 12px; cursor: pointer; }
.admin-table-wrap { overflow-x: auto; }
.admin-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.admin-table th { background: var(--cream); color: var(--brown); font-weight: 700; padding: 10px 12px; text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
.admin-table td { padding: 10px 12px; border-bottom: 1px solid #F5EDD8; vertical-align: middle; }
.admin-table tr:hover td { background: #fdf8f0; }
.admin-sub-pill { background: #e8f5ee; color: var(--green); font-weight: 700; font-size: 11px; padding: 3px 8px; border-radius: 20px; }
.admin-no-sub { color: #9a8070; font-size: 12px; }
.admin-action-btn { padding: 5px 10px; font-size: 11px; font-family: 'Nunito',sans-serif; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; background: var(--cream); color: var(--brown); margin-right: 4px; }
.admin-action-btn.danger { background: #fde8e8; color: var(--red); }
.admin-status-paid { color: var(--green); font-weight: 700; font-size: 12px; }
