/* ── ORDER HISTORY ── */
.order-hist-row { display: flex; gap: 8px; align-items: center; padding: 7px 0; border-bottom: 1px solid #F5EDD8; font-size: 12px; flex-wrap: wrap; }
.order-hist-date { color: #9a8070; min-width: 70px; }
.order-hist-items { flex: 1; color: var(--dark); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.order-hist-total { font-weight: 800; color: var(--orange); }
.order-hist-status { font-weight: 700; }
.order-hist-status.paid { color: var(--green); }

