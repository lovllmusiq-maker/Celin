function saveOrderRecord(paymentMethod) {
  const orders = loadOrders();
  const total  = cart.reduce((s,i) => s + i.price * i.qty, 0).toFixed(2);
  const items  = cart.map(i => `${i.qty}× ${i.name}`).join(', ');
  orders.push({ id:Date.now(), date:new Date().toISOString(), userEmail:currentUser?currentUser.email:'guest', userName:currentUser?`${currentUser.prenom} ${currentUser.nom}`:'Invité', items, total, status:'paid', paymentMethod });
  saveOrders(orders);
  if (currentUser && currentUser.subscription && currentUser.subscription.remaining > 0) {
    currentUser.subscription.remaining--;
    const users = loadUsers();
    if (users[currentUser.email]) { users[currentUser.email].subscription.remaining = currentUser.subscription.remaining; saveUsers(users); }
    saveSession(currentUser);
  }
}


