<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OMNI Logo</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Black+Han+Sans&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    font-family: sans-serif;
  }

  .scene {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .app-icon {
    position: relative;
    width: 320px;
    height: 320px;
    border-radius: 72px;
    background: radial-gradient(ellipse at 30% 20%, #1a1a1a 0%, #050505 60%, #000 100%);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.08),
      0 30px 80px rgba(0,0,0,0.9),
      0 0 120px rgba(255,255,255,0.03),
      inset 0 1px 0 rgba(255,255,255,0.12),
      inset 0 -1px 0 rgba(0,0,0,0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    animation: float 4s ease-in-out infinite;
  }

  .app-icon::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 72px;
    background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .app-icon::after {
    content: '';
    position: absolute;
    top: 0; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  }

  .logo-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Shadow layer */
  .logo-shadow {
    position: absolute;
    font-family: 'Bebas Neue', 'Black Han Sans', sans-serif;
    font-size: 108px;
    font-weight: 900;
    letter-spacing: 6px;
    color: transparent;
    text-shadow:
      0 6px 20px rgba(0,0,0,1),
      0 3px 8px rgba(0,0,0,0.9);
    top: 8px;
    left: 3px;
    filter: blur(6px);
    opacity: 0.9;
    user-select: none;
  }

  /* Main chrome text */
  .logo-main {
    position: relative;
    font-family: 'Bebas Neue', 'Black Han Sans', sans-serif;
    font-size: 108px;
    font-weight: 900;
    letter-spacing: 6px;
    background: linear-gradient(
      180deg,
      #ffffff 0%,
      #e8e8e8 8%,
      #f5f5f5 18%,
      #b0b0b0 30%,
      #d8d8d8 42%,
      #f8f8f8 52%,
      #9a9a9a 62%,
      #c8c8c8 72%,
      #efefef 82%,
      #d0d0d0 90%,
      #ffffff 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter:
      drop-shadow(0 1px 0 rgba(255,255,255,0.9))
      drop-shadow(0 -1px 0 rgba(0,0,0,0.6))
      drop-shadow(2px 0 0 rgba(255,255,255,0.3))
      drop-shadow(-2px 0 0 rgba(0,0,0,0.4));
  }

  /* Highlight sheen overlay */
  .logo-sheen {
    position: absolute;
    font-family: 'Bebas Neue', 'Black Han Sans', sans-serif;
    font-size: 108px;
    font-weight: 900;
    letter-spacing: 6px;
    background: linear-gradient(
      120deg,
      transparent 0%,
      transparent 30%,
      rgba(255,255,255,0.15) 45%,
      rgba(255,255,255,0.35) 50%,
      rgba(255,255,255,0.15) 55%,
      transparent 70%,
      transparent 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    top: 0; left: 0;
    animation: sheen 5s ease-in-out infinite 1s;
    pointer-events: none;
  }

  /* Decorative line under */
  .logo-line {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  @keyframes sheen {
    0%, 100% { opacity: 0; background-position: -200% center; }
    30% { opacity: 1; }
    60% { opacity: 0; background-position: 200% center; }
  }

  /* Wordmark below icon */
  .wordmark {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 14px;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
    margin-left: 14px;
  }

  /* Controls */
  .controls {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    padding: 10px 22px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.6);
    border-radius: 8px;
    cursor: pointer;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.2s;
    font-family: sans-serif;
  }

  .btn:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }

  /* Color variants */
  .gold .logo-main {
    background: linear-gradient(
      180deg,
      #fff0a0 0%,
      #ffd700 15%,
      #ffec6e 30%,
      #c8a000 45%,
      #ffd700 58%,
      #ffe066 70%,
      #b8860b 82%,
      #ffd700 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  .blue .logo-main {
    background: linear-gradient(
      180deg,
      #e0f0ff 0%,
      #a0d0ff 15%,
      #c8e8ff 30%,
      #5090cc 45%,
      #90c8ff 58%,
      #c0e0ff 70%,
      #3070aa 82%,
      #a8d8ff 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
  }
</style>
</head>
<body>

<div class="scene">
  <div class="app-icon" id="icon">
    <div class="logo-wrap">
      <div class="logo-shadow">OMNI</div>
      <div class="logo-main" id="logoText">OMNI</div>
      <div class="logo-sheen">OMNI</div>
      <div class="logo-line"></div>
    </div>
  </div>

  <div class="wordmark">OMNI STUDIO</div>

  <div class="controls">
    <button class="btn" onclick="setStyle('chrome')">⬜ Chrome</button>
    <button class="btn" onclick="setStyle('gold')">🟡 Or</button>
    <button class="btn" onclick="setStyle('blue')">🔵 Acier</button>
    <button class="btn" onclick="downloadLogo()">⬇ Télécharger</button>
  </div>
</div>

<script>
  function setStyle(style) {
    const icon = document.getElementById('icon');
    icon.classList.remove('gold', 'blue');
    if (style !== 'chrome') icon.classList.add(style);
  }

  function downloadLogo() {
    // Guide user
    alert('Astuce : Faites clic droit sur le logo → "Enregistrer l\'image" ou utilisez une capture d\'écran (Cmd+Shift+4 sur Mac)');
  }
</script>

</body>
</html>
