export function DepositScreen() {
const [method,   setMethod]  = useState<string | null>(null);
const [amount,   setAmount]  = useState(’’);
const [currency, setCurrency] = useState(‘EUR’);
const [step,     setStep]    = useState(1);
const [loading,  setLoading] = useState(false);
// Card
const [cardNum,  setCardNum]  = useState(’’);
const [cardExp,  setCardExp]  = useState(’’);
const [cardCvv,  setCardCvv]  = useState(’’);
const [cardName, setCardName] = useState(’’);
// Mobile
const [mobileOp, setMobileOp]   = useState(‘Orange Money’);
const [mobileNum, setMobileNum] = useState(’’);

const METHODS = [
{ id:‘card’,   icon:‘💳’, label:‘Carte bancaire’,   sub:‘Visa, Mastercard’ },
{ id:‘mobile’, icon:‘📱’, label:‘Mobile Money’,     sub:‘Orange, MTN, Wave, Moov’ },
{ id:‘iban’,   icon:‘🏦’, label:‘Virement IBAN’,    sub:‘SEPA / SWIFT’ },
{ id:‘crypto’, icon:‘₿’,  label:‘Crypto’,           sub:‘USDT, BTC, ETH’ },
];

const simulate = async () => {
setLoading(true);
await new Promise(r => setTimeout(r, 2000));
setLoading(false);
const ref = ‘PRG-’ + Date.now().toString(36).toUpperCase();
Alert.alert(‘✓ Virement initié’, `Référence : ${ref}\nMontant : ${amount} ${currency}\nLes fonds seront crédités après confirmation.`, [
{ text: ‘OK’, onPress: () => { setStep(1); setMethod(null); setAmount(’’); } }
]);
};

if (step === 1) return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
<ScrollView contentContainerStyle={{ padding: 20 }}>
<Text style={styles.pageLabel}>ALIMENTER MON COMPTE</Text>
<Text style={styles.pageTitle}>Déposer des fonds</Text>

```
    <Text style={styles.label}>MONTANT</Text>
    <View style={styles.inputRow}>
      <TextInput style={[styles.input, { flex: 1, fontSize: 24, fontWeight: '800', marginBottom: 0 }]} placeholder="0.00" placeholderTextColor={COLORS.muted} value={amount} onChangeText={setAmount} keyboardType="decimal-pad" />
      <TouchableOpacity style={styles.currencyPicker} onPress={() => Alert.alert('Devise', 'EUR sélectionné')}>
        <Text style={{ fontWeight: '700', color: COLORS.navy }}>EUR ▾</Text>
      </TouchableOpacity>
    </View>
    <View style={styles.quickAmounts}>
      {[10, 25, 50, 100, 500].map(a => (
        <TouchableOpacity key={a} style={[styles.quickBtn, amount === String(a) && styles.quickBtnActive]} onPress={() => setAmount(String(a))}>
          <Text style={[styles.quickBtnText, amount === String(a) && { color: COLORS.white }]}>{a}</Text>
        </TouchableOpacity>
      ))}
    </View>

    <Text style={[styles.label, { marginTop: 20 }]}>MODE DE PAIEMENT</Text>
    {METHODS.map(m => (
      <TouchableOpacity key={m.id} style={[styles.methodCard, !amount && { opacity: 0.4 }]} disabled={!amount} onPress={() => { setMethod(m.id); setStep(2); }}>
        <View style={styles.methodIconBox}><Text style={{ fontSize: 24 }}>{m.icon}</Text></View>
        <View style={{ flex: 1 }}>
          <Text style={styles.methodLabel}>{m.label}</Text>
          <Text style={styles.methodSub}>{m.sub}</Text>
        </View>
        <Text style={{ color: COLORS.muted, fontSize: 18 }}>›</Text>
      </TouchableOpacity>
    ))}

    {/* Architecture info */}
    <View style={[styles.infoBox, { marginTop: 20 }]}>
      <Text style={styles.infoTitle}>🏗️ Intégrations en production</Text>
      {[['💳','Stripe API + 3DS2'],['📱','CinetPay API v2'],['🏦','Lemonway / SEPA'],['₿','CoinGate / BitPay']].map(([icon, txt], i) => (
        <Text key={i} style={styles.infoItem}>{icon} {txt}</Text>
      ))}
    </View>
  </ScrollView>
</SafeAreaView>
```

);

if (step === 2) return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
<TouchableOpacity onPress={() => { setStep(1); setMethod(null); }} style={styles.backBtn}>
<Text style={styles.backBtnText}>← Retour</Text>
</TouchableOpacity>
<ScrollView contentContainerStyle={{ padding: 20 }} keyboardShouldPersistTaps=“handled”>
<Text style={styles.pageTitle}>{METHODS.find(m => m.id === method)?.icon} {METHODS.find(m => m.id === method)?.label}</Text>
<Text style={styles.pageLabel}>{amount} {currency} à déposer</Text>

