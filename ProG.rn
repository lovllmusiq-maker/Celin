// ════════════════════════════════════════════════════════════════
// 6. ARIA COACH (app/(app)/coach.tsx)
// ════════════════════════════════════════════════════════════════

export function CoachScreen() {
const { user } = useAuth();
const [messages,  setMessages]  = useState<{role:string, content:string}[]>([]);
const [input,     setInput]     = useState(’’);
const [loading,   setLoading]   = useState(false);
const [analyzed,  setAnalyzed]  = useState(false);
const [ariaLang,  setAriaLang]  = useState(‘fr’);
const scrollRef = useRef<ScrollView>(null);

const LANGS = [
{code:‘fr’,flag:‘🇫🇷’},{code:‘en’,flag:‘🇺🇸’},{code:‘es’,flag:‘🇪🇸’},
{code:‘ar’,flag:‘🇸🇦’},{code:‘pt’,flag:‘🇧🇷’},{code:‘de’,flag:‘🇩🇪’},
{code:‘zh’,flag:‘🇨🇳’},{code:‘wo’,flag:‘🇸🇳’},
];

const callARIA = async (userMsg: string) => {
const langName = {fr:‘Français’,en:‘English’,es:‘Español’,ar:‘العربية’,pt:‘Português’,de:‘Deutsch’,zh:‘中文’,wo:‘Wolof’}[ariaLang] || ‘Français’;
const system = `Tu es ARIA, coach épargne IA pour Pro.G. Tu t'adresses à ${user?.name}. Bienveillant·e, analytique. TOUJOURS répondre en ${langName}. Concis (3-5 phrases). Action concrète chiffrée systématique.`;
const res = await fetch(‘https://api.anthropic.com/v1/messages’, {
method: ‘POST’,
headers: { ‘Content-Type’: ‘application/json’ },
body: JSON.stringify({
model: ‘claude-sonnet-4-20250514’,
max_tokens: 1000,
system,
messages: […messages, { role: ‘user’, content: userMsg }],
}),
});
const data = await res.json();
return data.content?.[0]?.text || ‘Impossible de générer une réponse.’;
};

const analyze = async () => {
setLoading(true); setMessages([]);
try {
const reply = await callARIA(‘Analyse mes projets. Bilan global, projet le plus à risque, le plus sain, 2 actions prioritaires chiffrées.’);
setMessages([{ role: ‘assistant’, content: reply }]);
setAnalyzed(true);
} catch { setMessages([{ role: ‘assistant’, content: ‘Erreur de connexion. Réessaie.’ }]); }
setLoading(false);
setTimeout(() => scrollRef.current?.scrollToEnd({ animated: true }), 100);
};

const send = async () => {
if (!input.trim() || loading) return;
const msg = input.trim(); setInput(’’);
const updated = […messages, { role: ‘user’, content: msg }];
setMessages(updated); setLoading(true);
try {
const reply = await callARIA(msg);
setMessages([…updated, { role: ‘assistant’, content: reply }]);
} catch { setMessages([…updated, { role: ‘assistant’, content: ‘Erreur. Réessaie.’ }]); }
setLoading(false);
setTimeout(() => scrollRef.current?.scrollToEnd({ animated: true }), 100);
};

return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
{/* Header */}
<View style={styles.coachHeader}>
<View style={styles.coachAvatar}><Text style={{ fontSize: 22 }}>✦</Text></View>
<View style={{ flex: 1 }}>
<Text style={styles.coachTitle}>ARIA <Text style={styles.coachSub}>AI Advisor</Text></Text>
<Text style={styles.coachDesc}>Analyse bienveillante · Conseils chiffrés</Text>
</View>
</View>

```
  {/* Lang strip */}
  <ScrollView horizontal showsHorizontalScrollIndicator={false} style={styles.langStrip} contentContainerStyle={{ paddingHorizontal: 16, gap: 6 }}>
    {LANGS.map(l => (
      <TouchableOpacity key={l.code} onPress={() => { setAriaLang(l.code); setAnalyzed(false); setMessages([]); }} style={[styles.langBtn, ariaLang === l.code && styles.langBtnActive]}>
        <Text style={{ fontSize: 16 }}>{l.flag}</Text>
      </TouchableOpacity>
    ))}
  </ScrollView>

  {/* Messages */}
  <ScrollView ref={scrollRef} style={{ flex: 1 }} contentContainerStyle={{ padding: 16, paddingBottom: 8 }}>
    {messages.length === 0 && !loading && (
      <View style={styles.ariaWelcome}>
        <View style={styles.ariaWelcomeIcon}><Text style={{ fontSize: 32 }}>✦</Text></View>
        <Text style={styles.ariaWelcomeTitle}>Bonjour {user?.name?.split(' ')[0]}, je suis ARIA</Text>
        <Text style={styles.ariaWelcomeText}>Votre coach épargne IA. J'analyse vos projets, identifie les risques et vous guide avec des conseils chiffrés et personnalisés.</Text>
        <TouchableOpacity style={styles.btnPrimary} onPress={analyze}>
          <Text style={styles.btnPrimaryText}>✦ Analyser mes projets</Text>
        </TouchableOpacity>
      </View>
    )}

    {messages.map((m, i) => (
      <View key={i} style={[styles.msgRow, m.role === 'user' ? styles.msgRowUser : styles.msgRowAria]}>
        {m.role === 'assistant' && (
          <View style={styles.msgAvatar}><Text style={{ fontSize: 14, color: COLORS.white }}>✦</Text></View>
        )}
        <View style={[styles.msgBubble, m.role === 'user' ? styles.msgBubbleUser : styles.msgBubbleAria]}>
          <Text style={[styles.msgText, m.role === 'user' && { color: COLORS.white }]}>{m.content}</Text>
        </View>
      </View>
    ))}

    {loading && (
      <View style={styles.msgRow}>
        <View style={styles.msgAvatar}><Text style={{ fontSize: 14, color: COLORS.white }}>✦</Text></View>
        <View style={[styles.msgBubble, styles.msgBubbleAria, { flexDirection: 'row', gap: 6, alignItems: 'center' }]}>
          <ActivityIndicator size="small" color={COLORS.navy} />
          <Text style={{ color: COLORS.muted, fontSize: 12 }}>ARIA réfléchit…</Text>
        </View>
      </View>
    )}
  </ScrollView>

  {/* Suggestions */}
  {analyzed && !loading && (
    <ScrollView horizontal showsHorizontalScrollIndicator={false} style={styles.suggStrip} contentContainerStyle={{ paddingHorizontal: 16, gap: 8 }}>
      {['Quel projet prioriser ?','Suis-je en bonne voie ?','Comment épargner plus vite ?','Analyse mon rythme'].map((s, i) => (
        <TouchableOpacity key={i} style={styles.suggBtn} onPress={() => setInput(s)}>
          <Text style={styles.suggBtnText}>{s}</Text>
        </TouchableOpacity>
      ))}
    </ScrollView>
  )}

  {/* Input */}
  {analyzed && (
    <KeyboardAvoidingView behavior={Platform.OS === 'ios' ? 'padding' : 'height'} keyboardVerticalOffset={90}>
      <View style={styles.chatInputRow}>
        <TextInput
          style={styles.chatInput}
          placeholder="Posez une question à ARIA…"
          placeholderTextColor={COLORS.muted}
          value={input}
          onChangeText={setInput}
          onSubmitEditing={send}
          returnKeyType="send"
          multiline
        />
        <TouchableOpacity style={[styles.sendBtn, (!input.trim() || loading) && { backgroundColor: COLORS.border }]} onPress={send} disabled={!input.trim() || loading}>
          <Text style={{ color: COLORS.white, fontSize: 18 }}>↑</Text>
        </TouchableOpacity>
      </View>
    </KeyboardAvoidingView>
  )}
</SafeAreaView>
```

);
}

