export function AccountScreen() {
const { user, logout } = useAuth();
const [showAdminLogin, setShowAdminLogin] = useState(false);
const [adminCode, setAdminCode] = useState(’’);

const PLANS = [
{ id:‘starter’, name:‘Essential’,    price:‘Gratuit’,      color:’#64748B’ },
{ id:‘pro’,     name:‘Professional’, price:‘4,99 €/mois’,  color:’#1E3A5F’, popular:true },
{ id:‘elite’,   name:‘Elite’,        price:‘12,99 €/mois’, color:’#0F766E’ },
{ id:‘business’,name:‘Enterprise’,   price:‘29,99 €/mois’, color:’#92400E’ },
];

const UPCOMING = [
{ icon:‘🔄’, label:‘Virements automatiques’ },
{ icon:‘🔔’, label:‘Notifications push’ },
{ icon:‘📊’, label:‘Projections graphiques’ },
{ icon:‘🏆’, label:‘Gamification & badges’ },
{ icon:‘📈’, label:‘Pro.G Invest’ },
{ icon:‘⚙️’, label:‘API Access’ },
];

const handleLogout = () => {
Alert.alert(‘Déconnexion’, ‘Êtes-vous sûr ?’, [
{ text: ‘Annuler’, style: ‘cancel’ },
{ text: ‘Déconnexion’, style: ‘destructive’, onPress: () => logout() },
]);
};

return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
<ScrollView contentContainerStyle={{ padding: 20, paddingBottom: 50 }}>
<Text style={styles.pageLabel}>COMPTE</Text>
<Text style={styles.pageTitle}>Mon Compte</Text>

```
    {/* Profile card */}
    <View style={styles.profileCard}>
      <View style={styles.profileAvatar}>
        <Text style={styles.profileAvatarText}>{user?.name?.charAt(0).toUpperCase()}</Text>
      </View>
      <View style={{ flex: 1 }}>
        <Text style={styles.profileName}>{user?.name}</Text>
        <Text style={styles.profileEmail}>{user?.email}</Text>
        <View style={[styles.planTag, { backgroundColor: `${COLORS.navy}15` }]}>
          <Text style={[styles.planTagText, { color: COLORS.navy }]}>Plan Starter</Text>
        </View>
      </View>
      <TouchableOpacity style={styles.logoutBtn} onPress={handleLogout}>
        <Text style={styles.logoutText}>Quitter</Text>
      </TouchableOpacity>
    </View>

    {/* Admin access */}
    <TouchableOpacity style={styles.adminCard} onPress={() => setShowAdminLogin(true)}>
      <View style={styles.adminIconBox}><Text style={{ fontSize: 20 }}>🛡️</Text></View>
      <View style={{ flex: 1 }}>
        <Text style={styles.adminTitle}>Espace Administrateur</Text>
        <Text style={styles.adminSub}>Statistiques, paiements, utilisateurs</Text>
      </View>
      <Text style={{ color: COLORS.muted, fontSize: 18 }}>›</Text>
    </TouchableOpacity>

    {/* Plans */}
    <Text style={[styles.sectionTitle, { marginTop: 20 }]}>Abonnements</Text>
    {PLANS.map((p, i) => (
      <TouchableOpacity key={i} style={[styles.planCard, user?.plan === p.id && { borderColor: p.color, backgroundColor: `${p.color}06` }]} onPress={() => Alert.alert(p.name, `${p.price}\nAppuyez pour sélectionner ce plan.`)}>
        <View style={{ flex: 1 }}>
          <View style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
            <Text style={[styles.planName, user?.plan === p.id && { color: p.color }]}>{p.name}</Text>
            {p.popular && <View style={styles.popularBadge}><Text style={styles.popularText}>POPULAIRE</Text></View>}
            {user?.plan === p.id && <View style={[styles.activeBadge, { backgroundColor: `${p.color}20` }]}><Text style={[styles.activeText, { color: p.color }]}>ACTIF</Text></View>}
          </View>
          <Text style={styles.planSub}>Retrait 2.5% · Délai 5 jours</Text>
        </View>
        <Text style={[styles.planPrice, user?.plan === p.id && { color: p.color }]}>{p.price}</Text>
      </TouchableOpacity>
    ))}

    {/* Coming soon */}
    <Text style={[styles.sectionTitle, { marginTop: 20 }]}>Fonctionnalités à venir</Text>
    <View style={styles.upcomingCard}>
      {UPCOMING.map((f, i) => (
        <View key={i} style={[styles.upcomingRow, i < UPCOMING.length - 1 && { borderBottomWidth: 1, borderBottomColor: COLORS.border }]}>
          <Text style={{ fontSize: 18, width: 28 }}>{f.icon}</Text>
          <Text style={styles.upcomingLabel}>{f.label}</Text>
          <View style={styles.soonBadge}><Text style={styles.soonText}>SOON</Text></View>
        </View>
      ))}
    </View>

    {/* Legal */}
    {[['⚖️','Conformité légale'],['🔐','Sécurité'],['❓','Aide & Support']].map(([icon, title], i) => (
      <TouchableOpacity key={i} style={styles.legalRow} onPress={() => Alert.alert(title, 'Disponible bientôt')}>
        <Text style={{ fontSize: 18 }}>{icon}</Text>
        <Text style={styles.legalText}>{title}</Text>
        <Text style={{ color: COLORS.muted, fontSize: 18 }}>›</Text>
      </TouchableOpacity>
    ))}

    <Text style={styles.version}>Pro.G Financial · v1.0.0 · © 2025</Text>
  </ScrollView>

  {/* Admin Login Modal */}
  <Modal visible={showAdminLogin} animationType="slide" presentationStyle="pageSheet" onRequestClose={() => setShowAdminLogin(false)}>
    <SafeAreaView style={{ flex: 1, backgroundColor: COLORS.white }}>
      <View style={styles.modalHeader}>
        <Text style={styles.modalTitle}>🛡️ Accès Admin</Text>
        <TouchableOpacity onPress={() => { setShowAdminLogin(false); setAdminCode(''); }}>
          <Text style={{ fontSize: 20, color: COLORS.slate }}>✕</Text>
        </TouchableOpacity>
      </View>
      <View style={{ padding: 24 }}>
        <Text style={styles.label}>CODE ADMINISTRATEUR</Text>
        <TextInput
          style={[styles.input, { fontSize: 22, fontWeight: '800', letterSpacing: 6, textAlign: 'center' }]}
          placeholder="••••••••"
          placeholderTextColor={COLORS.muted}
          value={adminCode}
          onChangeText={setAdminCode}
          secureTextEntry
          autoCapitalize="characters"
        />
        <TouchableOpacity style={styles.btnPrimary} onPress={() => {
          if (adminCode === 'PROG2025') {
            setShowAdminLogin(false); setAdminCode('');
            router.push('/(app)/admin');
          } else {
            Alert.alert('Erreur', 'Code incorrect');
          }
        }}>
          <Text style={styles.btnPrimaryText}>Accéder au tableau de bord</Text>
        </TouchableOpacity>
        <Text style={styles.adminHint}>Code par défaut : PROG2025</Text>
      </View>
    </SafeAreaView>
  </Modal>
</SafeAreaView>
```

);
}

