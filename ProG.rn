export function AdminScreen() {
const [tab, setTab] = useState(‘stats’);
const ADMIN_TABS = [
{ id:‘stats’,        label:‘Stats’,        icon:‘📊’ },
{ id:‘users’,        label:‘Utilisateurs’, icon:‘👥’ },
{ id:‘transactions’, label:‘Transactions’, icon:‘📄’ },
{ id:‘payments’,     label:‘Paiements’,    icon:‘💰’ },
];

const mockUsers = [
{ name:‘Jean Martin’,    email:‘jean@mail.com’,   plan:‘pro’,     projects:3, saved:4200 },
{ name:‘Fatou Diallo’,   email:‘fatou@mail.com’,  plan:‘starter’, projects:1, saved:850  },
{ name:‘Kwame Asante’,   email:‘kwame@mail.com’,  plan:‘elite’,   projects:7, saved:18600},
];
const mockTx = [
{ id:‘PRG-A1B2C3’, user:‘Jean Martin’,  amount:200,  currency:‘EUR’, method:‘Carte’,       status:‘Complété’, date:‘18/04/2025’ },
{ id:‘PRG-D4E5F6’, user:‘Fatou Diallo’, amount:50,   currency:‘XOF’, method:‘Mobile Money’, status:‘En cours’, date:‘17/04/2025’ },
{ id:‘PRG-G7H8I9’, user:‘Kwame Asante’, amount:1000, currency:‘USD’, method:‘IBAN’,         status:‘Complété’, date:‘16/04/2025’ },
];

const [payConfig, setPayConfig] = useState({ holder:’’, iban:’’, bic:’’, paypal:’’, stripe:’’, cinetpay:’’ });

return (
<SafeAreaView style={{ flex: 1, backgroundColor: ‘#080F1A’ }}>
{/* Header */}
<View style={styles.adminHeader}>
<View style={styles.adminHeaderLeft}>
<View style={styles.adminHeaderIcon}><Text style={{ fontSize: 18 }}>🛡️</Text></View>
<View>
<Text style={styles.adminHeaderTitle}>Pro<Text style={{ color: COLORS.gold }}>.G</Text> Admin</Text>
<Text style={styles.adminHeaderSub}>Tableau de bord</Text>
</View>
</View>
<TouchableOpacity style={styles.adminCloseBtn} onPress={() => router.back()}>
<Text style={styles.adminCloseTxt}>✕ Fermer</Text>
</TouchableOpacity>
</View>

```
  {/* Sub nav */}
  <ScrollView horizontal showsHorizontalScrollIndicator={false} style={styles.adminNav} contentContainerStyle={{ paddingHorizontal: 16, gap: 8 }}>
    {ADMIN_TABS.map(t => (
      <TouchableOpacity key={t.id} style={[styles.adminNavBtn, tab === t.id && styles.adminNavBtnActive]} onPress={() => setTab(t.id)}>
        <Text style={{ marginRight: 4 }}>{t.icon}</Text>
        <Text style={[styles.adminNavTxt, tab === t.id && styles.adminNavTxtActive]}>{t.label}</Text>
      </TouchableOpacity>
    ))}
  </ScrollView>

  <ScrollView style={{ flex: 1 }} contentContainerStyle={{ padding: 16, paddingBottom: 40 }}>

    {/* STATS */}
    {tab === 'stats' && (
      <>
        <View style={styles.adminGrid}>
          {[
            { label:'Utilisateurs', value:mockUsers.length,   color:'#3B82F6' },
            { label:'Projets',      value:11,                  color:COLORS.green },
            { label:'Transactions', value:mockTx.length,      color:COLORS.gold },
            { label:'Collectifs',   value:2,                   color:'#8B5CF6' },
          ].map((s, i) => (
            <View key={i} style={styles.adminStatCard}>
              <Text style={[styles.adminStatValue, { color: s.color }]}>{s.value}</Text>
              <Text style={styles.adminStatLabel}>{s.label}</Text>
            </View>
          ))}
        </View>
        <LinearGradient colors={[COLORS.navy, COLORS.navy2]} style={styles.adminTotalCard}>
          <Text style={styles.adminTotalLabel}>TOTAL ÉPARGNE PLATEFORME</Text>
          <Text style={styles.adminTotalValue}>23 650 <Text style={styles.adminTotalCurrency}>EUR</Text></Text>
          <Text style={styles.adminTotalSub}>Réparti sur {mockUsers.length} utilisateurs</Text>
        </LinearGradient>
      </>
    )}

    {/* USERS */}
    {tab === 'users' && mockUsers.map((u, i) => (
      <View key={i} style={styles.adminUserCard}>
        <View style={styles.adminUserAvatar}><Text style={{ color: COLORS.gold, fontWeight: '700', fontSize: 16 }}>{u.name.charAt(0)}</Text></View>
        <View style={{ flex: 1 }}>
          <Text style={styles.adminUserName}>{u.name}</Text>
          <Text style={styles.adminUserEmail}>{u.email}</Text>
        </View>
        <View style={{ alignItems: 'flex-end' }}>
          <Text style={styles.adminUserSaved}>{u.saved.toLocaleString('fr-FR')} €</Text>
          <Text style={styles.adminUserPlan}>{u.plan}</Text>
        </View>
      </View>
    ))}

    {/* TRANSACTIONS */}
    {tab === 'transactions' && mockTx.map((tx, i) => (
      <View key={i} style={styles.adminTxCard}>
        <View style={{ flexDirection: 'row', justifyContent: 'space-between', marginBottom: 8 }}>
          <View>
            <Text style={styles.adminTxUser}>{tx.user}</Text>
            <Text style={styles.adminTxId}>{tx.id} · {tx.date}</Text>
          </View>
          <View style={{ alignItems: 'flex-end' }}>
            <Text style={styles.adminTxAmount}>{tx.amount} {tx.currency}</Text>
            <View style={[styles.txStatusBadge, { backgroundColor: tx.status === 'Complété' ? 'rgba(15,118,110,.3)' : 'rgba(217,119,6,.3)' }]}>
              <Text style={[styles.txStatusText, { color: tx.status === 'Complété' ? '#34D399' : COLORS.gold2 }]}>{tx.status}</Text>
            </View>
          </View>
        </View>
        <View style={styles.adminTxMethod}><Text style={styles.adminTxMethodTxt}>{tx.method}</Text></View>
      </View>
    ))}

    {/* PAYMENTS CONFIG */}
    {tab === 'payments' && (
      <>
        <Text style={styles.adminSectionLabel}>COORDONNÉES BANCAIRES</Text>
        {[
          { label:'Titulaire', key:'holder', placeholder:'Nom du titulaire' },
          { label:'IBAN',      key:'iban',   placeholder:'FR76 XXXX…', mono:true },
          { label:'BIC',       key:'bic',    placeholder:'CEPAFRPP…',  mono:true },
        ].map(({ label, key, placeholder, mono }) => (
          <View key={key}>
            <Text style={styles.adminLabel}>{label}</Text>
            <TextInput
              style={[styles.adminInput, mono && { fontFamily: Platform.OS === 'ios' ? 'Courier' : 'monospace', fontSize: 12 }]}
              placeholder={placeholder}
              placeholderTextColor="rgba(255,255,255,.2)"
              value={(payConfig as any)[key]}
              onChangeText={v => setPayConfig(p => ({ ...p, [key]: v }))}
              autoCapitalize={key === 'iban' || key === 'bic' ? 'characters' : 'words'}
            />
          </View>
        ))}
        <Text style={[styles.adminSectionLabel, { marginTop: 16 }]}>PAYPAL</Text>
        <Text style={styles.adminLabel}>Email PayPal</Text>
        <TextInput style={styles.adminInput} placeholder="votre@paypal.com" placeholderTextColor="rgba(255,255,255,.2)" value={payConfig.paypal} onChangeText={v => setPayConfig(p => ({ ...p, paypal: v }))} keyboardType="email-address" autoCapitalize="none" />
        <Text style={[styles.adminSectionLabel, { marginTop: 16 }]}>CLÉS API</Text>
        {[['Stripe Public Key','stripe','pk_live_…'],['CinetPay Key','cinetpay','Clé API CinetPay']].map(([label,key,ph]) => (
          <View key={key}>
            <Text style={styles.adminLabel}>{label}</Text>
            <TextInput style={[styles.adminInput, { fontFamily: Platform.OS === 'ios' ? 'Courier' : 'monospace', fontSize: 12 }]} placeholder={ph} placeholderTextColor="rgba(255,255,255,.2)" value={(payConfig as any)[key]} onChangeText={v => setPayConfig(p => ({ ...p, [key]: v }))} autoCapitalize="none" />
          </View>
        ))}
        <TouchableOpacity style={styles.adminSaveBtn} onPress={() => Alert.alert('✓', 'Configuration sauvegardée dans votre espace privé')}>
          <Text style={styles.adminSaveTxt}>🔒 Sauvegarder la configuration</Text>
        </TouchableOpacity>
        <Text style={styles.adminSaveHint}>Stockage chiffré · Invisible des utilisateurs</Text>
      </>
    )}
  </ScrollView>
</SafeAreaView>
```

);
}

