{ id:‘1’, name:‘Voyage Tokyo’, icon:‘✈️’, saved: 950,  goal: 3000,  currency:‘EUR’ },
{ id:‘2’, name:‘Voiture Tesla’, icon:‘🚗’, saved: 2200, goal: 15000, currency:‘EUR’ },
];

return (
<View style={{ flex: 1, backgroundColor: COLORS.light }}>
