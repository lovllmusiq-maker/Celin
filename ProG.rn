// ════════════════════════════════════════════════════════════════
// 3. PROJECTS (app/(app)/projects.tsx)
// ════════════════════════════════════════════════════════════════

import { Modal, FlatList } from ‘react-native’;

export function ProjectsScreen() {
const [projects, setProjects] = useState([
{ id:‘1’, name:‘Voyage Tokyo’,  category:‘travel’,   icon:‘✈️’, saved:950,  goal:3000,  currency:‘EUR’, deadline:‘2026-09-01’ },
{ id:‘2’, name:‘Voiture Tesla’, category:‘car’,      icon:‘🚗’, saved:2200, goal:15000, currency:‘EUR’, deadline:‘2027-06-01’ },
]);
const [showNew,     setShowNew]     = useState(false);
const [showDeposit, setShowDeposit] = useState(false);
const [active,      setActive]      = useState<any>(null);
const [deposit,     setDeposit]     = useState(’’);
const [newForm,     setNewForm]     = useState({ name:’’, goal:’’, currency:‘EUR’, deadline:’’ });

const handleDeposit = () => {
const amt = parseFloat(deposit);
if (!amt || amt <= 0) { Alert.alert(‘Erreur’, ‘Montant invalide’); return; }
setProjects(prev => prev.map(p =>
p.id === active.id ? { …p, saved: Math.min(p.saved + amt, p.goal) } : p
));
setDeposit(’’);
setShowDeposit(false);
Alert.alert(‘✓’, `+${amt} ${active.currency} ajouté`);
};

const handleCreate = () => {
if (!newForm.name || !newForm.goal || !newForm.deadline) {
Alert.alert(‘Erreur’, ‘Remplissez tous les champs’); return;
}
setProjects(prev => […prev, {
id: Date.now().toString(), name: newForm.name,
category: ‘other’, icon: ‘⭐’,
saved: 0, goal: parseFloat(newForm.goal),
currency: newForm.currency, deadline: newForm.deadline,
}]);
setNewForm({ name:’’, goal:’’, currency:‘EUR’, deadline:’’ });
setShowNew(false);
};

const renderProject = ({ item: p }: any) => {
const pct  = Math.min(100, Math.round((p.saved / p.goal) * 100));
const days = Math.max(0, Math.ceil((new Date(p.deadline).getTime() - Date.now()) / 86400000));
const late = days < 30 && pct < 50;
return (
<TouchableOpacity
style={styles.projectCard2}
onPress={() => { setActive(p); setShowDeposit(true); }}
activeOpacity={0.8}
>
<View style={styles.projectCardHeader}>
<View style={styles.projectIconBox}><Text style={{ fontSize: 20 }}>{p.icon}</Text></View>
<View style={{ flex: 1 }}>
<Text style={styles.projectName}>{p.name}</Text>
<Text style={styles.projectSub}>{p.currency} · {days} jours restants</Text>
</View>
<View style={[styles.statusBadge, { backgroundColor: late ? ‘#FEF2F2’ : ‘#F0FDF4’ }]}>
<Text style={[styles.statusText, { color: late ? COLORS.red : COLORS.green }]}>
{late ? ‘⚠ Risque’ : ‘En route’}
</Text>
</View>
</View>
<View style={styles.amountRow}>
<Text style={styles.savedAmount}>{p.saved.toLocaleString(‘fr-FR’)} <Text style={styles.currencyText}>{p.currency}</Text></Text>
<Text style={styles.goalAmount}>/ {p.goal.toLocaleString(‘fr-FR’)} {p.currency}</Text>
</View>
<View style={styles.progressTrackLight}>
<View style={[styles.progressFillLight, { width: `${pct}%` as any, backgroundColor: pct >= 100 ? COLORS.green : COLORS.navy }]} />
</View>
<Text style={[styles.pctText, { color: pct >= 100 ? COLORS.green : COLORS.slate }]}>
{pct >= 100 ? ‘✓ Objectif atteint !’ : `${pct}% financé`}
</Text>
</TouchableOpacity>
);
};

return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
<View style={styles.pageHeader}>
<View>
<Text style={styles.pageLabel}>MES PROJETS</Text>
<Text style={styles.pageTitle}>{projects.length} Projet{projects.length !== 1 ? ‘s’ : ‘’}</Text>
</View>
<TouchableOpacity style={styles.btnSmall} onPress={() => setShowNew(true)}>
<Text style={styles.btnSmallText}>+ Nouveau</Text>
</TouchableOpacity>
</View>

```
  <FlatList
    data={projects}
    renderItem={renderProject}
    keyExtractor={p => p.id}
    contentContainerStyle={{ padding: 16, paddingBottom: 40 }}
    showsVerticalScrollIndicator={false}
    ListEmptyComponent={
      <View style={styles.empty}>
        <Text style={styles.emptyIcon}>📋</Text>
        <Text style={styles.emptyTitle}>Aucun projet</Text>
        <Text style={styles.emptyText}>Créez votre premier objectif d'épargne</Text>
      </View>
    }
  />

  {/* MODAL: Dépôt */}
  <Modal visible={showDeposit} animationType="slide" presentationStyle="pageSheet" onRequestClose={() => setShowDeposit(false)}>
    <SafeAreaView style={{ flex: 1, backgroundColor: COLORS.white }}>
      <View style={styles.modalHeader}>
        <View>
          <Text style={styles.modalTitle}>{active?.name}</Text>
          <Text style={styles.modalSub}>{active?.icon} · {active?.currency}</Text>
        </View>
        <TouchableOpacity onPress={() => { setShowDeposit(false); setDeposit(''); }}>
          <Text style={{ fontSize: 20, color: COLORS.slate }}>✕</Text>
        </TouchableOpacity>
      </View>

      {active && (
        <>
          <View style={styles.depositInfo}>
            <Text style={styles.depositSaved}>{active.saved.toLocaleString('fr-FR')} <Text style={styles.depositCurrency}>{active.currency}</Text></Text>
            <Text style={styles.depositGoal}>/ {active.goal.toLocaleString('fr-FR')} {active.currency}</Text>
          </View>

          <View style={{ paddingHorizontal: 20 }}>
            <Text style={styles.label}>MONTANT ({active.currency})</Text>
            <TextInput
              style={[styles.input, { fontSize: 24, fontWeight: '800' }]}
              placeholder="0.00"
              placeholderTextColor={COLORS.muted}
              value={deposit}
              onChangeText={setDeposit}
              keyboardType="decimal-pad"
            />
            <View style={styles.quickAmounts}>
              {[50, 100, 500, 1000].map(a => (
                <TouchableOpacity key={a} onPress={() => setDeposit(String(a))} style={[styles.quickBtn, deposit === String(a) && styles.quickBtnActive]}>
                  <Text style={[styles.quickBtnText, deposit === String(a) && { color: COLORS.white }]}>+{a}</Text>
                </TouchableOpacity>
              ))}
            </View>
            <TouchableOpacity style={styles.btnPrimary} onPress={handleDeposit}>
              <Text style={styles.btnPrimaryText}>Déposer {deposit ? `${parseFloat(deposit || '0').toLocaleString('fr-FR')} ${active.currency}` : ''}</Text>
            </TouchableOpacity>
          </View>
        </>
      )}
    </SafeAreaView>
  </Modal>

  {/* MODAL: Nouveau projet */}
  <Modal visible={showNew} animationType="slide" presentationStyle="pageSheet" onRequestClose={() => setShowNew(false)}>
    <SafeAreaView style={{ flex: 1, backgroundColor: COLORS.white }}>
      <View style={styles.modalHeader}>
