// ─── COULEURS & CONSTANTES ──────────────────────────────────────
export const COLORS = {
navy:    ‘#0A1628’,
navy2:   ‘#1E3A5F’,
gold:    ‘#C9A84C’,
gold2:   ‘#E8C97A’,
slate:   ‘#64748B’,
light:   ‘#F8FAFC’,
white:   ‘#FFFFFF’,
border:  ‘#E2E8F0’,
text:    ‘#0F172A’,
muted:   ‘#94A3B8’,
green:   ‘#0F766E’,
red:     ‘#DC2626’,
};

// ════════════════════════════════════════════════════════════════
// 1. ÉCRAN LOGIN / REGISTER (app/(auth)/login.tsx)
// ════════════════════════════════════════════════════════════════

import React, { useState, useRef } from ‘react’;
import {
View, Text, TextInput, TouchableOpacity, StyleSheet,
ScrollView, KeyboardAvoidingView, Platform, Alert,
Animated, ActivityIndicator, Image,
} from ‘react-native’;
import { SafeAreaView } from ‘react-native-safe-area-context’;
import { router } from ‘expo-router’;
import * as LocalAuthentication from ‘expo-local-authentication’;
import { useAuth } from ‘../../contexts/AuthContext’;

export function LoginScreen() {
const { login } = useAuth();
const [email, setEmail]       = useState(’’);
const [password, setPassword] = useState(’’);
const [showPwd, setShowPwd]   = useState(false);
const [loading, setLoading]   = useState(false);
const shakeAnim = useRef(new Animated.Value(0)).current;

const shake = () => {
Animated.sequence([
Animated.timing(shakeAnim, { toValue: 10,  duration: 60, useNativeDriver: true }),
Animated.timing(shakeAnim, { toValue: -10, duration: 60, useNativeDriver: true }),
Animated.timing(shakeAnim, { toValue: 6,   duration: 60, useNativeDriver: true }),
Animated.timing(shakeAnim, { toValue: 0,   duration: 60, useNativeDriver: true }),
]).start();
};

const handleLogin = async () => {
if (!email || !password) { shake(); return; }
setLoading(true);
try {
await login(email.toLowerCase().trim(), password);
router.replace(’/(app)/dashboard’);
} catch (e: any) {
shake();
Alert.alert(‘Erreur’, e.message === ‘account_not_found’
? ‘Aucun compte trouvé avec cet email’
: ‘Mot de passe incorrect’);
}
setLoading(false);
};

const handleBiometric = async () => {
const result = await LocalAuthentication.authenticateAsync({
promptMessage: ‘Accès Pro.G’,
fallbackLabel: ‘Utiliser le mot de passe’,
});
if (result.success) router.replace(’/(app)/dashboard’);
};

return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
<KeyboardAvoidingView
style={{ flex: 1 }}
behavior={Platform.OS === ‘ios’ ? ‘padding’ : ‘height’}
>
<ScrollView
contentContainerStyle={styles.authContainer}
keyboardShouldPersistTaps="handled"
>
{/* Logo */}
<View style={styles.logoWrap}>
<View style={styles.logoBox}>
<Text style={styles.logoEmoji}>🏦</Text>
</View>
<Text style={styles.logoText}>
Pro<Text style={{ color: COLORS.gold }}>.G</Text>
</Text>
<Text style={styles.logoSub}>Votre plateforme d’épargne intelligente</Text>
</View>

```
      <Animated.View style={{ transform: [{ translateX: shakeAnim }] }}>
        {/* Email */}
        <Text style={styles.label}>ADRESSE EMAIL</Text>
        <TextInput
          style={styles.input}
          placeholder="votre@email.com"
          placeholderTextColor={COLORS.muted}
          value={email}
          onChangeText={setEmail}
          keyboardType="email-address"
          autoCapitalize="none"
          autoCorrect={false}
        />

        {/* Password */}
        <Text style={styles.label}>MOT DE PASSE</Text>
        <View style={styles.inputRow}>
          <TextInput
            style={[styles.input, { flex: 1, marginBottom: 0 }]}
            placeholder="••••••••"
            placeholderTextColor={COLORS.muted}
            value={password}
            onChangeText={setPassword}
            secureTextEntry={!showPwd}
            onSubmitEditing={handleLogin}
          />
          <TouchableOpacity
            onPress={() => setShowPwd(p => !p)}
            style={styles.eyeBtn}
          >
            <Text style={styles.eyeText}>{showPwd ? '🙈' : '👁️'}</Text>
          </TouchableOpacity>
        </View>

        <TouchableOpacity onPress={() => router.push('/(auth)/forgot')}>
          <Text style={styles.forgotText}>Mot de passe oublié ?</Text>
        </TouchableOpacity>

        {/* Login Button */}
        <TouchableOpacity
          style={[styles.btnPrimary, loading && { opacity: 0.7 }]}
          onPress={handleLogin}
          disabled={loading}
        >
          {loading
            ? <ActivityIndicator color="#fff" />
            : <Text style={styles.btnPrimaryText}>Se connecter</Text>
          }
        </TouchableOpacity>

        {/* Biometric */}
        <TouchableOpacity
          style={styles.btnBiometric}
          onPress={handleBiometric}
        >
          <Text style={styles.btnBiometricText}>
            {Platform.OS === 'ios' ? '🔒 Face ID / Touch ID' : '🔒 Empreinte digitale'}
          </Text>
        </TouchableOpacity>
      </Animated.View>

      <View style={styles.switchRow}>
        <Text style={styles.switchText}>Nouveau sur Pro.G ? </Text>
        <TouchableOpacity onPress={() => router.push('/(auth)/register')}>
          <Text style={styles.switchLink}>Créer un compte</Text>
        </TouchableOpacity>
      </View>
    </ScrollView>
  </KeyboardAvoidingView>
</SafeAreaView>
```

);
}

// ─── REGISTER SCREEN (3 étapes) ─────────────────────────────────
export function RegisterScreen() {
const { register } = useAuth();
const [step, setStep]         = useState(1);
const [form, setForm]         = useState({ name:’’, email:’’, phone:’’, password:’’, confirm:’’ });
const [pin, setPin]           = useState([’’,’’,’’,’’]);
const [otp, setOtp]           = useState(’’);
const [fakeOtp, setFakeOtp]   = useState(’’);
const [showPwd, setShowPwd]   = useState(false);
const [loading, setLoading]   = useState(false);
const pinRefs = [useRef<TextInput>(null), useRef<TextInput>(null), useRef<TextInput>(null), useRef<TextInput>(null)];

const f = (k: string, v: string) => setForm(p => ({ …p, [k]: v }));

const step1 = () => {
if (!form.name || !form.email.includes(’@’) || !form.phone) {
Alert.alert(‘Erreur’, ‘Remplissez tous les champs’); return;
}
if (form.password.length < 6) {
Alert.alert(‘Erreur’, ‘Mot de passe trop court (6 min)’); return;
}
if (form.password !== form.confirm) {
Alert.alert(‘Erreur’, ‘Mots de passe différents’); return;
}
setStep(2);
};

const step2 = () => {
if (pin.some(d => !d)) { Alert.alert(‘Erreur’, ‘Entrez un PIN à 4 chiffres’); return; }
const code = Math.floor(100000 + Math.random() * 900000).toString();
setFakeOtp(code);
Alert.alert(‘Code de vérification (simulé)’, `Votre code : ${code}`);
setStep(3);
};

const doRegister = async () => {
if (otp !== fakeOtp) { Alert.alert(‘Erreur’, ‘Code incorrect’); return; }
setLoading(true);
try {
await register({ …form, pin: pin.join(’’), lang: ‘fr’ });
router.replace(’/(app)/dashboard’);
} catch (e: any) {
Alert.alert(‘Erreur’, e.message === ‘email_taken’ ? ‘Email déjà utilisé’ : ‘Erreur. Réessayez.’);
}
setLoading(false);
};

const handlePin = (val: string, idx: number) => {
if (!/^\d*$/.test(val)) return;
const n = […pin]; n[idx] = val.slice(-1); setPin(n);
if (val && idx < 3) pinRefs[idx + 1].current?.focus();
};

return (
<SafeAreaView style={{ flex: 1, backgroundColor: COLORS.light }}>
<KeyboardAvoidingView style={{ flex: 1 }} behavior={Platform.OS === ‘ios’ ? ‘padding’ : ‘height’}>
<ScrollView contentContainerStyle={styles.authContainer} keyboardShouldPersistTaps="handled">

```
      {/* Progress */}
      <View style={styles.progressRow}>
        {[1,2,3].map(s => (
          <View key={s} style={[styles.progressBar, { backgroundColor: step >= s ? COLORS.navy : COLORS.border }]} />
        ))}
      </View>

      {step === 1 && (
        <>
          <Text style={styles.screenTitle}>Informations personnelles</Text>
          <Text style={styles.screenSub}>Étape 1 sur 3</Text>
          {[
            { key:'name',    label:'NOM COMPLET',       placeholder:'Nom Prénom',              type:'default' as const },
            { key:'email',   label:'EMAIL',             placeholder:'votre@email.com',          type:'email-address' as const },
            { key:'phone',   label:'TÉLÉPHONE',         placeholder:'+33 6 00 00 00 00',        type:'phone-pad' as const },
          ].map(({ key, label, placeholder, type }) => (
            <View key={key}>
              <Text style={styles.label}>{label}</Text>
              <TextInput
                style={styles.input}
                placeholder={placeholder}
                placeholderTextColor={COLORS.muted}
                value={(form as any)[key]}
                onChangeText={v => f(key, v)}
                keyboardType={type}
                autoCapitalize={key === 'email' ? 'none' : 'words'}
              />
            </View>
          ))}
          <Text style={styles.label}>MOT DE PASSE</Text>
          <View style={styles.inputRow}>
            <TextInput style={[styles.input, { flex: 1, marginBottom: 0 }]} placeholder="6 caractères min" placeholderTextColor={COLORS.muted} value={form.password} onChangeText={v => f('password', v)} secureTextEntry={!showPwd} />
            <TouchableOpacity onPress={() => setShowPwd(p => !p)} style={styles.eyeBtn}><Text style={styles.eyeText}>{showPwd ? '🙈' : '👁️'}</Text></TouchableOpacity>
          </View>
          <Text style={styles.label}>CONFIRMER</Text>
          <TextInput style={styles.input} placeholder="Ressaisissez le mot de passe" placeholderTextColor={COLORS.muted} value={form.confirm} onChangeText={v => f('confirm', v)} secureTextEntry />
          <TouchableOpacity style={styles.btnPrimary} onPress={step1}>
            <Text style={styles.btnPrimaryText}>Continuer →</Text>
          </TouchableOpacity>
        </>
      )}

      {step === 2 && (
        <>
          <Text style={styles.screenTitle}>Code PIN</Text>
          <Text style={styles.screenSub}>Étape 2 sur 3 — Choisissez un PIN à 4 chiffres</Text>
          <View style={styles.pinRow}>
            {pin.map((d, i) => (
              <TextInput
                key={i}
                ref={pinRefs[i]}
                style={styles.pinBox}
                maxLength={1}
                keyboardType="numeric"
                secureTextEntry
                value={d}
                onChangeText={v => handlePin(v, i)}
                onKeyPress={({ nativeEvent }) => {
                  if (nativeEvent.key === 'Backspace' && !d && i > 0) pinRefs[i - 1].current?.focus();
                }}
              />
            ))}
          </View>
          <TouchableOpacity style={styles.btnPrimary} onPress={step2}>
            <Text style={styles.btnPrimaryText}>Continuer →</Text>
          </TouchableOpacity>
        </>
      )}

      {step === 3 && (
        <>
          <Text style={styles.screenTitle}>Vérification email</Text>
          <Text style={styles.screenSub}>Étape 3 sur 3 — Code envoyé à {form.email}</Text>
          <View style={styles.warningBox}>
            <Text style={styles.warningText}>📧 Simulation : Le code est affiché dans l'alerte ci-dessus</Text>
          </View>
          <Text style={styles.label}>CODE DE VÉRIFICATION</Text>
          <TextInput
            style={[styles.input, { fontSize: 28, fontWeight: '800', letterSpacing: 8, textAlign: 'center' }]}
            placeholder="——————"
            placeholderTextColor={COLORS.muted}
            value={otp}
            onChangeText={v => setOtp(v.replace(/\D/g, ''))}
            keyboardType="numeric"
            maxLength={6}
          />
          <TouchableOpacity style={[styles.btnPrimary, loading && { opacity: 0.7 }]} onPress={doRegister} disabled={loading}>
            {loading ? <ActivityIndicator color="#fff" /> : <Text style={styles.btnPrimaryText}>Créer mon compte</Text>}
          </TouchableOpacity>
        </>
      )}

      {step > 1 && (
        <TouchableOpacity onPress={() => setStep(s => s - 1)} style={{ marginTop: 16, alignItems: 'center' }}>
          <Text style={{ color: COLORS.slate, fontSize: 13, fontWeight: '600' }}>← Retour</Text>
        </TouchableOpacity>
      )}
    </ScrollView>
  </KeyboardAvoidingView>
</SafeAreaView>
```

);
}

